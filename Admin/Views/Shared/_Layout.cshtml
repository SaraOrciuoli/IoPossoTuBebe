<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - RetailCassa</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Roboto:400,500,700&subset=latin,cyrillic-ext" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- CSS Libraries -->
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.10.20/css/jquery.dataTables.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/scroller/2.0.1/css/scroller.dataTables.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/buttons/1.6.1/css/buttons.dataTables.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @Scripts.Render("~/bundles/jquery")
    @Styles.Render("~/Content/DevExtremeBundle")
    @Scripts.Render("~/Scripts/DevExtremeBundle")

    <style>
        :root {
            --primary-color: #1a73e8;
            --primary-dark: #0d47a1;
            --primary-light: #4285f4;
            --sidebar-width: 280px;
            --navbar-height: 70px;
            --shadow-light: 0 2px 10px rgba(0,0,0,0.08);
            --shadow-medium: 0 4px 20px rgba(0,0,0,0.12);
            --border-radius: 8px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f8f9fa;
            color: #333;
            line-height: 1.6;
            overflow-x: hidden;
        }

        .layout-container {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Moderna */
        .sidebar-modern {
            width: var(--sidebar-width);
            background: #1e4982;
            color: white;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 1000;
            box-shadow: var(--shadow-medium);
            transition: var(--transition);
            overflow-y: auto;
        }

        .sidebar-header {
            padding: 25px 20px;
            background: rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            text-align: center;
        }

            .sidebar-header img {
                max-width: 180px;
                height: auto;
            }

        a:hover, a:focus {
            color: white;
            text-decoration: none;
        }

        .user-info-modern {
            padding: 25px 20px;
            background: rgba(255,255,255,0.08);
            margin: 15px;
            border-radius: var(--border-radius);
            backdrop-filter: blur(10px);
        }

        .user-name {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 5px;
            color: white;
        }

        .user-email {
            font-size: 13px;
            color: rgba(255,255,255,0.8);
            margin-bottom: 15px;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            color: rgba(255,255,255,0.9);
            text-decoration: none;
            padding: 8px 15px;
            background: rgba(255,255,255,0.1);
            border-radius: 6px;
            transition: var(--transition);
            font-size: 14px;
            border: 1px solid rgba(255,255,255,0.2);
        }

            .logout-btn:hover {
                background: rgba(255,255,255,0.2);
                color: white;
                transform: translateY(-1px);
            }

        .submenu {
            display: none;
        }

            .submenu.active {
                display: block;
            }
        /* Menu Moderno */
        .modern-menu {
            padding: 20px 0;
        }

        .menu-section {
            margin-bottom: 5px;
        }

        .menu-title {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.6);
            padding: 0 25px 10px;
            font-weight: 600;
        }

        .menu-item {
            list-style: none;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 25px;
            color: rgba(255,255,255,0.9);
            text-decoration: none;
            transition: var(--transition);
            border-left: 3px solid transparent;
            font-weight: 500;
        }

            .menu-link:hover, .menu-link.active {
                background: rgba(255,255,255,0.1);
                color: white;
                border-left-color: #4fc3f7;
            }

            .menu-link i {
                font-size: 20px;
                width: 24px;
                text-align: center;
            }

        .submenu {
            background: rgba(0,0,0,0.2);
            margin-left: 20px;
            border-radius: 6px;
            overflow: hidden;
        }

            .submenu .menu-link {
                padding: 10px 20px;
                font-size: 14px;
                border-left: none;
            }

        /* Navbar Moderna */
        .navbar-modern {
            height: var(--navbar-height);
            background: #ffffff;
            box-shadow: var(--shadow-light);
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            z-index: 999;
            display: flex;
            align-items: center;
            padding: 0 30px;
        }

        .navbar-brand-modern {
            color: #21abe2;
            font-size: 22px;
            font-weight: 700;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .navbar-brand-modern:hover {
                color: #0d47a1;
            }

        .navbar-actions {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        /* Contenuto Principale */
        .main-content {
            flex: 1;
            margin-left: var(--sidebar-width);
            padding: 20px;
            min-height: 100vh;
            background: #f8f9fa;
        }

        .content-card {
            background: white;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow-light);
            padding: 25px;
            margin-bottom: 25px;
        }

        .sidebar-footer {
            padding: 5px;
            text-align: center;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: auto;
            color: rgb(255 255 255);
            font-size: 12px;
            position: fixed;
            bottom: 0;
            width: 280px;
            background: #ffffff1a;
        }

        .version-badge {
            background: rgba(255,255,255,0.1);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            margin-top: 8px;
            display: inline-block;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .sidebar-modern {
                transform: translateX(-100%);
                width: 280px;
            }

                .sidebar-modern.mobile-open {
                    transform: translateX(0);
                }

            .navbar-modern {
                left: 0;
            }

            .main-content {
                margin-left: 0;
                padding-left: 20px;
                padding-right: 20px;
            }

            .mobile-menu-btn {
                display: block;
            }
        }

        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            color: white;
            font-size: 24px;
            cursor: pointer;
            margin-right: 15px;
        }

        /* Scrollbar Personalizzato */
        .sidebar-modern::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar-modern::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.1);
        }

        .sidebar-modern::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.3);
            border-radius: 3px;
        }

        .slimScrollBar {
            width: 6px !important;
            background: rgba(255,255,255,0.3) !important;
        }
    </style>
</head>
<body>
    <!-- Page Loader -->
