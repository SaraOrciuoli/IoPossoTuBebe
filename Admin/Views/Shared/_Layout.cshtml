                                <li class="menu-item">
                                    <a href="/Collezioni/EditCollezione" class="menu-link">Aggiungi Collezione</a>
                                </li>
                            </ul>
                        </li>

                        <!-- Prodotti -->
                        <li class="menu-item">
                            <a href="javascript:void(0);" class="menu-link menu-toggle">
                                <i class="material-icons">shopping_bag</i>
                                <span>Prodotti</span>
                            </a>
                            <ul class="submenu">
                                <li class="menu-item">
                                    <a href="/Prodotti/Index" class="menu-link">Prodotti</a>
                                </li>
                                <li class="menu-item">
                                    <a href="/Prodotti/Edit" class="menu-link">Aggiungi Prodotto</a>
                                </li>
                                <li class="menu-item">
                                    <a href="/CodiciSconto/Index" class="menu-link">Sconti & Promozioni</a>
                                </li>
                            </ul>
                        </li>

                        <!-- Ordini -->
                        <li class="menu-item">
                            <a href="/Ordini/IndexOrdini" class="menu-link">
                                <i class="material-icons">receipt_long</i>
                                <span>Ordini</span>
                            </a>
                        </li>

                        <!-- Fatture -->
                        <!--<li class="menu-item">
                    <a href="javascript:void(0);" class="menu-link menu-toggle">
                        <i class="material-icons">payments</i>
                        <span>Fatture</span>
                    </a>
                    <ul class="submenu">
                        <li class="menu-item">
                            <a href="/Fatture/Index" class="menu-link">Fatture</a>
