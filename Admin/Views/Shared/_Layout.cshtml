                        <li class="menu-item">
                            <a href="/Configurazioni/IndexTipoFatture" class="menu-link">Tipi Fatture</a>
                        </li>
                        <li class="menu-item">
                            <a href="/Configurazioni/IndexFornitori" class="menu-link">Fornitori</a>
                        </li>
                        <li class="menu-item">
                            <a href="/Configurazioni/IndexCategorieFatture" class="menu-link">Categorie Fattura</a>
                        </li>
                    </ul>
                </li>-->
                        <!-- Report -->
                        @*<li class="menu-item">
                        <a href="/Report/Index" class="menu-link">
                            <i class="material-icons">analytics</i>
                            <span>Report</span>
                        </a>
                    </li>*@

                        <!-- Configurazioni -->
                        <li class="menu-item">
                            <a href="javascript:void(0);" class="menu-link menu-toggle">
                                <i class="material-icons">settings</i>
                                <span>Configurazioni</span>
                            </a>
                            <ul class="submenu">
                                @*<li class="menu-item">
                                    <a href="/Configurazioni/IndexMarchi" class="menu-link">Gestione Marchi</a>
                                </li>*@
                                @*<li class="menu-item">
                                <a href="/Configurazioni/IndexTaglie" class="menu-link">Dimensioni Prodotti</a>
                            </li>
                            <li class="menu-item">
                                <a href="/Configurazioni/IndexColori" class="menu-link">Gestione Colori</a>
                            </li>
                            <li class="menu-item">
