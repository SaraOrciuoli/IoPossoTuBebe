    //    DevExpress.pdfExporter.exportDataGrid({
    //        jsPDFDocument: doc,
    //        component: e.component,
    //        indent: 5,
    //        format: 'A4',
    //        landscape: true,
    //    }).then(function () {
    //        doc.save("ListaUtenti.pdf");
    //    });
    //}
    function fileUploader_valueChanged(e) {
        var myNode = document.getElementById('imageAllergen');
        for (var i = myNode.childNodes.length - 1; i >= 0; --i) {
            myNode.removeChild(myNode.childNodes[i]);
        }
        var pathFoto = $("#Path_icon").dxTextBox('instance').option('value', e.request.responseText);
        var img = document.createElement('img');
        img.src = e.request.responseText;
        //img.style = "border:none";
        img.className = "form-avatar_icons"
        document.getElementById('imageAllergen').appendChild(img);
    }

    function fileUploader_pathFile(e) {
        var idPathFoto = $('#Path_icon').dxTextBox('instance').option('value');
        var avatar = $('.form-avatar_icons');

        if (idPathFoto != "") {
            var img = document.createElement('img');
            img.src = idPathFoto;
            //img.style = "border:none";
            img.className = "form-avatar_icons "
            document.getElementById('imageAllergen').appendChild(img);
        }


    }


