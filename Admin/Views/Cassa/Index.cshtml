<div class="row ">
    <div class="col-lg-5 col-md-5 panelListaProdottiCassa" style="height:594px">
        <div id="ListaScontrino">
        </div>
    </div>
    <div class="col-lg-5 col-md-4 panelProdotti" style="height:380px">

        <div class="row myRowValue">
            <div class="col-xs-4 col-lg-4 col-md-12 d-flex myColValue" style="padding-left: 30px; padding-right: 30px;">

                <input class="form-control myMarginImput" type="text" id="ValoreInput" placeholder="" />
            </div>
        </div>
        <div style="margin-right: 11px;">
            <div class="row ">
                <div class="col-md-12 col-lg-12  col-xs-12">
                    <div class="col-md-10 col-lg-6  col-xs-6">
                        <div class="text-center fulKeybord" @*style="margin-left: -15px; "*@>
                            <div class="myKeyborad " tabindex="-1">
                                @foreach (var nc in numberChar)
                                {

                                    if (nc == 'c')
                                    {
                                        <button class="btn  btn-ticket" onclick="cleanNumber('ValoreInput')"><i class="material-icons">delete</i></button>
                                    }
                                    else
                                    {
                                        <button class="btn  btn-ticket" onclick="printChar('@nc','ValoreInput')">@nc</button>
                                    }

                                }

                            </div>
                            <div class="row">
                                <div class="text-end " style="width:311px">
                                    @if (System.Configuration.ConfigurationManager.AppSettings["Sconto"] != "0")
                                    {
                                        @*  <img src="~/Content/Img/percentuale.png" class=" btn btn-Special" id="Sconto" style="cursor:pointer;" onclick="addSconto()" />*@
                                        <button class="btn btn-SpecialVarie" onclick="addSconto()"><strong>% &nbsp Sconto</strong></button>
                                    }
                                    @if (System.Configuration.ConfigurationManager.AppSettings["Varie"] != "0")
                                    {
                                        <button class="btn btn-SpecialVarie " type="button" name="inlineRadioOptions" id="btnVarie" onclick="addVarie()"><strong>Varie</strong></button>
                                    }
                                </div>


                            </div>
                        </div>

                    </div>

                    <div class="col-lg-6 col-md-2  ">
                        <div class="" style="width: 103px; margin-left: -41px; ">
                            @if (System.Configuration.ConfigurationManager.AppSettings["AddProdotto"] != "0")

                            {
                                @*<img class="btn btn-SpecialAddProd" type="button" name="inlineRadioOptions" id="btnAddProd" onclick="GetBarCodeByInput()" src="~/Content/Img/prodotto (2).png" />*@
                                <button class="btn btn-SpecialAddProd" type="button" name="inlineRadioOptions" id="btnAddProd" onclick="GetBarCodeByInput()"><strong>+<br /><br />Prd</strong></button>
                            }
                            @if (System.Configuration.ConfigurationManager.AppSettings["ClienteVersato"] != "0")
                            {
                                @* <img class="btn btn-SpecialAddVers" type="button" name="inlineRadioOptions" id="btnVersatoCliente" onclick="ShowVersatoClienti()" src="~/Content/Img/versato (2).png" />*@
                                <button class="btn btn-SpecialAddProd" type="button" name="inlineRadioOptions" id="btnVersatoCliente" onclick="ShowVersatoClienti()" style="margin:5px !important"><strong>€<br /><br />Ver</strong></button>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="row d-flex justify-content-center" style="margin-top: 20px; ">
                <div class="col-md-12 col-lg-6 d-flex justify-content-center"  style="margin-top: 10px; ">
                    @if (System.Configuration.ConfigurationManager.AppSettings["NonFiscale"] != "0")
                    {
                        <img src="~/Content/ImgCat/icona 3.png" class=" btn-disable imgAcq" id="StampaScontrinoNonFiscale" style="cursor:pointer;" onclick="StampaScontrinoNonFiscale()" />
                    }
                    <img src="~/Content/ImgCat/icona 1.png" class=" btn-disable imgAcq" id="CheckBoxContanti" style="cursor:pointer; " onclick="CheckMetodoContanti('Contanti')" />
                    <img src="~/Content/ImgCat/icona-1.png" class=" btn-disable imgAcq" id="CheckBoxContantiVerde" style="cursor: pointer; display: none; "  />
                    <img src="~/Content/ImgCat/icona 2.png" class=" btn-disable imgAcq" id="CheckBoxCarte" style="cursor:pointer;" onclick="CheckMetodoCarte('Carte')" />
                    <img src="~/Content/ImgCat/icona-2.png" class=" btn-disable imgAcq" id="CheckBoxCarteVerde" style="cursor: pointer; display: none; " />
                </div>
            </div>

            <div class="row d-flex justify-content-center" style="margin-top: 20px; ">
                <div class="col-md-4 d-flex justify-content-center" style="margin-left: 10px;">
                    <button class="btn btn-Special" onclick="ScontrinoRegalo()"><strong style=" padding-left: 3px; padding-right: 3px;">Scontrino Regalo</strong></button>
                    <button class="btn btn-Special" onclick="AnnullaScontrino()"><strong>Annulla Scontrino</strong></button>
                </div>
                


            </div>
            <div class="row d-flex justify-content-center" style="margin-top: 9px; ">
                <div class="col-md-4 d-flex justify-content-center" style="margin-left: 10px;">
                    @if (System.Configuration.ConfigurationManager.AppSettings["OrdiniWeb"] != "0")
                    {
                        <button class="btn btn-Special" onclick="OrdiniWeb()"><strong style=" padding-left: 28px; padding-right: 28px;">Ordini Web</strong></button>
                    }
                    <button  class="btn btn-Special" onclick="LetturaCassa()"><strong  style=" padding-left: 24px; padding-right: 24px;"> Stato Cassa  </strong></button>

                </div>
               
            </div>
        </div>

    </div>
    <div class="col-lg-4 col-md-2 panelClienti text-center" style="min-height:380px">
        <div class="d-flex justify-content-center mt5" id="">
            <button class="btn btn-Special " type="button" onclick="ShowClientModal()"><strong>Clienti</strong></button>
            @* <strong class="text-center">Clienti</strong>*@

            @*   <strong >Clienti <span class="text-center" id="importoScontoOrdine">+</span></strong>*@

        </div>
        <div style="font-size:16px;">
            <label>Nome:</label>
            <p id="ClientName"></p>
            <br />
            <label>Cognome:</label>
            <p id="ClientSurname"></p>
            <br />
            <label class="labelFullName">Ragione Sociale:</label>
            <p id="ClientFullName"></p>
        </div>
    </div>
    <div class="row d-flex justify-content-end" style="margin-top: 20px; ">
        <div class="col-md-5 text-center">
            <div class="text-end" style="margin-left: 13px; text-align: end; margin-top: 1px;">
                @if (int.Parse(HttpContext.Current.Request.Cookies["userRetailCassa"].Values["IdRuolo"].ToString()) == (int)Admin.Classi.Configuration.EnumRuoli.Ruoli.Admin || int.Parse(HttpContext.Current.Request.Cookies["userRetailCassa"].Values["IdRuolo"].ToString()) == (int)Admin.Classi.Configuration.EnumRuoli.Ruoli.Test)
                {
                    <button class="btn btn-SpecialAmmin" onclick="BackHome()"><strong>Amministrazione</strong></button>
                }
            <button class="btn btn-SpecialAmmin" onclick="chiudiPOS()"><strong>Chiusura <br /> Giornaliera</strong></button>
               @* @if (System.Configuration.ConfigurationManager.AppSettings["OrdiniWeb"] != "0")
                {
                    <img src="~/Content/Img/tap.png" class="pull-left btn-disable imgAcq" id="Ordini" title="Vedi Ordini" style="cursor:pointer;" onclick="OrdiniWeb()" />
                }*@
            </div>
        </div>
       
    </div>
      
</div>



@*----------------------------  Modale Clienti --------------------------*@
@using (Ajax.BeginForm("SalvaCliente", "Cassa", new AjaxOptions { HttpMethod = "Post", OnSuccess = "SelectClient(data)" }))

{
    @Html.ValidationSummary(true)
    @Html.AntiForgeryToken()

    <div class="modal" id="modal_Clienti" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header text-center myModal-header" style=" height: 38px;">
                    <button style="border-radius:4px;" type="button" class="close" data-dismiss="modal">&times;</button>
                    <h2 class="modal-title">Aggiungi cliente</h2>
                </div>
                <div class="modal-body" style="height: 670px; height: 670px; height: 670px; ">
                    <div class="container-fluid w-100">
                        <div class="row max-vh-100">
                            <div class="col-9 text-center mySearch">
                                <input type="text" id="searchBox" name="searchBox" class="Myform-control empty  myBorder grid-width-100" placeholder="Cerca cliente" onfocus="handleFocus('searchBox')">
                            </div>
                        </div>
                    </div>
                    <div>
                        @Html.RadioButtonFor(m => m.ModelEditUtente.is_privato, false, new { @class = "form-control inputRentBike", @type = "radio", @title = "Nome", @id = "inputAzienda", @name = "TipoUtente", onclick = "IsPrivatoAzienda()", value = false })
                        <label for="inputAzienda">Azienda</label>
                        @Html.RadioButtonFor(m => m.ModelEditUtente.is_privato, true, new { @class = "form-control inputRentBike", @type = "radio", @title = "Nome", @id = "inputPrivato", @name = "TipoUtente", onclick = "IsPrivatoAzienda()", value = true })
                        <label for="inputPrivato">Privato</label>
                    </div>

                    


                    <div style="padding: 0 2vw; padding-top: 5px;">
                        <div class="row">
                            <div class="col-xs-4 col-lg-4 col-md-4">
                                <div>
                                    <label class="myPlabel">Nome</label>@*<span style="color: #c9302c"> *</span>*@
                                    @Html.TextBoxFor(m => m.ModelEditUtente.Utente.Nome, new { @class = "form-control inputRentBike", @type = "text", @*required = "required",*@ @title = "Nome", @style = "width: 100%", @id = "inputName", @onfocus = "handleFocus('inputName')" })
                                  
                                <div style="height: 20px;">@Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.Nome, "", new { @class = "text-danger", id = "messageName" })</div> 
                                    

                                </div>
                                
                                <div>
                                    <label class="myPlabel">Indirizzo</label>
                                    @Html.TextBoxFor(m => m.ModelEditUtente.Utente.indirizzo, new{@class = "form-control inputRentBike",@type = "text"@*, required = "required"*@,@title = "Indirizzo",@style = "width: 100%;z-index:10",@id = "inputAddress",@onfocus = "handleFocus('inputAddress')"})
                                <div style="height: 20px;">@Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.indirizzo, "", new { @class = "text-danger" })</div>
                                                                </div>
                                <div class="" id="CodeSito">
                                    <div id="CodeUniv">
                                        <label class="labelCodeUni myPlabel">Codice univoco</label>@*<span class="star" style="color: #c9302c"> *</span>*@
                                        @Html.TextBoxFor(m => m.ModelEditUtente.Utente.CodiceUnivoco, new { @class = "form-control inputRentBike", @type = "text", required = "required", @title = "Codice univoco", @style = "width: 100%", @id = "inputCodiceUni", @onfocus = "handleFocus('inputCodiceUni')" })
                                    <div style="height: 20px;">@Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.CodiceUnivoco, "", new { @class = "text-danger" })</div>
                                    </div>

                                    <div>
                                         <label class="myPlabel">Sito web</label>
                                        @Html.TextBoxFor(m => m.ModelEditUtente.Utente.SitoWeb, new{@class = "form-control inputRentBike",@type = "text"@*, required = "required"*@,@title = "Sito Web",@style = "width: 100%",@id = "inputSitoWeb",@onfocus = "handleFocus('inputSitoWeb')"})
                                    <div style="height: 20px;">@Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.SitoWeb, "", new { @class = "text-danger" })</div>
                                    </div>
                                 </div>
                                
                                <label  class="myPlabel">Data consenso</label>
                                @Html.TextBoxFor(m => m.ModelEditUtente.Utente.DataConsenso, new { @class = "form-control inputRentBike", @type = "date", required = "required", @title = "Data consenso", @style = "width: 100%", @id = "inputDate", @onfocus = "handleFocus('inputDate')"})
                            <div style="height: 20px;"> @Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.DataConsenso, "", new { @class = "text-danger" })</div>

                                
                               
                            </div>
                            <div class="col-xs-4 col-lg-4 col-md-4">
                                <div>
                                    <label class="myPlabel">Cognome</label>@*<span style="color: #c9302c"> *</span>*@
                                    @Html.TextBoxFor(m => m.ModelEditUtente.Utente.Cognome, new { @class = "form-control inputRentBike", @type = "text"@*, required = "required"*@, @title = "Cognome", @style = "width: 100%", @id = "inputSurname", @onfocus = "handleFocus('inputSurname')" })
                                <div style="height: 20px;">@Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.Cognome, "", new { @class = "text-danger", id = "messageSurname" })</div>
                                </div>
                               
                                <div>
                                     <label class="myPlabel">Città</label>
                                     @Html.TextBoxFor(m => m.ModelEditUtente.Utente.Citta, new{@class = "form-control inputRentBike",@type = "text"@*, required = "required"*@,@title = "Città",@style = "width: 100%",@id = "inputCity",@onfocus = "handleFocus('inputCity')"})
                                <div style="height: 20px;"> @Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.Citta, "", new { @class = "text-danger" })</div>
                                </div>
                                <div>
                                    <label class="myPlabel"> Partita IVA</label>@*<span style="color: #c9302c"> *</span>*@
                                    @Html.TextBoxFor(m => m.ModelEditUtente.Utente.p_iva, new { @class = "form-control inputRentBike", @type = "text", required = "required", @title = "Partita IVA", @style = "width: 100%", @id = "inputIVA", @onfocus = "handleFocus('inputIVA')" })
                                <div style="height: 20px;"> @Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.p_iva, "", new { @class = "text-danger", id = "messagePiva" })</div>
                                </div>
                            
                                
                               <div>
                                    <label class="myPlabel"> Pec</label>
                                     @Html.TextBoxFor(m => m.ModelEditUtente.Utente.pec, new{@class = "form-control inputRentBike",@type = "text"@*, required = "required"*@,@title = "Pec",@style = "width: 100%",@id = "inputPec",@onfocus = "handleFocus('inputPec')"})
                               <div style="height: 20px;">@Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.pec, "", new { @class = "text-danger" })</div>
                               </div>
                               
                               <div>
                                   <label class="myPlabel"> Consenso</label>
                                   <br />
                                   @Html.CheckBoxFor(m => m.ModelEditUtente.consentito, new { @class = "", @type = "checkbox", @title = "Consenso", @id = "checkboxConsenso" })


                               </div>
                               


                            </div>
                            <div class="col-xs-4 col-lg-4 col-md-4">
                                <div id="RagionSoc">

                                    <label class="labelRagioneSociale myPlabel">Ragione sociale</label>
                                    @Html.TextBoxFor(m => m.ModelEditUtente.Utente.NomeCompleto, new{@class = "form-control inputRentBike",@type = "text",required = "required"@*, @title = "Ragione sociale"*@,@style = "width: 100%",@id = "inputRagioneSociale",@onfocus = "handleFocus('inputRagioneSociale')"})
                                <div style="height: 20px;">  @Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.NomeCompleto, "", new { @class = "text-danger" })</div>
                                </div>
                               

                                
                                <div class="" id="CapCodeFi">
                                    <div>
                                        <label class="myPlabel">Cap</label>@*<span style="color: #c9302c "> *</span>*@
                                        @Html.TextBoxFor(m => m.ModelEditUtente.Utente.Cap, new { @class = "form-control inputRentBike", @type = "text"@*, required = "required"*@, @title = "Cap", @style = "width: 100%", @id = "inputCap", @onfocus = "handleFocus('inputCap')" })
                                    <div style="height: 20px;"> @Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.Cap, "", new { @class = "text-danger" })</div>
                                    </div>
                                    <div>
                                          <label id="CD" class="myPlabel">Codice Fiscale</label>
                                          @Html.TextBoxFor(m => m.ModelEditUtente.Utente.Codice_Fiscale, new{@class = "form-control inputRentBike",@type = "text"@*, required = "required"*@,@title = "Codice Fiscale",@style = "width: 100%",@id = "inputCodice_Fiscale",@onfocus = "handleFocus('inputCodice_Fiscale')"})
                                    <div style="height: 20px;">  @Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.Codice_Fiscale, "", new { @class = "text-danger", id = "messageCodFi" })</div>
                                    </div>
                                  
                                </div>

                                <div>
                                    <label class="myPlabel">Cellulare</label>
                                    @Html.TextBoxFor(m => m.ModelEditUtente.Utente.Cellulare, new{@class = "form-control inputRentBike",@type = "text"@*, required = "required"*@,@title = "Cellulare",@style = "width: 100%",@id = "inputCellulare",@onfocus = "handleFocus('inputCellulare')"})
                                <div style="height: 20px;">@Html.ValidationMessageFor(m => m.ModelEditUtente.Utente.Cellulare, "", new { @class = "text-danger" })</div>

                                </div>
                                 @Html.HiddenFor(m => m.ModelEditUtente.Utente.id_utente, new { @id = "inputIdUtente" })
                            <div style="height: 20px;">@Html.HiddenFor(m => m.ModelEditUtente.Utente.id_Ruolo, new { @id = "inputIdRuolo" })</div>
                               

                                @*<div class="col-12 text-center mt-5">
                                    <button id="btnValid" class=" mettiInCarrello btn btnRentBike" type="submit">SALVA</button>
                                </div>*@

                            </div>
                        </div>
                    </div>

                   <div class="d-flex justify-content-center">
                        <div class="d-flex justify-content-center mydivContainerKeyboard myPlabel" id="divContainerKeyboard">
         
                        </div>
                        <div class="col-12 text-center">
                            <button id="btnValid" class=" mettiInCarrello btn btnRentBike mySave" type="submit">SALVA</button>
                        </div>
                   </div>
                </div>
            </div>
        </div>
    </div>
}
