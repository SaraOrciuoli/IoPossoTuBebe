                      $('#inputIVA').val(data[0].p_iva);
                      $('#inputPec').val(data[0].pec);
                      $('#inputDate').val(data[0].DataConsenso.split('T')[0]);
                      $('#inputRagioneSociale').val(data[0].NomeCompleto);
                      $('#inputCity').val(data[0].Citta);
                      $('#inputIban').val(data[0].Iban);
                    $('#inputMail').val(data[0].Mail);
                    $('#inputCodice_Fiscale').val(data[0].Codice_Fiscale);
                    $('#inputIdUtente').val(data[0].id_utente);
                    $('#inputIdRuolo').val(data[0].id_Ruolo);
                    $('#checkboxConsenso').val(data[0].Consenso);
                    if (data[0].Consenso == true) {

                        document.getElementById('checkboxConsenso').checked = true;
                    } else {

                        document.getElementById('checkboxConsenso').checked = false;
                    }

                    btnValid.addEventListener("click", function() {
                        document.getElementById('checkboxConsenso').checked = false;
