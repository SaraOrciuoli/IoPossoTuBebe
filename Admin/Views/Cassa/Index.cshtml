                    $('#inputAddress').val("");
                    $('#inputIVA').val("");
                    $('#inputPec').val("");
                    $('#inputDate').val("");
                    $('#inputRagioneSociale').val("");
                    $('#inputCity').val("");
                    $('#inputIban').val("");
                    $('#inputMail').val("");
                    $('#inputCodice_Fiscale').val("");
                    $('#inputIdUtente').val("");
                    $('#inputIdRuolo').val("");
                    $('#checkboxConsenso').val(false);



                }
                // Insert the returned search results html into the result element


            },
