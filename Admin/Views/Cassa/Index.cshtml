<div class="modal" id="modal_OrdiniWeb" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header text-center">
                    <button style="border-radius:4px;" type="button" class="close" data-dismiss="modal">&times;</button>
                    <h2 class="modal-title">Ordini Web</h2>
                </div>
                <div class="modal-body">
                    @(Html.DevExtreme().DataGrid<DAL.Model.DettagliOrdine>()
                                //.DataSource(Model)
                                .DataSource(ds => ds
                                    .Mvc()
                                    .Controller("Ordini")
                                    .Key("id_ordine")
                                    .LoadAction("GetOrdiniOnline")
                                )
                                .ShowBorders(true)
                                .Columns(columns => {
                                     columns.Add()
                                        .Type(GridCommandColumnType.Buttons)
                                        .Width(50)
                                        .Buttons(b =>
                                        {
                                            b.Add().Template(@<text><a  class="menu-toggle"  onclick="CaricaProdotti(<%=data.id_ordine%>)"><i class="material-icons" style="font-size:30px">add_shopping_cart</i></a></text>);
                                        });
                                    columns.AddFor(m => m.Descrizione_tipoVendita).Caption("Tipo Vendita").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                    columns.AddFor(m => m.DataOra).Caption("Data").Format("dd/MM/yyyy HH:mm").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                    columns.AddFor(m => m.Tipo_Pagamento).Caption("Metodo").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                    columns.AddFor(m => m.Totale).Caption("Importo").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                    columns.AddFor(m => m.NumeroPezzi).Caption("N. Pz").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell").Width(90);
                                    columns.AddFor(m => m.Nominativo).Caption("Nominativo").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                    columns.AddFor(m => m.NumTelefono).Caption("Telefono").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                    columns.AddFor(m => m.Note).Caption("Note").Alignment(HorizontalAlignment.Left).CssClass("VerticalCell");
                                })
                                .Paging(p => p.PageSize(9))
                                .FilterRow(f => f.Visible(true))
                                .HeaderFilter(f => f.Visible(true))
                                .Grouping(g => g.AutoExpandAll(false))
                                .RemoteOperations(true)
                                .WordWrapEnabled(true)
                            )


                </div>
            </div>
        </div>
    </div>

