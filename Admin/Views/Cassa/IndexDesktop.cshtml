    let autocomplete;
    let cityAutocomplete;
    let address1Field;
    let cityField;
    let postalField;

    function initAutocomplete() {
        address1Field = document.querySelector("#inputAddress");
        cityField = document.querySelector("#inputCity");
        postalField = document.querySelector("#inputCap");

        autocomplete = new google.maps.places.Autocomplete(address1Field, {
            fields: ["address_components", "geometry"],
            types: ["address"],
        });

        cityAutocomplete = new google.maps.places.Autocomplete(cityField, {
            types: ["(cities)"],
        });

        address1Field.focus();
        autocomplete.addListener("place_changed", fillInAddress);
        cityField.focus();
        cityAutocomplete.addListener("place_changed", fillInCity);
    }

    function fillInAddress() {
        const place = autocomplete.getPlace();
        let address1 = "";
        let postcode = "";

        for (const component of place.address_components) {
            const componentType = component.types[0];

            switch (componentType) {
                case "street_number": {
                    address1 = `${component.long_name} ${address1}`;
                    break;
                }
                case "route": {
                    address1 += component.short_name;
                    break;
                }
                case "postal_code": {
                    postalField.value = component.long_name;
                    postcode = component.long_name;
                    break;
                }
                case "locality": {
                    cityField.value = component.long_name;
                    break;
                }
            }
        }
    }

    function fillInCity() {
        const place = cityAutocomplete.getPlace();
        if (!place.geometry) {
            console.log("Place details not found for the city: ", place.name);
            return;
        }

        cityField.value = place.name;

        const addressComponents = place.address_components;
        for (const component of addressComponents) {
            const types = component.types;
            if (types.includes("postal_code")) {
                postalField.value = component.long_name;
                break;
            }
        }
    }
</script>



