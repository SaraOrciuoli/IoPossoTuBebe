    function CalcolaResto() {
        var vers = document.getElementById("importoversatoCliente").textContent;

        var sconto = '';
        if (@System.Configuration.ConfigurationManager.AppSettings["Sconto"] != "0") {
            var sconto = document.getElementById("importoScontoOrdine").textContent;
        }
        $('#versatoCliente').text(vers + "€");
        var imp = $('#importoScontrino').text();
        if (vers !== '' && vers !== '0,00 €') {

            var diff = (parseFloat(vers.replace('.', '').replace(',', '.').replace('€', '')).toFixed(2) - parseFloat(imp.replace('.', '').replace(',', '.').replace('€', '')).toFixed(2));

        }
        else {
            var diff = "0,00";

        }

        let valoreResto = parseFloat(diff.toString()).toFixed(2) + " €";

        $('#resto').text(valoreResto.replace('.', ','));
    }


