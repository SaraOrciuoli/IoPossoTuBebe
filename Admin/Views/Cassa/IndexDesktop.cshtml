@model Admin.Models.CustomModels.ModelCassa
@{
    ViewBag.Title = "Cassa";
    Layout = "~/Views/Shared/_LayoutCassaDesktop.cshtml";

    char[] numberChar = new char[] { '1', '2', '3', '4', '5', '6', '7', '8', '9', '0', ',', 'c' };

}

<div class="container-fluid cont-panel">
    <div class="row row-panel">
        <div class="col-lg-12 col-panel">
            <div>
                <strong style="color: #EE7A1C;">SUBTOTALE</strong>
                <strong><span class="text-center" id="SubTotaleScontrino">0,00 €</span></strong>
            </div>
            @if (System.Configuration.ConfigurationManager.AppSettings["Sconto"] != "0")
            {

                <div>
                    <strong style="color: #EE7A1C;">SCONTO</strong>
                    <strong><span class="text-center" id="importoScontoOrdine">0,00 €</span></strong>
                </div>

            }
            <div>
                <strong style="color: #EE7A1C;">TOTALE</strong>
                <strong><span class="text-center" id="importoScontrino">0,00 €</span></strong>
            </div>
            @if (System.Configuration.ConfigurationManager.AppSettings["ClienteVersato"] != "0")
            {
                <div>
                    <strong style="color: #EE7A1C;">VERSATO</strong>
                    <strong><span class="text-center" id="importoversatoCliente">0,00 €</span></strong>
                </div>

                <div>
                    <strong style="color: #EE7A1C;">RESTO</strong>
                    <strong><span class="text-center" id="resto">0,00 €</span></strong>
                </div>

            }
        </div>
    </div>
    <div class="row d-flex row-pane-important">
        <div class="col-4  col-panel-important sinistra">
            <div id="ListaScontrino" style="position: fixed; width: 38%;">

            </div>
        </div>
        <div class="row row-img-absolute">
            <div class="col-md-12" style="display: flex; justify-content: space-between; width: 527px !important; left: 8px; margin-bottom: 5px; ">
                @if (System.Configuration.ConfigurationManager.AppSettings["NonFiscale"] != "0")
                {
                    <img src="~/Content/ImgCat/icona 3.png" class=" btn-disable imgAcq" id="StampaScontrinoNonFiscale" style="cursor: pointer; width: 100px; height: 77px " onclick="StampaScontrinoNonFiscale()" />
                }

        
                <img src="~/Content/ImgCat/icona 1.png" class=" btn-disable imgAcq" id="CheckBoxContanti" style="cursor: pointer; width: 100px; height: 77px" onclick="CheckMetodoContanti('Contanti')" />
                <img src="~/Content/ImgCat/icona-1.png" class=" btn-disable imgAcq" id="CheckBoxContantiVerde" style="cursor: pointer; display: none; width: 100px; height: 77px" />


           
            
                <img src="~/Content/ImgCat/icona 2.png" class=" btn-disable imgAcq" id="CheckBoxCarte" style="cursor: pointer; width: 100px; height: 77px" onclick="CheckMetodoCarte('Carte')" />
                <img src="~/Content/ImgCat/icona-2.png" class=" btn-disable imgAcq" id="CheckBoxCarteVerde" style="cursor: pointer; display: none; width: 100px; height: 77px" />


            </div>
        </div>


        <div class="col-4 col-panel-important centro">

            <div class="col-md-5  " style="margin-top: -36px;">
                <div class="row myRowValue">
                    <div class="col-md-12 d-flex" style="margin-top: 40px;">

                        <input class="form-control myMarginImput" type="text" id="ValoreInput" placeholder="" />
                    </div>
                </div>
                <div class=" fulKeybord" style="margin-left: -14px;">
                    <div class="myKeyboard " tabindex="-1">
                        @foreach (var nc in numberChar)
                        {

                            if (nc == 'c')
                            {
                                <button style="font-size:large;" class="btn  btn-ticket" onclick="cleanNumber('ValoreInput')"><i class="material-icons">delete</i></button>
                            }
                            else
                            {
                                <button style="font-size:large;" class="btn  btn-ticket" onclick="printChar('@nc','ValoreInput')">@nc</button>
                            }

                        }

                    </div>
                    <div class="col-lg-3 prd-ver-col  ">
                        <div class="">
                            <button class="btn btn-SpecialAddProd" type="button" name="inlineRadioOptions" id="btnAddProd" onclick="GetBarCodeByInput()" style="margin-top0"><strong>+<br /><br />Prd</strong></button>
                            <button class="btn btn-SpecialAddProd" type="button" name="inlineRadioOptions" id="btnVersatoCliente" onclick="ShowVersatoClienti()"><strong>€<br /><br />Ver</strong></button>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class=" " style="width: 330px;">
                        <button class="btn btn-SpecialVarie" onclick="addSconto()"><strong>% &nbsp Sconto</strong></button>
                        <button class="btn btn-SpecialVarie " type="button" name="inlineRadioOptions" id="btnVarie" onclick="addVarie()"><strong>Varie</strong></button>
                    </div>


                </div>

            </div>


        </div>
        <div class="col-4 col-panel-important destra">
            <button class="btn btn-Clienti " type="button" onclick="ShowClientModal()"><strong>Clienti</strong></button>
            <div class="text-center d-flex justify-content-around" style="font-size:16px; margin-top: 35px;">
                <div>
                    <label style="margin-right: 140px; font-size: larger;">Nome:</label><p id="ClientName" style="margin-right: 140px; font-size: larger; "></p>
                </div>
                <div>
                    <label style=" font-size: larger;">Cognome:</label><p id="ClientSurname" style="font-size: larger;"></p>
                </div>


            </div>
            <div class="text-center" style="margin-top: 30px;">
                <label class="labelFullName" style="font-size: large;">Ragione Sociale:</label>
                <p id="ClientFullName" style="font-size: larger;"></p>
            </div>
            <div class="row d-flex" style=" position: absolute; bottom: 392px; ">
                <div>
                    @if (int.Parse(HttpContext.Current.Request.Cookies["userRetailCassa"].Values["IdRuolo"].ToString()) == (int)Admin.Classi.Configuration.EnumRuoli.Ruoli.Admin || int.Parse(HttpContext.Current.Request.Cookies["userRetailCassa"].Values["IdRuolo"].ToString()) == (int)Admin.Classi.Configuration.EnumRuoli.Ruoli.Test)
                    {
                        <button class="btn btn-SpecialAmmin" onclick="BackHome()"><strong>Amministrazione</strong></button>
                    }
                </div>
                <div>
                    <button class="btn btn-SpecialAmmin" onclick="chiudiPOS()"><strong>Chiusura <br />Giornaliera</strong></button>
                </div>
            </div>
            <div class="row row-btn-absolute">
        
                    <button class="btn btn-Special" onclick="ScontrinoRegalo()"><strong>Scontrino Regalo</strong></button>
                    <button class="btn btn-Special" onclick="AnnullaScontrino()"><strong>Annulla Scontrino</strong></button>
                    @if (System.Configuration.ConfigurationManager.AppSettings["OrdiniWeb"] != "0")
                    {
                        <button class="btn btn-Special" onclick="OrdiniWeb()"><strong style=" padding-left: 28px; padding-right: 28px;">Ordini Web</strong></button>
                    }
                    <button class="btn btn-Special" onclick="LetturaCassa()"><strong style=" padding-left: 24px; padding-right: 24px;"> Stato Cassa  </strong></button>
                </div>
                @*      <div class="col-4 ">
                <button class="btn btn-Special" onclick="AnnullaScontrino()"><strong>Annulla Scontrino</strong></button>

            </div>*@

            </div>
        </div>
     
    </div>

    @*<div class="row">
            <div class="col-4 ">
                <img src="~/Content/ImgCat/icona 3.png"/>
            </div>
            <div class="col-4 ">

            </div>
            <div class="col-4 ">

            </div>
        </div>*@
</div>


@*----------------------------  Modale Clienti --------------------------*@
