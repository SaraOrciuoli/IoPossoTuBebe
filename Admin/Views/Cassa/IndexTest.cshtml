@*---------------------------- Modale Funzione Avanzate --------------------------*@
<div class="modal" id="modal_Funzioni" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-center">
                <button style="border-radius:4px;" type="button" class="close" data-dismiss="modal">&times;</button>
                <h2 class="modal-title">Funzioni Avanzate</h2>
            </div>
            <div class="modal-body">
                <div style="padding: 0 2vw;">
                    <div class="row">
                        <div class="col-lg-12 col-md-12">
                            <button class="btn btn-Special" onclick="chiudiPOS()"><strong>Chiusura Giornaliera</strong></button>
                            <button class="btn btn-Special" onclick="LetturaCassa()"><strong>Stato Cassa</strong></button>
                            <button class="btn btn-Special" onclick="ScontrinoRegalo()"><strong>Scontrino Regalo</strong></button>
                            <button class="btn btn-Special" onclick="AnnullaScontrino()"><strong>Annulla Scontrino</strong></button>
                            @if (int.Parse(HttpContext.Current.Request.Cookies["userRetailCassa"].Values["IdRuolo"].ToString()) == (int)Admin.Classi.Configuration.EnumRuoli.Ruoli.Admin)
                            {
                                <button class="btn btn-Special" onclick="BackHome()"><strong>Amministrazione</strong></button>
                            }
                            @if (System.Configuration.ConfigurationManager.AppSettings["OrdiniWeb"] != "0")
                            {
                                <button class="btn btn-Special" onclick="OrdiniWeb()"><strong>Ordini Web</strong></button>
                            }
                            @if (System.Configuration.ConfigurationManager.AppSettings["Tavoli"] != "0")
                            {
                                <button class="btn btn-Special" onclick="Tavoli()"><strong>Tavoli</strong></button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@*---------------------------- Fine Modale --------------------------*@

@*---------------------------- Modale Ordini Web --------------------------*@
<div class="modal" id="modal_OrdiniWeb" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-center">
                <button style="border-radius:4px;" type="button" class="close" data-dismiss="modal">&times;</button>
                <h2 class="modal-title">Ordini Web</h2>
            </div>
            <div class="modal-body">
                @(Html.DevExtreme().DataGrid<DAL.Model.DettagliOrdine>()
                            //.DataSource(Model)
                            .DataSource(ds => ds
                                .Mvc()
                                .Controller("Ordini")
                                .Key("id_ordine")
                                .LoadAction("GetOrdiniOnline")
                            )
                            .ShowBorders(true)
                            .Columns(columns => {
                                 columns.Add()
                                    .Type(GridCommandColumnType.Buttons)
                                    .Width(50)
                                    .Buttons(b =>
                                    {
                                        b.Add().Template(@<text><a  class="menu-toggle"  onclick="CaricaProdotti(<%=data.id_ordine%>)"><i class="material-icons" style="font-size:30px">add_shopping_cart</i></a></text>);
                                    });
                                columns.AddFor(m => m.Descrizione_tipoVendita).Caption("Tipo Vendita").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                columns.AddFor(m => m.DataOra).Caption("Data").Format("dd/MM/yyyy HH:mm").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                columns.AddFor(m => m.Tipo_Pagamento).Caption("Metodo").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                columns.AddFor(m => m.Totale).Caption("Importo").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                columns.AddFor(m => m.NumeroPezzi).Caption("N. Pz").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell").Width(90);
                                columns.AddFor(m => m.Nominativo).Caption("Nominativo").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                columns.AddFor(m => m.NumTelefono).Caption("Telefono").Alignment(HorizontalAlignment.Center).CssClass("VerticalCell");
                                columns.AddFor(m => m.Note).Caption("Note").Alignment(HorizontalAlignment.Left).CssClass("VerticalCell");
                            })
                            .Paging(p => p.PageSize(9))
                            .FilterRow(f => f.Visible(true))
                            .HeaderFilter(f => f.Visible(true))
                            .Grouping(g => g.AutoExpandAll(false))
                            .RemoteOperations(true)
                            .WordWrapEnabled(true)
                        )


            </div>
        </div>
    </div>
</div>

@*---------------------------- Fine Modale --------------------------*@

@*---------------------------- Modale Tavoli --------------------------*@
<div class="modal" id="modal_Tavoli" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header text-center">
                <button style="border-radius:4px;" type="button" class="close" data-dismiss="modal">&times;</button>
                <h2 class="modal-title">Tavoli</h2>
            </div>
            <div class="modal-body">
                <div class="">
                    <div class="row">
                        @foreach (var tavolo in Model.ListaGestioneTavolo.OrderBy(n => Convert.ToInt32(n.numero)))
                        {
                            string border = tavolo.stato == 2 ? "borderRed" : "borderGreen";

                            if (tavolo.preconto_stampato == true)
                            {
                                border = "borderYellow";
                            }
                            string data = tavolo.id_gestione.ToString() + ',' + tavolo.id_tavolo.ToString() + ',' + tavolo.numero;
                            string persone = !string.IsNullOrEmpty(tavolo.numero_persone.ToString()) ? tavolo.numero_persone.ToString() : "0";
                            string onClick = tavolo.stato == 2 ? $"caricaOrdiniTavolo({data})" : "niente(" + tavolo.numero + ")";

                            string tot = tavolo.totale != null ? string.Format("{0:#.00}", tavolo.totale) : "0,00";

                            <div class="col-md-2 col-sm-3 col-xs-6">
                                <div onclick=@onClick>
                                    <div class="tableDiv @border" id="panelTavoli_@tavolo.id_tavolo">
                                        <div class="row text-right" style="color: #333 !important">
                                            <div class="col-xs-6 text-left">
                                                <p class="numTable"><b>@tavolo.numero</b></p>
                                            </div>
                                            <div class="col-xs-6 text-center">
                                                <img src="~/Content/Img/omini.png" alt="omini" width="30" />
                                                <p style="color: #ee7a1c !important; font-weight: bold"><span>@persone</span> pax</p>
                                            </div>
                                        </div>
                                        <div class="row" style="color: #333 !important">
                                            <div class="col-xs-6 text-left">
                                                <small><b>TIME</b></small>
                                            </div>
                                            <div class="col-xs-6 text-center">
                                                @*<small id="timer_@tavolo.id_tavolo" style="font-size:83%">@tavolo.TempoTrascorso</small>*@
                                            </div>
                                            <div class="col-xs-6 text-left">
                                                <small><b>COSTO</b></small>
                                            </div>
                                            <div class="col-xs-6 text-center">
                                                <small style="color: red !important">€ @tot</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@*---------------------------- Fine Modale --------------------------*@

