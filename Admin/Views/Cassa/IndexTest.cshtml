            function GetTicket() {
        let code = document.querySelector('#HiddenInput');
        /*        alert(code);*/
        code.hidden = true;
                $.ajax({
        type: "POST",
                    url: '@Url.Action("GetTicketByCode", "Cassa")',
                    data: { code: code.value },
                    success: function (result) {
                if (result == 'OK') {
                    ShowScontrino();
                    code.value = "";
                }
                else {
                    alert(result);
                    code.value = "";
                }
            },
                    error: function () {
                alert("Ticket non trovato.");
            }
        });
            }

            function GetBarCode() {
        let barcode = document.querySelector('#HiddenInput');
        barcode.hidden = true;
                $.ajax({
        type: "POST",
                    url: '@Url.Action("GetProdottoByBarCode", "Cassa")',
                    data: { barcode: barcode.value },
                    success: function (result) {
                if (result == 'OK') {
                    ShowScontrino();
                    barcode.value = "";
                }
                else {
                    alert(result);
                    barcode.value = "";
                }
            },
                    error: function () {
                alert("Prodotto non trovato");
            }
        });
            }

