    function addScontoProd() {

        let scontoProd = document.querySelector("#ScontoProdVal").value;
        if (parseFloat(scontoProd.replace(/,/g, '.')) > parseFloat(totxSconto))
        {
            alert("ATTENZIONE:Lo sconto super il valore del prodotto.")
                }
        else
        {
                    $.ajax({
            url: '@Url.Action("AddScontoProd", "Cassa")',
                       type: 'POST',
                       data: { idprod: idProdSconto, sconto: scontoProd  },
                       success: function (resultString) {
                    if (resultString == 'OK') {
                               $('#modal_ScontoProd').modal("hide");
                               $('#ScontoProdVal').val("");
                        ShowScontrino();
                    }
                    else
                    {
                        alert(resultString);
                    }

                },
                       error: function () {
                    alert("error");
                }
            });
                }

            }

