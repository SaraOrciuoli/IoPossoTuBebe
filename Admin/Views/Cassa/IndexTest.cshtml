    function SaveAnnScontrino()
    {
        let codAzzeramento = document.getElementById("codAzzeramento").value;
        let codScontrino = document.getElementById("codScontrino").value;
        let codGestionale = document.getElementById("codGestionale").value;
        let DtScontrino = document.getElementById("DataScontrino").value;
        if ((codAzzeramento !== '' && codAzzeramento !== undefined)
            && (codScontrino !== '' && codScontrino !== undefined))
        {

                        $.ajax({
            url: '@Url.Action("AnnScontrino", "Cassa")',
                           type: 'POST',
                            data:
                {
                codA: codAzzeramento,
                                codS: codScontrino,
                                codG: codGestionale,
                                DataScontrino: DtScontrino
                            },
                            success: function (result) {
                                $('#modal_AnnullaScontrino').modal("hide");
                },
                           error: function () {
                    alert("error");
                }
            });
                }
                else
    {
        alert("Inserire codice azzeramento e codice scontrino!");
    }
            }

