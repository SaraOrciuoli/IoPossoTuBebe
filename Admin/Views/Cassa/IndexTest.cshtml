@if (System.Configuration.ConfigurationManager.AppSettings["Ticket"] != "0")
{
    @*---------------------------- Modale Ticket --------------------------*@
    <div class="modal" id="modal_ticket" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header text-center">
                    <button style="border-radius:4px;" type="button" class="close" data-dismiss="modal">&times;</button>
                    <h2 class="modal-title">Valore Ticket</h2>
                </div>
                <div class="modal-body">
                    <div style="padding: 0 2vw;">
                        <div class="row">
                            <div class="col-xs-4 col-lg-4 col-md-4">
                                <label>Valore:</label>
                                <input   type="text" id="ticketVal" placeholder="€" />
                                <br />
                                <br />
                                <button type="button" class="btn btn-Special" id="add_ticket" value="Salva" onclick="addTicket()">Salva</button>
                            </div>
                            <div class="col-md-6 col-lg-6 col-xs-6 text-center">
                                @foreach (var nc in numberChar)
                                {

                                    if (nc == 'c')
                                    {
                                        <button class="btn btn-success btn-ticket" onclick="cleanNumber('ticketVal')"><i class="material-icons">delete</i></button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-success btn-ticket" onclick="printChar('@nc','ticketVal')">@nc</button>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @*---------------------------- Fine Modale --------------------------*@
}

