                                            .Value(Model.s_p2.id_categoria)
                                        )
                                </div>
                                <div data-id="s1_p2" data-role="cus" class="@(Model.s_p2.type == "cus" ? "" : "d_none" )">
                                    @*<div class="dx-field-label">Immagini Custom</div>*@
                                    @(Html.DevExtreme().FileUploader().ID("cus_s1_p2")
                                            .Name("myFile")
                                            .SelectButtonText("Seleziona un file")
                                            .LabelText("Trascina il file qui")
                                            .Accept("image/*")
                                            .UploadMode(FileUploadMode.UseButtons)
                                            .OnValueChanged("s1_page.ShowCusPreview")
                                            .UploadUrl(Url.Action("UploadImg", "HomeLayout"))

                                        )
                                </div>
                            </div>
                        </div>
                        <div class="panel-body" style="display: flex; justify-content: center; padding-top: 0;">
                            <div class="col-md-6 col-sm-12 d-flex justify-content-center">
