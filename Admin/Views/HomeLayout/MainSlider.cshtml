@model Admin.Models.CustomModels.SliderModel
@{
    ViewBag.Title = "Bacheca Principale";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<style>
    section.content {
        margin: 15px 15px 0 315px;
    }

    .d_none {
        display: none;
    }
    

    #s1_p1_text {
        position: absolute;
        bottom: 0px;
        right: -52px;
        background-color: grey;
        opacity: .5;
        content: "";
        z-index: 1;
        text-align: center;
        height: 150px;
        width: 150px;
        color: white;
        font-size: 2rem;
        vertical-align: middle;
        text-transform: uppercase;
    }

    #text_space {
        margin-top: 25%;
    }
    .image-container, .img-reponsive {
        border: none !important;
        position:relative;
    }
    #clearSlider {
        display: inline-block;
        margin: auto 20px;
    }
    .overlay_img_piccole {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 120px;
        height: 40px;
        background: rgba(0, 0, 0, 0.5);
        transition: height 0.5s;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    .overlay_img_piccole:hover{
        height:120px;
    }
    .form-check {
        margin: 0 10px;
    }
    
</style>

<div class="panel-heading"><h3><strong>Layout Bacheca Principale</strong></h3></div>

<div class="row">
    <div class="col-md-6 col-sm-12">
        @using (Ajax.BeginForm("SalvaMainSlider", "HomeLayout", new AjaxOptions { HttpMethod = "Post"}))
        {
            @Html.ValidationSummary(true)
            @Html.AntiForgeryToken()
            <div class="panel panelGreen">
                <div class="panel-heading"><h3><strong>Impostazione Bacheca</strong></h3></div>
                <div class="panel-body">
                    <div class="row">
                        @* testo promozionale *@
                        <div class="panel panelGreen">
                            <div class="panel-body">
                                <div class="row">
                                    <div class="col-md-6 col-sm-12 d-flex justify-content-center">
                                        <div class="dx-field-label text-center">Testo Promozionale</div>

                                    </div>

                                    <div class="col-md-6 col-sm-12">
                                        @(Html.DevExtreme()
                                            .TextBox()
                                            .Name("text_s1_p1_ita")
                                            .ID("text_s1_p1_ita")
                                            .OnValueChanged("s1_page.WritePromotionMessage")
                                            .Value(Model.promotion_msg_ita)
                                        )
                                    </div>
                                </div>
                                <br />
                                <div class="row">
                                    <div class="col-md-6 col-sm-12 d-flex justify-content-center">
                                        <div class="dx-field-label" style="overflow:unset">Testo Promozionale Inglese</div>

                                    </div>

                                    <div class="col-md-6 col-sm-12">
                                            @(Html.DevExtreme()
                                             .TextBox()
                                             .Name("text_s1_p1_eng")
                                             .ID("text_s1_p1_eng")
                                             .OnValueChanged("s1_page.WritePromotionMessageEng")
                                             .Value(Model.promotion_msg_eng)
                                         )
                                    </div>
                                </div>

                               
                            </div>

                        </div>

                        @* posizione 1 *@
                        <div class="panel panelGreen">
                            <div class="panel-heading d-flex justify-content-start">
                                <h5><strong>Slider Bacheca</strong></h5>    
                                <button type = "button" class="btn btn-small btn-info" id="clearSlider">Svuota Slider Immagini</button>
                            </div>
                            <div class="panel-body">
                                <div class="col-md-3 col-sm-12">    
                                    <div data-id="s1_p1" data-role="prod">
                                        @(Html.DevExtreme().TagBox()
                                            .DataSource(Model.Prodotti)
                                            .Name("prod_s1_p1")
                                            .InputAttr("aria-label", "Prodotti")
                                            .ID("prod_s1_p1")
                                            .DisplayExpr("Descrizione")
                                            .ValueExpr("id_prodotto")
                                            .Value(Model.main_s_p1_prod_ids)
                                            .ShowSelectionControls(true)
                                            .SearchEnabled(true)
                                            .Placeholder("Seleziona Prodotti")
                                            .ShowClearButton(true)
                                            .OnValueChanged("s1_page.ShowProdSliderPreview")
                                            .OnClosed("s1_page.ShowCusSliderPreview")
                                        )
                                    </div>
                                </div>
                                <div class="col-md-3 col-sm-12">
                                    <div data-id="s1_p1" data-role="cat">
                                        @(Html.DevExtreme().TagBox()
                                            .DataSource(Model.Categorie)
                                            .Name("cat_s1_p1")
                                            .ID("cat_s1_p1")
                                            .DisplayExpr("Descrizione")
                                            .ValueExpr("id_categorie")
                                            .Value(Model.main_s_p1_cat_ids)
                                            .InputAttr("aria-label", "Categorie")
                                            .ShowSelectionControls(true)
                                            .SearchEnabled(true)
                                            .Placeholder("Seleziona Categorie")
                                            .ShowClearButton(true)
                                            .OnValueChanged("s1_page.ShowCatSliderPreview")
                                            .OnClosed("s1_page.ShowCusSliderPreview")
                                        )
                                    </div>
                                </div>
                                <div class="col-md-6 col-sm-12" style="margin-top: -17px;">
                                    <div data-id="s1_p1" data-role="cus">
                                        @(Html.DevExtreme().FileUploader().ID("cus_s1_p1")
                                            .Name("myFile")
                                            .SelectButtonText("Seleziona immagini")
                                            .Multiple(true)
                                            .LabelText("Trascina il file qui")
                                            .InputAttr("aria-label", "Immagini Custom")
                                            .Accept("image/*")
                                            .UploadMode(FileUploadMode.UseButtons)
                                            .OnValueChanged("s1_page.AddCusImgToSlider")
                                            .AllowCanceling(true)
                                        )
                                    </div>
                                </div>
                                </div>
                        </div>
                        @* posizione 2 *@
