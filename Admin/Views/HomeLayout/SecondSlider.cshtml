@model Admin.Models.CustomModels.SliderModel
@{
    ViewBag.Title = "Bacheca Secondaria";
    Layout = "~/Views/Shared/_Layout.cshtml";
    @*@(Model.s_p1.type == "cat" ? Model.s_p1.id_categoria : Model.s_p1.id_prodotto)'*@
var Sdata1 = 0;
var Sdata2 = 0;
var Sdata3 = 0;
var Sdata4 = 0;

if (Model.s_p1.type == "cat")
{
    Sdata1 = (int)Model.s_p1.id_categoria;
}
else if(Model.s_p1.type == "prod")
{
    Sdata1 = (int)Model.s_p1.id_prodotto;

}
else if(Model.s_p1.type == "sottcat")
{
    Sdata1 = (int)Model.s_p1.id_sottocategoria;

}


if (Model.s_p2.type == "cat")
{
    Sdata2 = (int)Model.s_p2.id_categoria;
}
else if (Model.s_p2.type == "prod")
{
    Sdata2 = (int)Model.s_p2.id_prodotto;

}
else if (Model.s_p2.type == "sottcat")
{
    Sdata2 = (int)Model.s_p2.id_sottocategoria;

}


if (Model.s_p3.type == "cat")
{
    Sdata3 = (int)Model.s_p3.id_categoria;
}
else if (Model.s_p3.type == "prod")
{
    Sdata3 = (int)Model.s_p3.id_prodotto;

}
else if (Model.s_p3.type == "sottcat")
{
    Sdata3 = (int)Model.s_p3.id_sottocategoria;

}


if (Model.s_p4.type == "cat")
{
    Sdata4 = (int)Model.s_p4.id_categoria;
}
else if (Model.s_p4.type == "prod")
{
    Sdata4 = (int)Model.s_p4.id_prodotto;

}
else if (Model.s_p4.type == "sottcat")
{
    Sdata4 = (int)Model.s_p4.id_sottocategoria;

}


}

<style>
    section.content {
        margin: 15px 15px 0 315px;
    }

    .d_none {
        display: none;
    }

    .input_row {
        height: 150px;
        padding: 0 5px;
    }

    .radio_row {
        width: 100%;
        display: flex;
    }

    .dx-fileuploader-files-container {
        padding-top: 0 !important;
    }

    .panel-heading {
        padding: 5px 15px !important;
    }

    .image-container {
        padding: 0 3px;
        position: relative;
    }

    .overlay_img_piccole {
        position: absolute;
        bottom: 0;
        left: 4px;
        width: 294px;
        height: 30%;
        background: rgba(0, 0, 0, 0.5);
        transition: height 0.5s;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .overlay_img_piccole:hover {
            height: 294px;
        }

        .overlay_img_piccole p {
            font-size: 3rem;
        }

    #s2_impostazioni {
        padding: 15px;
    }
</style>

<div class="panel-heading"><h3><strong>Layout Bacheca Secondaria</strong></h3></div>

<div class="row">
    <div class="col-md-12" id="s2_impostazioni">
        <div class="panel panelGreen">
            <div class="panel-heading"><h3><strong>Impostazione Bacheca</strong></h3></div>
            <div class="panel-body">
                <div class="row">
                    <div class="col-md-3 col-sm-6">
                        @* tipologia *@
                        <div class="row">
                            <div class="panel panelGreen">
                                <div class="panel-heading"><h5><strong>Box 1</strong></h5></div>
                                <div class="panel-body radio_row" style="display: flex; justify-content: space-evenly;">
                                    <div class="form-check" style=" display: flex; align-items: center;">
                                        <input class="form-check-input" style=" margin: auto;" type="radio" name="s2_p1" id="prodotto_p1" value="prod" @(Model.s_p1.type == "prod" ? "checked" : "" )>
                                        <label class="form-check-label" for="prodotto_p1" style="padding-left: 5px !important; margin-bottom: 0">
                                            Prodotto
                                        </label>
                                    </div>
                                    <div class="form-check" style=" display: flex; align-items: center;">
                                        <input class="form-check-input" style=" margin: auto;" type="radio" name="s2_p1" id="categoria_p1" value="cat" @(Model.s_p1.type == "cat" ? "checked" : "" )>
                                        <label class="form-check-label" for="categoria_p1" style="padding-left: 5px !important; margin-bottom: 0 ">
                                            Categoria
                                        </label>
                                    </div>
                                    <div class="form-check" style=" display: flex; align-items: center;">
                                        <input class="form-check-input" style=" margin: auto;" type="radio" name="s2_p1" id="sottocategoria_p1" value="sottcat" @(Model.s_p1.type == "sottcat" ? "checked" : "" )>
                                        <label class="form-check-label" for="sottocategoria_p1" style="padding-left: 5px !important; margin-bottom: 0 ">
                                            Sottocategoria
                                        </label>
                                    </div>

                                    <div class="form-check" style=" display: flex; align-items: center;">
                                        <input class="form-check-input" style=" margin: auto;" type="radio" name="s2_p1" id="custom_p1" value="cus" @(Model.s_p1.type == "cus" ? "checked" : "" )>
                                        <label class="form-check-label" for="custom_p1" style="padding-left: 5px !important; margin-bottom: 0">
                                            Immagini Custom
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        @* input field 1*@
                        <div class="row input_row">
                            <div data-id="s2_p1" data-role="prod" class="@(Model.s_p1.type == "prod" ? "" : "d_none" )">
                                <div>Prodotti</div>
                                @(Html.DevExtreme().SelectBox()
                                        .DataSource(Model.Prodotti)
                                        .Name("prod_s2_p1")
                                        .ID("prod_s2_p1")
                                        .DisplayExpr("Descrizione")
                                        .ValueExpr("id_prodotto")
                                        .ShowClearButton(true)
                                        .OnValueChanged("s2_page.ShowProdPreview")
                                        .Width(200)
                                        .Value(Model.s_p1.id_prodotto)
                                    )
                            </div>
                            <div data-id="s2_p1" data-role="cat" class="@(Model.s_p1.type == "cat" ? "" : "d_none" )">
                                <div>Categorie</div>
                                @(Html.DevExtreme().SelectBox()
                                        .DataSource(Model.Categorie)
                                        .Name("cat_s2_p1")
                                        .ID("cat_s2_p1")
                                        .DisplayExpr("Descrizione")
                                        .ValueExpr("id_categorie")
                                        .Placeholder("Selezionare Categoria")
                                        .ShowClearButton(true)
                                        .OnValueChanged("s2_page.ShowCatPreview")
                                        .Width(200)
                                        .Value(Model.s_p1.id_categoria)
                                    )
                            </div>
                            <div data-id="s2_p1" data-role="sottcat" class="@(Model.s_p1.type == "sottcat" ? "" : "d_none" )">
                                <div>Sottocategorie</div>
                                @(Html.DevExtreme().SelectBox()
                                        .DataSource(Model.Sottocategorie)
                                        .Name("sottcat_s2_p1")
                                        .ID("sottcat_s2_p1")
                                        .DisplayExpr("Nome")
                                        .ValueExpr("id_sottocategoria")
                                        .Placeholder("Selezionare Sottocategoria")
                                        .ShowClearButton(true)
                                        .OnValueChanged("s2_page.ShowSottCatPreview")
                                        .Width(200)
                                        .Value(Model.s_p1.id_sottocategoria)
                                    )
                            </div>
                            <div data-id="s2_p1" data-role="cus" class="@(Model.s_p1.type == "cus" ? "" : "d_none" )">
                                <div>Immagini Custom</div>
                                @(Html.DevExtreme().FileUploader().ID("cus_s2_p1")
                                        .Name("myFile")
                                        .SelectButtonText("Seleziona un file")
                                        .LabelText("Trascina il file qui")
                                        .Accept("image/*")
                                        .UploadMode(FileUploadMode.UseButtons)
                                        .UploadUrl(Url.Action("UploadImg", "HomeLayout"))
                                        .OnValueChanged("s2_page.ShowCusPreview")

                                    )
                            </div>
                        </div>
                        <div class="row input_row">
                            <div>Sovraimpressione</div>
                            <div data-id="s2_p1" data-role="Description" style="margin-top: 5px;">
                                @(Html.DevExtreme().TextBox().ID("desc_s2_p1_ita")
                                    .Name("Description")
                                    .OnValueChanged("s2_page.ShowDescText")
                                    .Placeholder("Inserisci Sovraimpressione")
                                    .Value(Model.s_p1.Descrizione)
                                    .Width(300)
                                )
                            </div>
                            <div data-id="s2_p1" data-role="Description" style="margin-top: 5px;">
                                @(Html.DevExtreme().TextBox().ID("desc_s2_p1_eng")
                                    .Name("Description")
                                    .OnValueChanged("s2_page.ShowDescTextEng")
                                    .Placeholder("Inserisci Sovraimpressione Inglese")
                                    .Value(Model.s_p1.Descrizione_eng)
                                    .Width(300)
                                )
                            </div>
                        </div>
