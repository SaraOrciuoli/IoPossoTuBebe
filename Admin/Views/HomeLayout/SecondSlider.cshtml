                            </div>
                            <div data-id="s2_p4" data-role="cat" class="@(Model.s_p4.type == "cat" ? "" : "d_none" )">
                                <div>Categorie</div>
                                @(Html.DevExtreme().SelectBox()
                                    .DataSource(Model.Categorie)
                                    .Name("cat_s2_p4")
                                    .ID("cat_s2_p4")
                                    .DisplayExpr("Descrizione")
                                    .ValueExpr("id_categorie")
                                    .Placeholder("Selezionare Categoria")
                                    .ShowClearButton(true)
                                    .OnValueChanged("s2_page.ShowCatPreview")
                                    .Width(200)
                                    .Value(Model.s_p4.id_categoria)
                                )
                            </div>
                            <div data-id="s2_p4" data-role="sottcat" class="@(Model.s_p4.type == "sottcat" ? "" : "d_none" )">
                                <div>Sottcategorie</div>
                                @(Html.DevExtreme().SelectBox()
                                    .DataSource(Model.Sottocategorie)
                                    .Name("sottcat_s2_p4")
                                    .ID("sottcat_s2_p4")
                                    .DisplayExpr("Nome")
                                    .ValueExpr("id_sottocategoria")
                                    .Placeholder("Selezionare Sottcategoria")
                                    .ShowClearButton(true)
                                    .OnValueChanged("s2_page.ShowSottCatPreview")
                                    .Width(200)
                                    .Value(Model.s_p4.id_sottocategoria)
                                )
                            </div>
                            <div data-id="s2_p4" data-role="cus" class="@(Model.s_p4.type == "cus" ? "" : "d_none" )">
                                <div>Immagini Custom</div>
                                @(Html.DevExtreme().FileUploader().ID("cus_s2_p4")
                                    .Name("myFile")
                                    .SelectButtonText("Seleziona un file")
                                    .LabelText("Trascina il file qui")
                                    .Accept("image/*")
                                    .UploadMode(FileUploadMode.UseButtons)
                                    .UploadUrl(Url.Action("UploadImg", "HomeLayout"))
                                    .OnValueChanged("s2_page.ShowCusPreview")

                                )
                            </div>
                        </div>
                        <div class="row input_row">
                            <div>Sovraimpressione</div>
                            <div data-id="s2_p1" data-role="Description" style="margin-top: 5px;">
                                @(Html.DevExtreme().TextBox().ID("desc_s2_p4_ita")
                                    .Name("Description")
                                    .OnValueChanged("s2_page.ShowDescText")
                                    .Placeholder("Inserisci Sovraimpressione")
                                    .Value(Model.s_p4.Descrizione)
                                    .Width(300)
                                )
                            </div>
                            <div data-id="s2_p1" data-role="Description" style="margin-top: 5px;">
                                @(Html.DevExtreme().TextBox().ID("desc_s2_p4_eng")
                                    .Name("Description")
                                    .OnValueChanged("s2_page.ShowDescTextEng")
                                    .Placeholder("Inserisci Sovraimpressione Inglese")
                                    .Value(Model.s_p4.Descrizione_eng)
                                    .Width(300)
                                )
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
    <div class="col-md-12">
        <div class="panel panelGreen">
            <div class="panel-heading"><h3><strong>Anteprima</strong></h3></div>
            <div class="panel-body">
                <div class="row row-abiti" style="display: flex; justify-content: center; align-items: center; padding-top: 30px;">
                    <div class="image-container">
                        <img class="img-responsive" id="s2_p1_show" src="@Model.s_p1.path_img_slider" data-source="@Model.s_p1.type" data-id='@Sdata1' style="width:294px; height:294px; object-fit:cover;" />
                        <div class="overlay_img_piccole">
                            <p class="text-warning" data-id="s2_p1_desc_show">@Model.s_p1.Descrizione</p>
                        </div>
                    </div>
                    <br />
                    <div class="image-container">
                        <img class="img-responsive" id="s2_p2_show" src="@Model.s_p2.path_img_slider" data-source="@Model.s_p2.type" data-id='@Sdata2' style="width:294px; height:294px; object-fit:cover;" />
                        <div class="overlay_img_piccole">
                            <p class="text-warning" data-id="s2_p2_desc_show">@Model.s_p2.Descrizione</p>
                        </div>
                    </div>
                    <br />
                    <div class="image-container">
                        <img class="img-responsive" id="s2_p3_show" src="@Model.s_p3.path_img_slider" data-source="@Model.s_p3.type" data-id='@Sdata3' style="width:294px; height:294px; object-fit:cover;" />
                        <div class="overlay_img_piccole">
                            <p class="text-warning" data-id="s2_p3_desc_show">@Model.s_p3.Descrizione</p>
                        </div>
                    </div>
                    <br />
                    <div class="image-container">
                        <img class="img-responsive" id="s2_p4_show" src="@Model.s_p4.path_img_slider" data-source="@Model.s_p4.type" data-id='@Sdata4' style="width:294px; height:294px;" />
                        <div class="overlay_img_piccole">
                            <p class="text-warning" data-id="s2_p4_desc_show">@Model.s_p4.Descrizione</p>
                        </div>
                    </div>
                </div>
                <div class="row d-flex justify-content-center">
                    <button type="button" class="btn btn-primary" id="p2Save">Salva Configurazione</button>
                </div>
            </div>
        </div>
    </div>
</div>



<script>
    $(document).ready(function () {
        s2_page.init();
    });

    let s2_page = {
        init: function () {
            $("input[type='radio']").off('click').on('click', function () {
                let row = $(this).attr("name");
                let target = $(this).val();

                $("div[data-id='" + row + "']").each(function () {
                    if ($(this).attr("data-role") == target || $(this).attr("data-role") == "Description") {
                        if ($(this).hasClass("d_none")) $(this).removeClass("d_none");
                    } else {
                        if (!$(this).hasClass("d_none")) $(this).addClass("d_none");
                        if (target != "cus") {
                            $("#" + target + "_" + row).dxSelectBox("instance").reset();
                        } else {
                            $("#" + target + "_" + row).dxFileUploader("instance").reset();
                        }
                    }
                })
            })

            $("#p2Save").off("click").on("click", function () {
                let message = "Attenzione! Mancano immagini a: ";
                let validation = true;
                if ($("#s2_p1_show").attr("src") == "" || typeof $("#s2_p1_show").attr("src") == 'undefined') {
                    message += " Box1 ";
                    validation = false;
                }
                if ($("#s2_p2_show").attr("src") == "" || typeof $("#s2_p2_show").attr("src") == 'undefined') {
                    message += " Box2 ";
                    validation = false;
                }
                if ($("#s2_p3_show").attr("src") == "" || typeof $("#s2_p3_show").attr("src") == 'undefined') {
                    message += " Box3 ";
                    validation = false;
                }
                if ($("#s2_p4_show").attr("src") == "" || typeof $("#s2_p4_show").attr("src") == 'undefined') {
                    message += " Box4 ";
                    validation = false;
                }

                if (!validation) {
                    alert(message);
                } else {
                    let values = s2_page.getPostDataSlider();
                    $.ajax({
                        url: "SalvaSecondSlider",
                        type: "POST",
                        data: {
                            values: values
                        },
                        success: function (res) {
                            if (res == "OK") {
                                let next = confirm("Bacheca principale salvata correttamente!")
                                if (next) {
                                    window.location.reload();
                                } else {
                                    window.location.reload();
                                }
                            }
                        },
                        error: function (e) {
                            console.log(e);
                        }
                    })
                }

            });
        },
        ShowProdPreview: function (e) {
            $(".dx-fileuploader-button.dx-fileuploader-upload-button").each(function () {
                $(this).addClass("d_none");
            })
            let id = e.element[0].id.slice(5);
            if (e.value == "" || typeof e.value == undefined) {
                if ($("#" + id + "_num").hasClass("d_none")) {
                    $("#" + id + "_num").removeClass("d_none");
                }
            }
            $.ajax({
                url: "GetImmagineByProdId",
                type: "POST",
                data: {
                    id: e.value,
                    position: "2006",
                },
                success: function (res) {
                    if (!$("#" + id + "_num").hasClass("d_none")) {
                        $("#" + id + "_num").addClass("d_none");
                    }
                    $("#" + id + "_show").attr("src", res);
                    $("#" + id + "_show").attr("data-source", "prod");
                    $("#" + id + "_show").attr("data-id", e.value);
                },
                error: function (e) {
                    console.log(e);
                }
            })
        },
        ShowCatPreview: function (e) {
            $(".dx-fileuploader-button.dx-fileuploader-upload-button").each(function () {
                $(this).addClass("d_none");
            })
            let id = e.element[0].id.slice(4);
            if (e.value == "" || typeof e.value == undefined) {
                if ($("#" + id + "_num").hasClass("d_none")) {
                    $("#" + id + "_num").removeClass("d_none");
                }
            }

            $.ajax({
                url: "GetImmagineByCatId",
                type: "POST",
                data: {
                    id: e.value,
                    position: "2006",

                },
                success: function (res) {
                    if (!$("#" + id + "_num").hasClass("d_none")) {
                        $("#" + id + "_num").addClass("d_none");
                    }
                    $("#" + id + "_show").attr("src", res);
                    $("#" + id + "_show").attr("data-source", "cat");
                    $("#" + id + "_show").attr("data-id", e.value);
                },
                error: function (e) {
                    console.log(e);
                }
            });
        },
        ShowSottCatPreview: function (e) {
            $(".dx-fileuploader-button.dx-fileuploader-upload-button").each(function () {
                $(this).addClass("d_none");
            })
            let di = e.element[0].id.split("_");
            let id = di[1] + "_" + di[2];

            console.log(e)
            if (e.value == "" || typeof e.value == undefined) {
                if ($("#" + id + "_num").hasClass("d_none")) {
                    $("#" + id + "_num").removeClass("d_none");
                }
            }

            $.ajax({
                url: "GetImmagineBySottCatId",
                type: "POST",
                data: {
                    id: e.value,
                    position: "2006",

                },
                success: function (res) {
                    console.log(res)
                    console.log(id)
                    if (!$("#" + id + "_num").hasClass("d_none")) {
                        $("#" + id + "_num").addClass("d_none");
                    }
                    $("#" + id + "_show").attr("src", res);
                    $("#" + id + "_show").attr("data-source", "sottcat");
                    $("#" + id + "_show").attr("data-id", e.value);
                },
                error: function (e) {
                    console.log(e);
                }
            });
        },
        ShowCusPreview: function (e) {
            if (e.value.length != 0) {
                $(".dx-fileuploader-button.dx-fileuploader-upload-button").each(function () {
                    $(this).addClass("d_none");
                })
                let id = e.element[0].id.slice(4);
                if (!$("#" + id + "_num").hasClass("d_none")) {
                    $("#" + id + "_num").addClass("d_none");
                }
                let file = e.value[0];
                let img = new Image();
                img.src = window.URL.createObjectURL(file);
                img.onload = function () {
                    let width = img.naturalWidth;
                    let height = img.naturalHeight;

                    window.URL.revokeObjectURL(img.src);

                    if (width == 271 && height == 328) {
                        let formData = new FormData();
                        formData.append("myFile", e.value[0]);
                        $.ajax({
                            url: "UploadImg",
                            type: "POST",
                            data: formData,
                            processData: false,
                            contentType: false,
                            success: function (res) {
                                $("#" + id + "_show").attr("src", res);
                                $("#" + id + "_show").attr("data-source", "cus");
                            }
                        })
                    }
                    else {
                        alert("Dimensioni non valide: l'immagine deve essere 271x328px. Purtroppo quella fornita è di: " + width + "x" + height);
                    }
                };
            }
        },
        ShowDescText: function (e) {
            let text = e.value;
            let id = e.element[0].id.slice(5);

            $("p[data-id='" + id + "_desc_show']").html(text);
        },
        ShowDescTextEng: function (e) {
            let text = e.value;
            let id = e.element[0].id.slice(5);
            if ($("p[data-id='" + id + "_desc_show']").html() == "") {
                $("p[data-id='" + id + "_desc_show']").html(text);
            }
        },
        getPostDataSlider: function () {

            desc_s2_p4_eng

            let data = {
                s2_p1: {
                    img: $("#s2_p1_show").attr("src"),
                    source: $("#s2_p1_show").attr("data-source"),
                    id: $("#s2_p1_show").attr("data-id") != undefined ? $("#s2_p1_show").attr("data-id") : 0,
                    desc: $("#desc_s2_p1_ita").dxTextBox("instance").option("value") != "" ? $("#desc_s2_p1_ita").dxTextBox("instance").option("value") : "Acquista Ora",
                    desc_eng: $("#desc_s2_p1_eng").dxTextBox("instance").option("value") != "" ? $("#desc_s2_p1_eng").dxTextBox("instance").option("value") : "Buy Now",
                },
                s2_p2: {
                    img: $("#s2_p2_show").attr("src"),
                    source: $("#s2_p2_show").attr("data-source"),
                    id: $("#s2_p2_show").attr("data-id") != undefined ? $("#s2_p2_show").attr("data-id") : 0,
                    desc: $("#desc_s2_p2_ita").dxTextBox("instance").option("value") != "" ? $("#desc_s2_p2_ita").dxTextBox("instance").option("value") : "Acquista Ora",
                    desc_eng: $("#desc_s2_p2_eng").dxTextBox("instance").option("value") != "" ? $("#desc_s2_p2_eng").dxTextBox("instance").option("value") : "Buy Now",
                },
                s2_p3: {
                    img: $("#s2_p3_show").attr("src"),
                    source: $("#s2_p3_show").attr("data-source"),
                    id: $("#s2_p3_show").attr("data-id") != undefined ? $("#s2_p3_show").attr("data-id") : 0,
                    desc: $("#desc_s2_p3_ita").dxTextBox("instance").option("value") != "" ? $("#desc_s2_p3_ita").dxTextBox("instance").option("value") : "Acquista Ora",
                    desc_eng: $("#desc_s2_p3_eng").dxTextBox("instance").option("value") != "" ? $("#desc_s2_p3_eng").dxTextBox("instance").option("value") : "Buy Now",
                },
                s2_p4: {
                    img: $("#s2_p4_show").attr("src"),
                    source: $("#s2_p4_show").attr("data-source"),
                    id: $("#s2_p4_show").attr("data-id") != undefined ? $("#s2_p4_show").attr("data-id") : 0,
                    desc: $("#desc_s2_p4_ita").dxTextBox("instance").option("value") != "" ? $("#desc_s2_p4_ita").dxTextBox("instance").option("value") : "Acquista Ora",
                    desc_eng: $("#desc_s2_p4_eng").dxTextBox("instance").option("value") != "" ? $("#desc_s2_p4_eng").dxTextBox("instance").option("value") : "Buy Now",
                },
            };
            return JSON.stringify(data);
        }

    }
</script>
