@model Admin.Models.CustomModels.ModelTipiImmagini
@{
    ViewBag.Title = "Gestione Tipi Immagini";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* =========================================
       STILI GESTIONALE MODERNO
       ========================================= */
    body {
        background-color: #f4f6f9;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .admin-header {
        margin-top: 20px;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px solid #eaeaea;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .admin-header h3 {
            margin: 0;
            font-weight: 700;
            color: #2c3e50;
            font-size: 2.5rem;
        }

    .admin-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.04);
        border: 1px solid rgba(0,0,0,0.02);
        margin-bottom: 30px;
    }

    /* =========================================
       STILIZZAZIONE DATAGRID DEVEXTREME
       ========================================= */
    .dx-datagrid {
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #eef2f5 !important;
    }

        .dx-datagrid .dx-header-row {
            background: linear-gradient(135deg, #4d7cc4, #2c3e50);
            color: white !important;
            font-weight: 600;
        }

            .dx-datagrid .dx-header-row .dx-datagrid-text-content {
                color: white !important;
            }

        .dx-datagrid .dx-row {
            transition: background-color 0.2s ease;
        }

            .dx-datagrid .dx-row:hover {
                background-color: #f8fafc !important;
            }

        /* Stile Bottoni Azione */
        .dx-datagrid .dx-command-edit .dx-link {
            color: #4d7cc4;
            transition: color 0.3s;
            margin: 0 5px;
        }

            .dx-datagrid .dx-command-edit .dx-link:hover {
                color: #2c3e50;
            }

        .dx-datagrid .ddx-command-trash .dx-link,
        .dx-datagrid .dx-link-delete {
            color: #e74c3c;
        }

            .dx-datagrid .ddx-command-trash .dx-link:hover,
            .dx-datagrid .dx-link-delete:hover {
                color: #c0392b;
            }

    /* Stile Form Popup */
    .dx-popup-title {
        background: linear-gradient(135deg, #4d7cc4, #2c3e50) !important;
        color: white !important;
        border-bottom: none !important;
    }

        .dx-popup-title .dx-closebutton .dx-icon {
            color: white !important;
        }

    .modern-group-caption {
        font-size: 1.1rem !important;
        font-weight: 600 !important;
        color: #2c3e50 !important;
        border-bottom: 2px solid #f0f0f0 !important;
        padding-bottom: 10px !important;
        margin-bottom: 15px !important;
    }
</style>

<div class="admin-header mt-4">
    <i class="fas fa-image" style="font-size: 1.8rem; color: #4d7cc4;"></i>
    <h3>Gestione Tipi Immagini</h3>
</div>

<div class="admin-card">
    @(Html.DevExtreme().DataGrid<DAL.Model.Tipi_Immagini>()
        .ID("gridTypeImg")
        .DataSource(ds => ds
            .Mvc()
            .Controller("TipiImmagini")
            .Key("id_tipo_immagine")
            .LoadAction("GetTipiImmagini")
            .InsertAction("AddTipiImmagini")
            .UpdateAction("UpdateTipiImmagini")
            .DeleteAction("DeleteTipiImmagini").DeleteMethod("POST")
        )
        .ShowBorders(false) // Bordo gestito dalla Card genitore
        .ShowRowLines(true)
        .RowAlternationEnabled(true)
        .Editing(editing =>
        {
            editing.Mode(GridEditMode.Popup);
            if (Request.Cookies["userRetailCassa"]["IdRuolo"] != "2001")
            {
                editing.AllowUpdating(true);
                editing.AllowDeleting(new JS("allowDeleting"));
            }

            editing.AllowAdding(true);
            editing.UseIcons(true);

            editing.Popup(p => p
                .Title("Dettaglio Tipo Immagine")
                .ShowTitle(true)
                .Width(600)
                .Height("auto")
            );

            editing.Form(f => f
                .ShowValidationSummary(true)
                .ColCount(1) 
                .Items(items =>
                {
                    items.AddGroup()
                        .Caption("Informazioni Base")
                        .CssClass("modern-group-caption")
                        .Items(first_group =>
                        {
                            first_group.AddSimpleFor(m => m.Descrizione_tipo_Immagine)
                                .Label(m => m.Text("Descrizione (Es. Copertina Prodotto)"))
                                .Editor(e => e.TextBox().StylingMode(EditorStylingMode.Outlined));

                            first_group.AddGroup().ColCount(2).Items(switches => {
                                switches.AddSimpleFor(m => m.Categoria).Label(m => m.Text("Usa per Categorie")).Editor(e => e.Switch().ID("Categoria"));
                                switches.AddSimpleFor(m => m.Prodotto).Label(m => m.Text("Usa per Prodotti")).Editor(e => e.Switch().ID("Prodotto"));
                            });
                        });

                    items.AddGroup()
                        .Caption("Risoluzione (Pixel)")
                        .CssClass("modern-group-caption")
                        .ColCount(1)
                        .Items(second_group =>
                        {
                            second_group.AddSimpleFor(m => m.Width).Label(l => l.Text("Larghezza")).Editor(e => e.NumberBox().ID("width").StylingMode(EditorStylingMode.Outlined));
                            second_group.AddSimpleFor(m => m.Height).Label(l => l.Text("Altezza")).Editor(e => e.NumberBox().ID("height").StylingMode(EditorStylingMode.Outlined));
                        });
                })
            );
        })
        .Columns(columns => {
            columns.Add()
                .Type(GridCommandColumnType.Buttons)
                .Width(100)
                .Alignment(HorizontalAlignment.Center)
                .Buttons(b =>
                {
                    b.Add().Name(GridColumnButtonName.Edit).Hint("Modifica");
                    b.Add().Name(GridColumnButtonName.Delete).Hint("Elimina");
                });

            columns.AddFor(m => m.id_tipo_immagine).Caption("Id").Visible(false);

            columns.AddFor(m => m.Descrizione_tipo_Immagine).Caption("Descrizione Tipo Immagine").Width("auto");

            // Allineamento centrato per i campi booleani e numerici rende la tabella più ordinata
            columns.AddFor(m => m.Categoria).Caption("Uso Categoria").Width(150).Alignment(HorizontalAlignment.Center);
            columns.AddFor(m => m.Prodotto).Caption("Uso Prodotto").Width(150).Alignment(HorizontalAlignment.Center);
            columns.AddFor(m => m.Width).Caption("Larghezza (px)").Width(150).Alignment(HorizontalAlignment.Center);
            columns.AddFor(m => m.Height).Caption("Altezza (px)").Width(150).Alignment(HorizontalAlignment.Center);
        })
        .Paging(p => p.PageSize(20))
        .Pager(p => p.ShowPageSizeSelector(true).AllowedPageSizes(new[] { 10, 20, 50 }))
        .FilterRow(f => f.Visible(true))
        .HeaderFilter(f => f.Visible(true))
        .SearchPanel(s => s.Visible(true).Placeholder("Cerca tipo immagine...").Width(300))
        .GroupPanel(p => p.Visible(false)) // Nascosto per pulizia visiva
        .Grouping(g => g.AutoExpandAll(false))
        .RemoteOperations(true)
        .Width("100%") // Responsive design
    )
</div>

<script>
 

    function isChief(position) {
        return position && ["CEO", "CMO"].indexOf(position.trim().toUpperCase()) >= 0;
    };

    function allowDeleting(e) {
        if (!e.row.data.Position) return true;
        return !isChief(e.row.data.Position);
    }

    function isCloneIconVisible(e) {
        if (!e.row.data.Position) return true;
        return !e.row.isEditing && !isChief(e.row.data.Position);
    }

    function onCloneIconClick(e) {
        var clonedItem = $.extend({}, e.row.data, { ID: ++maxID });

        employees.splice(e.row.rowIndex, 0, clonedItem);
        e.component.refresh(true);
        e.event.preventDefault();
    }

    function onRowValidating(e) {
        var position = e.newData.Position;

        if (isChief(position)) {
            e.errorText = "The company can have only one " + position.toUpperCase() + ". Please choose another position.";
            e.isValid = false;
        }
    }

    function onEditorPreparing(e) {
        if (e.parentType === "dataRow" && e.dataField === "Position") {
            e.editorOptions.readOnly = isChief(e.value);
        }
    }

    function fileUploader_valueChanged(e) {
        // Logica per uploader se necessario
    }

    function fileUploaded(e) {
       // $("#gridCat").dxDataGrid("instance").refresh();
    }
</script>