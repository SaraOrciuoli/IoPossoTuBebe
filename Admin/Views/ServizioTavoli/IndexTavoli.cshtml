@model Admin.Models.CustomModels.ModelTavoloOrdini

@{
    ViewBag.Title = "Lista Tavoli";
    Layout = "~/Views/Shared/_LayoutServizioTavoli.cshtml";
}

<div class="container text-center">
    <h2 style="margin-top: 50px"><strong>Tavoli</strong></h2>
    <br />
    <div class="row">
        @*        @foreach (var tavolo in Model.ListaGestioneTavolo.OrderBy(n => Convert.ToInt32(n.numero)))
        {
            string colore = tavolo.stato == 2 ? "colorRed" : "colorGreen";

            if (tavolo.preconto_stampato == true)
            {
                colore = "colorYellow";
            }

            <div class="col-md-2 col-sm-3 col-xs-4">
                <div onclick="location.href='@Url.Action("Tavoli", "ServizioTavoli", new { id = tavolo.id_tavolo })'">
                    <div class="panel @colore" id="panelTavoli">
                        <div class="panel-body panel-select text-center">
                            <h2>@tavolo.numero</h2>
                        </div>
                    </div>
                </div>
            </div>
        }*@

        @foreach (var tavolo in Model.ListaGestioneTavolo.OrderBy(n => Convert.ToInt32(n.numero)))
        {
            string border = tavolo.stato == 2 ? "borderRed" : "borderGreen";

            if (tavolo.preconto_stampato == true)
            {
                border = "borderYellow";
            }
            string data = tavolo.id_gestione.ToString() + ',' + tavolo.id_tavolo.ToString() + ',' + tavolo.numero;
            string persone = !string.IsNullOrEmpty(tavolo.numero_persone.ToString()) ? tavolo.numero_persone.ToString() : "0";

            string tot = tavolo.totale != null ? string.Format("{0:#.00}", tavolo.totale) : "0,00";

            <div class="col-md-2 col-sm-3 col-xs-6">
                <div onclick="location.href='@Url.Action("Tavoli", "ServizioTavoli", new { id = tavolo.id_tavolo })'">
                    <div class="tableDiv @border" id="panelTavoli_@tavolo.id_tavolo">
                        <div class="row text-right" style="color: #333 !important">
                            <div class="col-xs-6 text-left">
                                <p class="numTable"><b>@tavolo.numero</b></p>
                            </div>
                            <div class="col-xs-6 text-center">
                                <img src="~/Content/Img/omini.png" alt="omini" width="30" />
                                <p style="color: #ee7a1c !important; font-weight: bold"><span>@persone</span> pax</p>
                            </div>
                        </div>
                        <div class="row" style="color: #333 !important">
                            <div class="col-xs-6 text-left">
                                <small><b>TIME</b></small>
                            </div>
                            <div class="col-xs-6 text-center">
                                <small id="timer_@tavolo.id_tavolo">@tavolo.TempoTrascorso</small>
                            </div>
                            <div class="col-xs-6 text-left">
                                <small><b>COSTO</b></small>
                            </div>
                            <div class="col-xs-6 text-center">
                                <small style="color: red !important">€ @tot</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
@*    <div class="text-center">
        <button class="btn btn-warning" onclick="chiudiPOS()"><strong>Chiusura Giornaliera</strong></button>
    </div>*@
</div>

@if (ViewBag.Message != null)
{
    <script>
        alert("@ViewBag.Message");
    </script>
}

