@*<script>
function startTimerForTable(dataPrenotazione, tavoloId) {

    let prenotazione = dataPrenotazione;

    let day = parseInt(prenotazione.slice(0, 2), 10);
    let month = parseInt(prenotazione.slice(3, 5), 10);
    let year = parseInt(prenotazione.slice(6, 10), 10);
    let hour = parseInt(prenotazione.slice(11, 13), 10);
    let minute = parseInt(prenotazione.slice(14, 16), 10);
    let second = parseInt(prenotazione.slice(17, 19), 10);

    let startDate = new Date(Date.UTC(year, (month - 1), day, hour, minute, second, 0));

