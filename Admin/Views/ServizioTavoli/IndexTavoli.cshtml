    // Aggiorna il timer ogni secondo
    setInterval(updateTimer, 1000);

    // Chiamata iniziale per aggiornare subito il timer
    updateTimer();
}

@foreach (var tavolo in Model.ListaGestioneTavolo.OrderBy(n => Convert.ToInt32(n.numero)))
{
    if (tavolo.data_prenotazione != null)
