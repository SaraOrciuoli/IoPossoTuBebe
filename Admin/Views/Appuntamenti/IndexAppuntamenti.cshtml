@using DevExpress.Web.Mvc.UI
@using DevExtreme.AspNet.Mvc
@model DAL.Model.GestioneAppuntamenti

@{
    ViewBag.Title = "Gestione Appuntamenti";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    section.content {
        margin: 15px 15px 0 315px;
    }
    /* Stile personalizzato per evidenziare l'orario nella griglia */
    .time-badge {
        background-color: #e8f5e9;
        color: #2e7d32;
        padding: 4px 8px;
        border-radius: 4px;
        font-weight: bold;
    }
</style>

<div class="panel panelGreen containerManu">
    <div class="panel-heading"><h2><strong>Agenda Appuntamenti</strong></h2></div>
    <div class="panel-body">
        <div class="row">
            <div class="col-lg-12" id="AppuntamentiGrid">
                @(Html.DevExtreme().DataGrid<DAL.Model.GestioneAppuntamenti>()
                .DataSource(ds => ds
                    .Mvc()
                    .Controller("Appuntamenti") // Nome del controller senza 'Controller'
                    .Key("id_appuntamento")
                    .LoadAction("GetAppuntamenti")
                    .InsertAction("AddAppuntamenti").InsertMethod("POST")
                    .UpdateAction("UpdateAppuntamenti").UpdateMethod("POST")
                    .DeleteAction("DeleteAppuntamenti").DeleteMethod("POST")
                )
                .ShowBorders(true)
                .Paging(p => p.PageSize(10))
                .FilterRow(f => f.Visible(true))
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(s => s.Visible(true).Placeholder("Cerca cliente..."))
                .Editing(editing =>
                {
                    editing.Mode(GridEditMode.Popup);
                    editing.AllowAdding(true);
                    editing.AllowUpdating(true); // Attiva se hai implementato l'Update
                    editing.AllowDeleting(true); // Attiva se hai implementato il Delete
                    editing.UseIcons(true);

                    // Configurazione Popup
                    editing.Popup(p => p
                        .Title("Nuovo Appuntamento")
                        .ShowTitle(true)
                        .Width(800)
                        .Height(600)
                        .Position(pos => pos.My(HorizontalAlignment.Center, VerticalAlignment.Center)
                                            .At(HorizontalAlignment.Center, VerticalAlignment.Center)
                                            .Of(new JS("window")))
                    );

                    // --- CONFIGURAZIONE FORM ---
                    editing.Form(f => f
                        .ColCount(1) // Una colonna è più pulita per questi dati
                        .Items(items =>
                        {
                            items.AddGroup()
                                .Caption("Dati Cliente")
                                .Items(groupItems =>
                                {
                                    groupItems.AddSimpleFor(m => m.id_appuntamento).Visible(false);

                                    groupItems.AddSimpleFor(m => m.cliente)
                                        .Label(l => l.Text("Nome Cliente"))
                                        .Editor(e => e.TextBox().Placeholder("Es. Mario Rossi"))
                                        .IsRequired(true);

                                    groupItems.AddSimpleFor(m => m.numero_telefono)
                                        .Label(l => l.Text("Telefono (39...)"))
                                        .Editor(e => e.NumberBox().Format("#").Placeholder("Es. 393331234567"))
                                        .IsRequired(true);
                                });

                            items.AddGroup()
                                .Caption("Dettagli Appuntamento")
                                .ColCount(2) // Data e Ora affiancati
                                .Items(groupItems =>
                                {
                                    groupItems.AddSimpleFor(m => m.data_appuntamento)
                                        .Label(l => l.Text("Data"))
                                        .Editor(e => e.DateBox()
                                            .Type(DateBoxType.Date)
                                            .DisplayFormat("dd/MM/yyyy")
                                        )
                                        .IsRequired(true);

                                    groupItems.AddSimpleFor(m => m.ora_appuntamento)
                                        .Label(l => l.Text("Ora"))
                                        .Editor(e => e.DateBox()
                                            .Type(DateBoxType.Time)
                                            .DisplayFormat("HH:mm")
                                        )
                                        .IsRequired(true);
                                });

                            // Nota informativa per l'utente
                            items.AddSimple()
                                 .Label(l => l.Visible(false))
                                 .Template(@<text>
                                     <div style="color: #666; font-size: 12px; margin-top: 10px; padding: 10px; background: #f0f0f0; border-radius: 4px;">
                                         <i class="dx-icon-info"></i> Al salvataggio verrà inviato automaticamente un messaggio WhatsApp al cliente.
                                     </div>
                                 </text>);
                        })
                    );
                })
                .Columns(columns => {
                    // Bottoni Azione
                    columns.Add()
                        .Type(GridCommandColumnType.Buttons)
                        .Width(80)
                        .Buttons(b =>
                        {
                            b.Add().Name(GridColumnButtonName.Edit);
                            b.Add().Name(GridColumnButtonName.Delete);
                        });

                    columns.AddFor(m => m.id_appuntamento).Visible(false);

                    columns.AddFor(m => m.cliente)
                        .Caption("Cliente")
                        .SortOrder(SortOrder.Asc);

                    columns.AddFor(m => m.numero_telefono)
                        .Caption("Telefono")
                        .Width(150);

                    columns.AddFor(m => m.data_appuntamento)
                        .Caption("Data")
                        .DataType(GridColumnDataType.Date)
                        .Format("dd/MM/yyyy")
                        .Width(120);

                    columns.AddFor(m => m.ora_appuntamento)
                        .Caption("Ora")
                        .DataType(GridColumnDataType.DateTime)
                        .Format("HH:mm")
                        .Width(100)
                        .CellTemplate(@<text>
                            <span class="time-badge"><%- text %></span>
                        </text>);
                })
                )
            </div>
        </div>
    </div>
</div>