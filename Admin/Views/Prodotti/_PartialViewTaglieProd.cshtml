@model Admin.Models.CustomModels.ModelEditProdotto
<style>
    .d_none{
        display: none;
    }
   
</style>

<div>
    @Html.HiddenFor(model => model.Prodotto.id_prodotto)
    @Html.Hidden("product_hidden", HttpContext.Current.Session["Product"].ToString())
    @Html.DevExtreme().TextBox().ID("interazioneUtente").Value("true").Visible(false)
    @Html.DevExtreme().TextBox().ID("taglieSalvate").Value("false").Visible(false)
    <div class="row" style="padding: 0 15px;">
        @(Html.DevExtreme().NumberBox().ID("id_prodotto").Value(Model.Prodotto != null ? Model.Prodotto.id_prodotto : 0).Visible(false))
        <div class="col-md-3 col-sm-5">
            @(Html.DevExtreme().SelectBox().DataSource(Model.GruppiTaglia).Name("gruppo_taglia")
            .ID("prod_gruppo_taglia")
            .DisplayExpr("Descrizione")
            .ValueExpr("id_gruppoTaglia")
            .Placeholder("Selezionare Gruppo Taglia")
            .ShowClearButton(true)
            .OnValueChanged("taglie_page.checkUserInputGruppiTaglia")
            .Width(300)
            .Value(Model.Prodotto != null ? Model.Prodotto.id_gruppo_taglie : 0)

        )
        </div>

        <div class="col-md-3 col-sm-5">
            @(Html.DevExtreme().SelectBox().DataSource(Model.GruppiColori).Name("gruppo_colori")
            .ID("prod_gruppo_colori")
            .DisplayExpr("descrizione")
            .ValueExpr("id_gruppoColore")
            .Placeholder("Selezionare Gruppo Colore")
            .ShowClearButton(true)
            //.OnValueChanged("taglie_page.checkUserInputGruppiTaglia")
            .Width(300)
            .Value(Model.Prodotto != null ? Model.Prodotto.id_gruppo_colori : 0)

        )
        </div>
      

        <div class="col-md-3 col-sm-5">
            @(Html.DevExtreme().SelectBox().DataSource(Model.GruppiSpessori).Name("gruppo_spessori")
            .ID("prod_gruppo_spessori")
            .DisplayExpr("descrizione_gruppoSpessori")
            .ValueExpr("id_gruppoSpessore")
            .Placeholder("Selezionare Gruppo Spessore")
            .ShowClearButton(true)
            //.OnValueChanged("taglie_page.checkUserInputGruppiTaglia")
            .Width(300)
            .Value(Model.Prodotto != null ? Model.Prodotto.id_gruppo_colori : 0)

        )
        </div>

        <div class="col-md-4 col-sm-1"></div>
        <div class="col-md-3 col-sm-2">
            @*<span style="display:inline-block;">Taglia Unica</span>
            @(Html.DevExtreme().Switch().OnValueChanged("taglie_page.checkUserInputTagliaUnica").ID("taglia_unica_switch").Value(Model.Prodotto.id_gruppo_taglie == 7))*@
        </div>
    </div>
