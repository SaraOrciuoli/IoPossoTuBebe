@*-------------------Modale Aggiungi Prodotti Magazzino----------------------*@
<div class="modal fade modal-xl" id="modal_prodottiMagazzino" tabindex="-1">
    <div class="">
        <div class="modal-content">
            <div class="modal-header text-center">
                <button style="border-radius:4px;" type="button" class="close" data-dismiss="modal">&times;</button>
                <h2 class="modal-title">Carico/Scarico magazzino</h2>
            </div>
            <div class="modal-body">
                <div style="padding: 0 2vw;">
                    <div class="row">
                        @using (Html.BeginForm("SalvaMovimento", "Prodotti", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()

                            @(Html.DevExtreme().Form<DAL.Model.MovimentiMagazzino>()
                            .LabelLocation(FormLabelLocation.Top)
                            .ColCount(3)
                            .Items(items =>
                            {
                                items.AddSimpleFor(m => m.Id_prodotto).Label(l => l.Text("Prodotto"))
                                        .IsRequired(true)
                                        .Editor(e => e
                                            .SelectBox()
                                            .DataSource(d => d.Mvc().Controller("Prodotti").LoadAction("GetProdotti").Key("id_prodotto"))
                                            .ID("cmbProd")
                                            .DisplayExpr("Descrizione")
                                            .ValueExpr("id_prodotto")
                                            .SearchEnabled(true)
                                            .Placeholder("Seleziona Prodotto"));
                                items.AddSimpleFor(m => m.Id_tipoMovimento).Label(l => l.Text("Movimento"))
                                        .IsRequired(true)
                                        .Editor(e => e
                                            .SelectBox()
                                            .DataSource(d => d.Mvc().Controller("Configurazioni").LoadAction("GetTipiMovimentoMagazzino").Key("Id_tipoMovimentoMagazzino"))
                                            .ID("cmbMovimento")
                                            .DisplayExpr("Descrizione_tipoMovimento")
                                            .ValueExpr("Id_tipoMovimentoMagazzino")
                                            .SearchEnabled(true)
                                            .Placeholder("Seleziona Movimento"));

                                items.AddSimpleFor(m => m.id_Fornitore).Label(l => l.Text("Fornitore"))
                                        .IsRequired(false)
                                        .Editor(e => e
                                            .SelectBox()
                                            .DataSource(d => d.Mvc().Controller("Configurazioni").LoadAction("GetFornitori").Key("id_fornitore"))
                                            .ID("cmbFornitore")
                                            .DisplayExpr("Descrizione_fornitore")
                                            .ValueExpr("id_fornitore")
                                            .SearchEnabled(true)
                                            .Placeholder("Seleziona Fornitore"));
                                items.AddSimpleFor(m => m.Quantita).Label(l => l.Text("Quantita")).IsRequired(true);
                                items.AddSimpleFor(m => m.Prezzo_prodotto).Label(l => l.Text("Prezzo")).IsRequired(false);

                                items.AddButton().HorizontalAlignment(HorizontalAlignment.Right)
                                .VerticalAlignment(VerticalAlignment.Bottom)
                                               .ButtonOptions(b => b.Text("Salva")
                                               .Type(ButtonType.Success)
                                               .UseSubmitBehavior(true));


                            })
                         .FormData(Model)
                          )}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@*---------------------------------End Modale -------------------------------*@

<script>
    var maxID = @Model.Count;
    var idProd;

    function Start() {
        let bcode = document.querySelector('#search_barcode');
        bcode.focus();
    };
    function isChief(position) {
        return position && ["CEO", "CMO"].indexOf(position.trim().toUpperCase()) >= 0;
    };

    function allowDeleting(e) {
        return !isChief(e.row.data.Position);
    }

    function isCloneIconVisible(e) {
        return !e.row.isEditing && !isChief(e.row.data.Position);
    }

    function onCloneIconClick(e) {
        var clonedItem = $.extend({}, e.row.data, { ID: ++maxID });

        employees.splice(e.row.rowIndex, 0, clonedItem);
        e.component.refresh(true);
        e.event.preventDefault();
    }


    function onRowValidating(e) {
        var position = e.newData.Position;

        if (isChief(position)) {
            e.errorText = "The company can have only one " + position.toUpperCase() + ". Please choose another position.";
            e.isValid = false;
        }
    }

    function onEditorPreparing(e) {
        if (e.parentType === "dataRow" && e.dataField === "Position") {
            e.editorOptions.readOnly = isChief(e.value);
        }
    }


    function SearchProd() {
        let bcode = document.querySelector('#search_barcode');
        //alert('Ricerca prodotto ' + bcode.value);
                    $.ajax({
                            type: "POST",
                            url: '@Url.Action("GetProdottoByBarCode","Prodotti")',
                            data: { barcode: bcode.value},
                            success: function (result) {
                                //alert(result);
                                idProd = result;
                                ShowTicketModal();
                            },
                            error: function () {
                                alert("Prodotto non trovato.");
                            }
                     });

    }

    function isChief(position) {
        return position && ["CEO", "CMO"].indexOf(position.trim().toUpperCase()) >= 0;
    };

    function allowDeleting(e) {
        return !isChief(e.row.data.Position);
    }

    function isCloneIconVisible(e) {
        return !e.row.isEditing && !isChief(e.row.data.Position);
    }

    function onCloneIconClick(e) {
        var clonedItem = $.extend({}, e.row.data, { ID: ++maxID });

        employees.splice(e.row.rowIndex, 0, clonedItem);
        e.component.refresh(true);
        e.event.preventDefault();
    }

    function onRowValidating(e) {
        var position = e.newData.Position;

        if (isChief(position)) {
            e.errorText = "The company can have only one " + position.toUpperCase() + ". Please choose another position.";
            e.isValid = false;
        }
    }

    function onEditorPreparing(e) {
        if (e.parentType === "dataRow" && e.dataField === "Position") {
            e.editorOptions.readOnly = isChief(e.value);
        }
    }


    function ShowTicketModal() {
        $('#modal_prodottiMagazzino').modal("show");
        $("#cmbProd").dxSelectBox("instance").option('value', parseInt(idProd));
    }

    $('#modal_prodottiMagazzino').on('hidden.bs.modal', function () {
        setTimeout(function () {
            let bcode = document.querySelector('#search_barcode');
            bcode.value = '';
            bcode.focus();
        }, 100);
    });


    function onInitNewRow(e, parentID) {
        e.data.id_prodotto = parentID;
    }

    document.getElementById('searchBox').addEventListener('keyup', function () {


        LiveSearch();
    })

    function LiveSearch() {
        let value = document.getElementById('searchBox').value;
        let partialViewProdotti = document.getElementById('_PartialViewProductList');

        $.ajax({
            type: "POST",
            url: '/Prodotti/CercaProdottoByLotto',
            data: {
                lotto: value
            },
            datatype: "html",
            success: function (data) {
                console.log(data);
            },
            error: function (error) {
                alert("Prodotto non trovato: " + error);
            }
        });
    }


</script>
