@*@model Admin.Models.CustomModels.ModelProdotti*@
@model Admin.Models.CustomModels.ModelEditProdotto

@{
    ViewBag.Title = "Gestione Prodotti";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    section.content {
        margin: 15px 15px 0 315px;
    }
</style>

<h2>Cerca un prodotto con il lotto</h2>

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-3 d-flex  mx-5 ">
            <div>
                <input type="text" id="searchBox" name="searchBox" class="form-control mySearchBox empty" placeholder="Cerca" @*onchange="LiveSearch()*@ />
            </div>

        </div>
    </div>
</div>

@(Html.DevExtreme().DataGrid<DAL.Model.DettaglioProdotti>
    ()
    /*    .ID("gridProd")*/
    .DataSource(ds => ds
    .Mvc()
    .Controller("Prodotti")
    .Key("id_prodotto")
    .LoadAction("GetProdotti")
    .DeleteAction("DeleteProdotto").DeleteMethod("POST")
    )
    .ShowBorders(true)
    .Editing(editing =>
    {
        editing.AllowUpdating(true);
        editing.AllowDeleting(new JS("allowDeleting"));
        editing.UseIcons(true);
    })
    .Columns(columns => {
        columns.Add()
    .Type(GridCommandColumnType.Buttons)
    .Width(80)
    .Buttons(b =>
    {
    b.Add().CssClass("ddx-command-edit dx-command-edit-with-icons").Template(@<text><a class="dx-link dx-link-icon dx-icon-edit dx-link-icon" onclick="location.href='@Url.Action("Edit", "Prodotti")/<%= data.id_prodotto %>';" value="Modifica"></a></text>);
        b.Add().Name(GridColumnButtonName.Delete);
    });
        columns.AddFor(m => m.id_prodotto).Caption("id").Width(50).Alignment(HorizontalAlignment.Center);
        columns.AddFor(m => m.pathFoto).CellTemplate(@<text>
                <div>
                    <img src="/<%= data.pathFoto %>" alt="" style="width:80px"/>
                </div>
                </text>).Width(120).Alignment(HorizontalAlignment.Center);
        if (Model.Ita)
        {
            columns.AddFor(m => m.Descrizione).Caption("Prodotto").Width(200).Alignment(HorizontalAlignment.Left);
        }
        else
        {
            columns.AddFor(m => m.DescrizioneProdotto_eng).Caption("Product").Width(200).Alignment(HorizontalAlignment.Left);
        }


        columns.AddFor(m => m.Categoria).Caption("Categoria").Width(100).Alignment(HorizontalAlignment.Center);
        columns.AddFor(m => m.Marca).Caption("Marca").Width(100).Alignment(HorizontalAlignment.Center);
        columns.AddFor(m => m.Quantita).Caption("Quantità").Width(100).Alignment(HorizontalAlignment.Center);
        columns.AddFor(m => m.PrezzoAcquisto).Caption("Prez. Acquisto").Width(100).Alignment(HorizontalAlignment.Center).Format("#0.#00€");
        columns.AddFor(m => m.PrezzoVendita).Caption("Prez. Vendita").Width(100).Alignment(HorizontalAlignment.Center).Format("#0.#00€");
        columns.AddFor(m => m.iva).Caption("Iva").Width(50).Alignment(HorizontalAlignment.Center);
        columns.AddFor(m => m.BarCode).Caption("BarCode").Width(120).Alignment(HorizontalAlignment.Center);
        columns.AddFor(m => m.LottoProdotto).Caption("Lotto prodotto").Width(150).Alignment(HorizontalAlignment.Center);
        columns.AddFor(m => m.DataProduzione).Caption("Data produzione").Width(130).Alignment(HorizontalAlignment.Center).Format("dd/MM/yyyy");
        columns.AddFor(m => m.DataScadenza).Caption("Data scadenza").Width(130).Alignment(HorizontalAlignment.Center).Format("dd/MM/yyyy");

    })


