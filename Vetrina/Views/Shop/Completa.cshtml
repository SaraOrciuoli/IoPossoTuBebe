    function MetodoSelezionato() {
        const metodiPagamento = document.querySelectorAll(".metodoPagamento");

        metodiPagamento.forEach(div => {
            div.addEventListener("click", function () {
                this.classList.add("metodoPagamentoSelezionato");

                metodiPagamento.forEach(otherDiv => {
                    if (otherDiv !== this) {
                        otherDiv.classList.remove("metodoPagamentoSelezionato");
                    }
                });
            });
        });

    }
</script>


