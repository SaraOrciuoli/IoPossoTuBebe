@model Vetrina.Models.CustomModel.ModelCompleta

@{
    ViewData["Title"] = "Menu";
    Layout = "~/Views/Shared/_LayoutMenu.cshtml";
}
<div class="row">
    <div class="col-xs-12">
        <div class="text-center">
            <h2 class="text-center"><strong>@Vetrina.App_GlobalResources.labels.Completa_titolo</strong></h2>
        </div>
    </div>
</div>



@using (Html.BeginForm("SalvaOrdine", "Shop", FormMethod.Post, new { enctype = "multipart/form-data", onsubmit = "validateForm(event)" }))
{
    @Html.HiddenFor(model => model.totale);
    @Html.HiddenFor(model => model.TotaleConServizio);
    @Html.HiddenFor(model => model.MetodoPagamento);
    @Html.HiddenFor(model => model.Resto);
    @Html.HiddenFor(model => model.Ordine.Nominativo);
    @Html.HiddenFor(model => model.Ordine.Tavolo);
    @Html.HiddenFor(model => model.Ordine.Indirizzo);
    @Html.HiddenFor(model => model.Ordine.Citta);
    @Html.HiddenFor(model => model.Ordine.Provincia);
    @Html.HiddenFor(model => model.Ordine.Cap);
    @Html.HiddenFor(model => model.Ordine.NumTelefono);


    <div class="row-co-first d-flex">
        <h4><strong>Prodotti:</strong></h4>
        @*<p><strong>Totale: <span class="color-org"> @Model.TotaleConServizio €</span></strong></p>*@
    </div>
    <div class="row text-center Margin-Top">
        <div class="col-xs-12 panelProdotti">
            <div id="ListProduct">

            </div>
        </div>
    </div>
    <br />
    <div class="row">
        <div class="col-xs-12">

            <div class="col-xs-12 text-center no-margin-left ">
                <h3><strong>Paga in cassa:</strong></h3>
            </div>


            @if (@System.Configuration.ConfigurationManager.AppSettings["MetodiPagamento"] == "1")
            {
                <div class="row">
                    <div class="col-xs-1"> </div>
                    <div class="col-xs-10 text-center">
                        <div class="form-check radio-inline">
                            <input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio1" value="Conanti" onchange="ShowInput()">
                            <label class="form-check-label" for="inlineRadio1" style="font-size:18px">Paga in @Vetrina.App_GlobalResources.labels.Completa_Contanti</label>
                        </div>
                    </div>
                    <div class="col-xs-1"> </div>
                </div>
                <div class="row">
                    <div id="DivVersatoCliente" class="col-xs-12 text-right">
                        <input class="form-control" type="number" id="versato" onchange="ModResto()" placeholder="@Vetrina.App_GlobalResources.labels.Completa_resto">
                    </div>
                </div>
            }
            else
            {
                <div class="row">
                    <div class="col-xs-1"> </div>
                    <div class="col-xs-10 text-center" style="padding: 0px;">
                        <div class="form-check  metodoPagamento " style="background-color: #373736" onclick="MetodoSelezionato()" onchange="ShowInput()">
                            <input class="form-check-input " style="display:none;" type="radio" name="inlineRadioOptions" id="inlineRadio1" value="Conanti">
                            <label class="form-check-label " for="inlineRadio1" style="font-size:18px;"><img style="padding: 1vw 2vw;" src="~/images/contanti.png" /><em>Paga in @Vetrina.App_GlobalResources.labels.Completa_Contanti</em></label>
                        </div>
                    </div>
                    <div class="col-xs-1"> </div>
                </div>
                <div class="row">
                    <div class="col-xs-1"> </div>
                    <div class="col-xs-10 text-center" style="padding: 0px;">
                        <div class="form-check metodoPagamento" style="margin-top: 10px; background-color:#373736" onclick="MetodoSelezionato()" onchange="ShowInput()">
                            <input class="form-check-input" type="radio" style="display:none;" name="inlineRadioOptions" id="inlineRadio2" value="Bancomat" >
                            <label class="form-check-label " for="inlineRadio2" style="font-size: 18px; padding-right: 25px;"><img style="padding: 1vw 2vw;" src="~/images/carta.png" /><em>Paga con @Vetrina.App_GlobalResources.labels.Completa_Carte</em></label>
                        </div>
                    </div>
                    <div class="col-xs-1"> </div>
                </div>
                <div class="row" style="margin-top:10px">
                    <div class="col-xs-1"> </div>
                    <div id="DivVersatoCliente" class="col-xs-10 text-right">
                        <input class="form-control" type="number" id="versato" onchange="ModResto()" placeholder="@Vetrina.App_GlobalResources.labels.Completa_resto">
                    </div>
                    <div class="col-xs-1"> </div>
                </div>
            }
            <div class="row">
                <div class="col-xs-12 text-center no-margin-left ">
                    <h3><strong>Paga in app:</strong></h3>
                </div>
                <div class="text-center ">
                    <img class="metodoPagamento" src="~/images/paypal-logo.png" />
                </div>
            </div>

        </div>
    </div>
        

   
    <div class="row text-right" style="margin-bottom:20px;margin-right:10px" >
        <div class="col-xs-12 ">
            <h2><strong>@Vetrina.App_GlobalResources.labels.Completa_Subtot <span class="color-org">@Model.totale €</span></strong></h2>
        </div>
        @if (Model.MostraServizio)
        {
            <div class="col-xs-12 ">
                <h2><strong>@Vetrina.App_GlobalResources.labels.Completa_Servizio <span class="color-org">@Model.CostoServizio €</span></strong></h2>
            </div>
            <div class="col-xs-12 ">
                <h2><strong>@Vetrina.App_GlobalResources.labels.Completa_totale <span class="color-org">@Model.TotaleConServizio €</span></strong></h2>
            </div>
        }
        else
        {
            <div class="col-xs-12 ">
                <h2><strong>@Vetrina.App_GlobalResources.labels.Completa_totale <span class="color-org">@Model.totale €</span></strong></h2>
            </div>
        }
    </div>
    if (!Model.MostraPulsante)
    {
        <div class="row">
            <div class="col-xs-12 text-center">
                <h3 class="color-red">Quantità minima non raggiunta per effettuare un ordine</h3>
            </div>
        </div>
    }
    <div class="row text-center justify-content-Right" style="padding-bottom:50px">
        <div class="col-sm-6 col-xs-12 justify-content-Right ">

            <button class="btn btn-info-mini waves-effect btn-custom2" type="submit" value="modifica" name="buttonType" style="background-color: #ee7a1c">@Vetrina.App_GlobalResources.labels.Button_Modifica</button>

        </div>
        <div class="col-sm-6 col-xs-12 justify-content-left ">
            @if (Model.MostraPulsante)
            {
                <button class="btn btn-info-mini waves-effect btn-custom2" type="submit" value="salva" name="buttonType" style="background-color: #ee7a1c">@Vetrina.App_GlobalResources.labels.Button_Completa</button>
            }
        </div>
    </div>
}



