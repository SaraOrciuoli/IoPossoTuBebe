<script>
      $(document).ready(function () {
       document.getElementById("DivVersatoCliente").style.visibility = "hidden";

        $('#ListProduct').dxList({
            dataSource:@Html.Raw(WebUtility.HtmlDecode(@Model.Prodotti)),
            itemTemplate(itemData, itemIndex, itemElement) {
                if (itemData.Quantita != 0) {
                    var uscita = itemData.OrdineUscita != "" || itemData.OrdineUscita != null || itemData.OrdineUscita != "0" ? itemData.OrdineUscita : " - ";
                return $('<div class="outer-co-item row">')
                    .append($('<div class="co-left-col col-xs-8">' +
                        '<div class="order-co-name" style=" white-space: normal;">' + itemData.Descrizione + '</div>' +
                        '<div class="order-co-quant order-co">' + "N° Prodotti: " + itemData.Quantita + '</div>' +
                        '<div class="order-co-price-single order-co">' + "Prezzo singolo: " + '<span class="color-red">' + itemData.Prezzo.toString() + "€" + '</span></div>' +
                        /*'<div class="order-co">' + "Portata n°: " + uscita + '</div>' +*/
                        '</div>' +
                        '<div class="co-right-col col-xs-4">' +
                        '<div class="picture-co-item" id="PathImg""><img class="picture-co" style="padding-top: 30px;" src=' + '@System.Configuration.ConfigurationManager.AppSettings["pathFoto"]'+ itemData.PathFoto + ' /></div>' +
                        '<div class="order-co-price">' + "Totale: " + '<span class="color-red">' + itemData.Calculate + "€" + '</span></div>' +
                            '</div>'));
                }
            },
                pageLoadMode:'scrollBottom',
                earchEnabled: true,
                searchExpr: 'Descrizione',
            });
    });

   function ModResto() {
        var vers = document.getElementById("versato").value;
        document.getElementById("Resto").value = "Resto di " + vers + "€";
    }

    function ShowInput() {
        var Contanti = document.getElementById("inlineRadio1").checked;
        if (Contanti) {
            document.getElementById("DivVersatoCliente").style.visibility = "visible";
        }
        else {
            document.getElementById("DivVersatoCliente").style.visibility = "hidden";
        }
    }

    function validateForm(event) {
            var mostraBancomat = @Html.Raw(WebUtility.HtmlDecode(@Model.MostraBancomat));
            if (event.submitter.value == "salva") {
                var Contanti = document.getElementById("inlineRadio1").checked;
                if (mostraBancomat == "2") {
                    var Bancomat = document.getElementById("inlineRadio2").checked;
                    if (Contanti || Bancomat) {
                        if (Contanti) document.getElementById("MetodoPagamento").value = "Contanti";
                        if (Bancomat) document.getElementById("MetodoPagamento").value = "Carte";
                        var vers = document.getElementById("versato").value;
                        document.getElementById("Resto").value = "Resto di " + vers + "€";

                    }
                    else {
                        event.preventDefault();
                        alert("Selezionare un metodo di pagamento!");
                    }
                }
                else {
                    if (Contanti) {
                        if (Contanti) document.getElementById("MetodoPagamento").value = "Contanti";
                        if (Bancomat) document.getElementById("MetodoPagamento").value = "Carte";
                        var vers = document.getElementById("versato").value;
                        document.getElementById("Resto").value = "Resto di " + vers + "€";

                    }
                    else {
                        event.preventDefault();
                        alert("Selezionare un metodo di pagamento!");
                    }
                }

            }

    };
