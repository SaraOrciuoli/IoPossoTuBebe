            gap: 12px;
        }

        .footer-social-link {
            color: #333;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: color 0.3s;
        }

            .footer-social-link:hover {
                color: #00a89d;
            }

        .footer-social-icon {
            width: 20px;
            text-align: center;
        }

        .footer-links {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .footer-link {
            color: #333;
            text-decoration: none;
            display: flex;
