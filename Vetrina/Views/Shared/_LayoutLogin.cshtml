            gap: 10px;
            transition: color 0.3s;
        }

            .footer-link:hover {
                color: #00a89d;
            }

        .footer-link-icon {
            width: 16px;
            text-align: center;
            color: #00a89d;
        }

        .footer-bottom {
            text-align: center;
            padding: 20px 0 10px;
            margin-top: 20px;
