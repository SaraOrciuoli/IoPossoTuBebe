        <!-- Prima Riga: Logo | Menu Centrale | User/Carrello -->
        <div class="navbar-top-row" id="navbarTopRow">
            <div class="navbar-logo" onclick="Home()">
                <img id="logoNav" src="~/Images/Plex/logo-navbar-footer.png" class="img-fluid" alt="Logo" />
            </div>

            <div class="top-nav-center d-none d-xl-flex">
                <a class="nav-link" href="@Url.Action("Index", "ecommerce")">HOME</a>
                <a class="nav-link" href="@Url.Action("Index", "ecommerce")#shop">SHOP</a>
                <a class="nav-link" href="@Url.Action("Contatti", "ecommerce")">CONTATTI</a>
            </div>

            <div class="top-nav-right">
                @if (HttpContext.Current.Request.Cookies["ForrestUser"] == null)
                {
                    <div class="dropdown" id="userIcon">
                        <button class="dropbtn">
                            <span class="nav-link">
                                <span class="material-symbols-outlined">account_circle</span>
                            </span>
                        </button>
                        <div class="dropdown-content">
                            <a href="@Url.Action("Registrazione", "login")" class="nav-link log">@Resources.labels.Registrati.ToUpper()</a>
                            <a href="@Url.Action("Login", "login")" class="nav-link log">@Resources.labels.Accedi.ToUpper()</a>
                        </div>
                    </div>
                }
                else
                {
                    var userNome = HttpContext.Current.Request.Cookies["ForrestUser"]["Nome"];
                    var userCognome = HttpContext.Current.Request.Cookies["ForrestUser"]["Cognome"];

                    <!-- Nome Utente (solo desktop) -->
                    <a href="@Url.Action("Profilo", "Login")/@HttpContext.Current.Request.Cookies["ForrestUser"]["IdUtente"]/@HttpContext.Current.Request.Cookies["ForrestUser"]["Nome"]-@HttpContext.Current.Request.Cookies["ForrestUser"]["Cognome"]" class="nav-link forrest-user d-none d-xl-block">
                        @userNome.ToUpper() @userCognome.ToUpper()
                    </a>

                    <!-- Logout Icon (tutti gli schermi) -->
                    <div class="dropdown" id="userIcon">
                        <button class="dropbtn">
                            <span class="nav-link">
                                <span class="material-symbols-outlined">logout</span>
                            </span>
                        </button>
                        <div class="dropdown-content">
                            <a href="@Url.Action("Profilo", "Login")/@HttpContext.Current.Request.Cookies["ForrestUser"]["IdUtente"]/@HttpContext.Current.Request.Cookies["ForrestUser"]["Nome"]-@HttpContext.Current.Request.Cookies["ForrestUser"]["Cognome"]" class="nav-link forrest-user">
                                @Resources.labels.Profilo.ToUpper()
                            </a>
                            <a href="@Url.Action("Logout", "login")" class="nav-link">LOGOUT</a>
                        </div>
                    </div>
                }

                <!-- Carrello -->
                <a href="@Url.Action("carrello", "ecommerce")" class="nav-link cart-icon">
                    <img src="~/images/Plex/carrello.png" style="height: 40px;" />
                    <span class="qta" id="cartItemCount"></span>
                </a>

                <!-- Mobile Toggle Button -->
                <button class="navbar-toggler d-xl-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar" aria-label="Toggle navigation" style="margin-right:30px;">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
        </div>
    </nav>

    <!-- Offcanvas per Mobile (Menu Principale) -->
    <div class="offcanvas offcanvas-end d-xl-none" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
        <div class="offcanvas-header" style="background: #134f72; color: white;">
            <h5 class="offcanvas-title" id="offcanvasNavbarLabel">Menu</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body" style="background: #0d3c55; color: white;">
            <ul class="navbar-nav flex-grow-1 pe-3">
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "ecommerce")">HOME</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "ecommerce")#shop">SHOP</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Contatti", "ecommerce")">CONTATTI</a>
                </li>
                <li><hr class="dropdown-divider"></li>

                <!-- Sezioni User nel mobile -->
                @if (HttpContext.Current.Request.Cookies["ForrestUser"] == null)
                {
                    <li class="nav-item">
                        <a href="@Url.Action("Registrazione", "login")" class="nav-link">@Resources.labels.Registrati.ToUpper()</a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Login", "login")" class="nav-link">@Resources.labels.Accedi.ToUpper()</a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a href="@Url.Action("Profilo", "Login")/@HttpContext.Current.Request.Cookies["ForrestUser"]["IdUtente"]/@HttpContext.Current.Request.Cookies["ForrestUser"]["Nome"]-@HttpContext.Current.Request.Cookies["ForrestUser"]["Cognome"]" class="nav-link">
                            @Resources.labels.Profilo.ToUpper()
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="@Url.Action("Logout", "login")" class="nav-link text-danger">LOGOUT</a>
                    </li>
                }
                <li><hr class="dropdown-divider"></li>
                <li class="nav-item">
                    <a href="@Url.Action("Index", "ecommerce")" class="nav-link">@Resources.labels.TornaAgliAcquisti.ToUpper()</a>
                </li>
            </ul>
        </div>
