    @Scripts.Render("~/bundles/jquery")
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    @RenderSection("scripts", required: false)

    <script>
        $(document).ready(function () {
            // Inizializza animazioni AOS
            AOS.init({
                once: true,
                offset: 50,
                duration: 800
            });

            // Disabilita tasto destro
            $("body").on("contextmenu", function (e) {
                return false;
            });

            // Chiudi i menu a tendina se si clicca fuori
            $(document).on('click', function (e) {
                if (!$(e.target).closest('.navbar').length) {
                    $('.category-glass-menu').removeClass('active');
                }
                if (!$(e.target).closest('.user-dropdown-container').length) {
                    $('#userMenu').removeClass('active');
                }
            });

            updateCartItemCount();
        });

        // Funzione per il Carrello
        function updateCartItemCount() {
            $.ajax({
                url: '@Url.Action("GetCartItemCount", "Shop")',
                type: 'GET',
                success: function(response) {
                    $('#cartItemCount').text(response);
                },
                error: function() {
                    console.error('Errore durante il recupero del carrello.');
                }
            });
        }

        // --- NUOVA LOGICA SEARCH ---
        function toggleSearch() {
            const container = document.getElementById('searchContainer');
            const input = container.querySelector('input');
            const icon = container.querySelector('.cerca-icon');

            container.classList.toggle('active');

            if (container.classList.contains('active')) {
                input.focus();
                // Sostituisce la lente con una X per la chiusura
                icon.classList.remove('fa-search');
                icon.classList.add('fa-times');
            } else {
                // Torna alla lente
                icon.classList.remove('fa-times');
                icon.classList.add('fa-search');
            }
        }

        // Funzione per il Menu Utente
        function toggleUserMenu(event) {
            event.preventDefault();
            event.stopPropagation();
            $('.category-glass-menu').removeClass('active');
            $('#userMenu').toggleClass('active');
        }

        function toggleGlassMenu(event, menuId) {
            event.preventDefault();
            event.stopPropagation();
            $('#userMenu').removeClass('active');

            if ($('#' + menuId).hasClass('active')) {
                $('#' + menuId).removeClass('active');
            } else {
                $('.category-glass-menu').removeClass('active');
                $('#' + menuId).addClass('active');
            }
        }

        // Funzioni per gestire il Side-Cart
        function openSideCart() {
            $('#cart-overlay').addClass('active');
            $('#side-cart').addClass('active');
            $('body').css('overflow', 'hidden');
            loadCartContent();
        }

        function closeSideCart() {
            $('#cart-overlay').removeClass('active');
            $('#side-cart').removeClass('active');
            $('body').css('overflow', 'auto');
        }

        function loadCartContent() {
            $.ajax({
                url: '@Url.Action("CartPartial", "Ecommerce")',
                type: 'GET',
                success: function (data) {
                    $('#side-cart-body').html(data);
                },
                error: function () {
                    $('#side-cart-body').html('<div class="text-center text-danger mt-5">Errore nel caricamento del carrello.</div>');
                }
            });
        }

        function eliminaProdotto(index) {
            $.ajax({
                url: '@Url.Action("RemoveProductFromSession", "Ecommerce")',
                method: 'POST',
                data: { index: index },
                success: function() {
                    loadCartContent();
                    updateCartItemCount();
                },
                error: function(xhr, status, error) {
                    console.error(error);
                }
            });
        }
    </script>
</body>
