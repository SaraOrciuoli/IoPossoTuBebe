@model Vetrina.Models.CustomModel.CombinedViewModel
@{
    DAL.Repository.ConfigurazioniRepository configRepo = new DAL.Repository.ConfigurazioniRepository();

    var testiToolbar = configRepo.getTestiToolbar() as List<DAL.Model.Toolbar>;
}
<!DOCTYPE html>
<html lang="it-IT">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anye Label - @ViewBag.Title</title>


    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <script src="https://www.paypal.com/sdk/js?client-id=AXu7FJu3WSL8BSatEYoHvWwwkxwikuTc-CDgdg7sh5T8m34ImLo3-m5fAqez9_s1d5FXjut44bj4t-Yj&components=buttons&currency=EUR&intent=capture&commit=true&disable-funding=mybank"></script>

    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <style>
         html, body {
             font-family: "Raleway", sans-serif;
             overflow-x: hidden;
             font-weight: 200;
         }

         /* =========================================
                 TOP TOOLBAR (TESTO SCORREVOLE)
                 ========================================= */
         .top-toolbar {
             position: fixed;
             top: 0;
             left: 0;
             width: 100%;
             height: 40px;
             background-color: black;
             display: flex;
             align-items: center;
             z-index: 1040;
             font-size: 0.8rem;
             font-weight: 400;
             letter-spacing: 1.5px;
             text-transform: uppercase;
         }

         .scrolling-text-container {
             width: 100%;
             overflow: hidden;
             white-space: nowrap;
         }

         .scrolling-text {
             display: inline-block;
             padding-left: 50%;
             animation: scroll-left 45s linear infinite;
         }

             .scrolling-text i {
                 margin-right: 5px;
                 color: white;
             }

             .scrolling-text span {
                 margin: 0 200px;
                 color: white;
             }

         @@keyframes scroll-left {
             0% {
                 transform: translateX(0);
             }

             100% {
                 transform: translateX(-100%);
             }
         }

         /* =========================================
                 BOTTONI E HOVER
                 ========================================= */
         .btn-custom {
             border-radius: 30px;
             padding: 12px 35px;
             text-transform: uppercase;
             font-size: 0.85rem;
             font-weight: 500;
             letter-spacing: 1px;
             transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
             position: relative;
             overflow: hidden;
         }

         .btn-negro-custom {
             background-color: transparent;
             color: black;
             border: 2px solid black;
         }

             .btn-negro-custom:hover {
                 background-color: black;
                 color: white;
                 transform: translateY(-3px);
                 border: 2px solid #2c3e50;
                 font-weight: 900
             }

         .btn-outline-custom {
             background-color: transparent;
             color: #2c3e50;
             border: 2px solid #2c3e50;
         }

             .btn-outline-custom:hover {
                 background-color: #2c3e50;
                 color: white;
                 transform: translateY(-3px);
             }

         .hover-specialissimo {
             transition: all 0.3s ease-in-out;
         }

             .hover-specialissimo:hover {
                 transform: translateY(-10px);
                 box-shadow: 0 15px 30px rgba(0,0,0,0.1);
             }

         /* =========================================
                 NAVBAR E LOGO
                 ========================================= */
         .navbar.fixed-top {
             top: 40px !important;
             width: 100%;
             left: 0;
             z-index: 1030;
             min-height: 65px
         }

         .navbar {
             padding: 0; /* Su desktop manteniamo padding zero */
             background-color: rgba(255, 255, 255, 0.95);
             backdrop-filter: blur(10px);
             box-shadow: 0 2px 20px rgba(0,0,0,0.05);
             transition: all 0.3s;
         }

         .logo-img {
             height: 70px;
             width: auto;
             max-width: 100%;
             transition: transform 0.3s;
             PADDING: 5PX;
             position: absolute;
             margin-left: 206px;
             margin-top: -35px;
         }

         .navbar-logo:hover .logo-img {
             transform: scale(1.05);
         }

         .nav-link {
             font-size: 1.5rem;
             font-weight: 500;
             color: black;
             margin: 0 10px;
             position: relative;
             cursor: pointer;
         }

             .nav-link::after {
                 content: '';
                 position: absolute;
                 width: 0;
                 height: 2px;
                 bottom: 5px;
                 left: 50%;
                 background-color: black;
                 transition: all 0.3s;
                 transform: translateX(-50%);
             }

             .nav-link:hover::after {
                 width: 100%;
             }

         /* =========================================
         SIDE CART (OFFCANVAS GLASSMORPHISM)
         ========================================= */
         .cart-overlay {
             position: fixed;
             top: 0;
             left: 0;
             width: 100vw;
             height: 100vh;
             background: rgba(0, 0, 0, 0.4);
             backdrop-filter: blur(3px);
             -webkit-backdrop-filter: blur(3px);
             z-index: 1050;
             opacity: 0;
             visibility: hidden;
             transition: all 0.4s ease;
         }

             .cart-overlay.active {
                 opacity: 1;
                 visibility: visible;
             }

         .side-cart {
             position: fixed;
             top: 0;
             right: -450px;
             width: 400px;
             max-width: 100vw;
             height: 100vh;
             background: rgba(255, 255, 255, 0.85);
             backdrop-filter: blur(20px);
             -webkit-backdrop-filter: blur(20px);
             box-shadow: -10px 0 30px rgba(0, 0, 0, 0.1);
             z-index: 1060;
             display: flex;
             flex-direction: column;
             transition: right 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
         }

             .side-cart.active {
                 right: 0;
             }

         .side-cart-header {
             padding: 25px;
             border-bottom: 1px solid rgba(0,0,0,0.05);
             display: flex;
             justify-content: space-between;
             align-items: center;
         }

         .close-cart-btn {
             background: transparent;
             border: none;
             font-size: 1.5rem;
             color: #95a5a6;
             cursor: pointer;
             transition: transform 0.3s, color 0.3s;
         }

             .close-cart-btn:hover {
                 color: #8B0000;
                 transform: rotate(90deg);
             }

         .side-cart-body {
             flex: 1;
             overflow-y: auto;
             padding: 25px;
         }

         .cart-item-card {
             display: flex;
             align-items: center;
             background: white;
             border-radius: 16px;
             padding: 15px;
             margin-bottom: 15px;
             box-shadow: 0 5px 15px rgba(0,0,0,0.03);
             position: relative;
             border: 1px solid #f1f2f6;
         }

         .cart-item-img {
             width: 70px;
             height: 70px;
             background: #f8f9fa;
             border-radius: 12px;
             display: flex;
             align-items: center;
             justify-content: center;
             margin-right: 15px;
             overflow: hidden;
         }

             .cart-item-img img {
                 max-width: 100%;
                 max-height: 100%;
                 object-fit: contain;
                 mix-blend-mode: multiply;
             }

         .cart-item-details {
             flex: 1;
         }

         .cart-item-title {
             font-size: 0.95rem;
             font-weight: 400;
             color: #2c3e50;
             margin-bottom: 5px;
         }

         .cart-item-price-row {
             display: flex;
             justify-content: space-between;
             align-items: center;
         }

         .cart-item-remove {
             background: #ffeaa7;
             color: #d35400;
             border: none;
             width: 30px;
             height: 30px;
             border-radius: 50%;
             display: flex;
             align-items: center;
             justify-content: center;
             cursor: pointer;
             transition: all 0.3s;
             position: absolute;
             top: 15px;
             right: 15px;
         }

             .cart-item-remove:hover {
                 background: #e74c3c;
                 color: white;
             }

         /* STILI BOTTONI CARRELLO E STATO VUOTO */
         .empty-cart-container {
             text-align: center;
             padding-top: 50px;
         }

         .empty-cart-icon {
             font-size: 4rem;
             color: #e0e0e0;
             margin-bottom: 20px;
         }

         .btn-modern-dark {
             background: #2c3e50;
             color: white;
             border-radius: 30px;
             padding: 12px;
             font-weight: 500;
             text-transform: uppercase;
             transition: all 0.3s;
             border: 2px solid #2c3e50;
             margin-bottom: 10px;
             width: 100%;
         }

             .btn-modern-dark:hover {
                 background: transparent;
                 color: #2c3e50;
                 transform: translateY(-2px);
             }

         .btn-modern-outline {
             background: transparent;
             color: #2c3e50;
             border-radius: 30px;
             padding: 12px;
             font-weight: 500;
             text-transform: uppercase;
             border: 2px solid #2c3e50;
             transition: all 0.3s;
             display: block;
             text-align: center;
             text-decoration: none;
         }

             .btn-modern-outline:hover {
                 background: #2c3e50;
                 color: white;
                 transform: translateY(-2px);
             }

         /* GLASSMORPHISM MENU CATEGORIE */
         .glass-menu-container {
             position: absolute;
             top: 100%;
             left: 0;
             width: 100%;
             backdrop-filter: blur(20px);
             -webkit-backdrop-filter: blur(20px);
             border-top: 1px solid rgba(255,255,255,0.5);
             opacity: 0;
             visibility: hidden;
             transform: translateY(-10px);
             transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
             z-index: 1000;
             padding: 10px 0;
         }

             .glass-menu-container.active {
                 opacity: 1;
                 visibility: visible;
                 transform: translateY(0);
             }

         .glass-link {
             display: inline-block;
             padding: 7px 15px;
             color: #2c3e50;
             font-weight: 600;
             text-transform: uppercase;
             text-decoration: none;
             border-radius: 30px;
             background: rgb(255 255 255 / 73%);
             backdrop-filter: blur(119px) !important;
             -webkit-backdrop-filter: blur(12px);
             border: 1px solid rgba(255, 255, 255, 0.35);
             box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
             transition: all 0.35s ease;
             width: fit-content;
             background: #edecec4f;
             padding: 10px 15px;
             border-radius: 40px;
             backdrop-filter: blur(84px);
             font-size: 0.8rem;
         }

         .conteiner-allglass {
             width: fit-content;
             display: flex;
             justify-content: space-around;
             max-width: 800px;
             background: #eeeeeed6;
             padding: 8px 13px;
             border-radius: 40px;
             backdrop-filter: blur(84px);
         }

         .glass-link:hover {
             background: rgba(255, 255, 255, 0.28);
             box-shadow: 0 10px 40px rgba(0, 0, 0, 0.25);
             transform: translateY(-2px);
             color: #8b0000;
         }

         /* =========================================
                 USER DROPDOWN MENU (MODERNO)
                 ========================================= */
         .user-dropdown-container {
             position: relative;
         }

         .user-dropdown-menu {
             position: absolute;
             top: 150%;
             right: 0;
             min-width: 220px;
             background: rgba(255, 255, 255, 0.9);
             backdrop-filter: blur(15px);
             -webkit-backdrop-filter: blur(15px);
             border: 1px solid rgba(255, 255, 255, 0.5);
             box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
             border-radius: 16px;
             padding: 10px 0;
             opacity: 0;
             visibility: hidden;
             transform: translateY(-15px);
             transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
             z-index: 1050;
             color: black
         }

             .user-dropdown-menu.active {
                 opacity: 1;
                 visibility: visible;
                 transform: translateY(0);
             }

             .user-dropdown-menu::before {
                 content: '';
                 position: absolute;
                 top: -6px;
                 right: 15px;
                 width: 12px;
                 height: 12px;
                 background: rgba(255, 255, 255, 0.9);
                 color: black;
                 transform: rotate(45deg);
                 border-left: 1px solid rgba(255, 255, 255, 0.5);
                 border-top: 1px solid rgba(255, 255, 255, 0.5);
             }

         .user-dropdown-item {
             display: flex;
             align-items: center;
             gap: 10px;
             padding: 12px 20px;
             color: black;
             text-decoration: none;
             font-weight: 400;
             font-size: 0.9rem;
             text-transform: uppercase;
             transition: background 0.2s, color 0.2s;
         }

             .user-dropdown-item:hover, .user-dropdown-item:hover i {
                 color: #8b0000;
             }

             .user-dropdown-item i {
                 font-size: 1.1rem;
                 color: #95a5a6;
             }

         .user-greeting {
             padding: 10px 20px;
             font-size: 0.85rem;
             color: black;
             border-bottom: 1px solid rgba(0,0,0,0.05);
             margin-bottom: 5px;
             font-weight: 400;
             text-transform: none;
         }

             .user-greeting span {
                 display: block;
                 font-weight: 400;
                 color: black;
                 font-size: 1rem;
             }

         .user-dropdown-divider {
             height: 1px;
             background: rgba(0,0,0,0.05);
             margin: 5px 0;
         }

         .text-danger:hover, .text-danger:hover i {
             color: #e74c3c !important;
         }

         /* =========================================
                 SEARCH BAR & CARRELLO
                 ========================================= */
         .cerca-icon {
             cursor: pointer;
             font-size: 1.2rem;
             color: #2c3e50;
             transition: transform 0.3s, color 0.3s;
         }

         .cart-container {
             position: relative;
             display: flex;
             align-items: center;
         }

         .cart-badge {
             position: absolute;
             top: -8px;
             right: -8px;
             background: #8B0000;
             color: white;
             border-radius: 50%;
             padding: 2px 6px;
             font-size: 10px;
             font-weight: bold;
             min-width: 18px;
             text-align: center;
         }

         /* CSS RICERCA DESKTOP (Espanzione Laterale) */
         @@media (min-width: 992px) {
             .cerca-container {
                 display: flex;
                 align-items: center;
                 overflow: hidden;
             }

             .cerca-input {
                 width: 0;
                 opacity: 0;
                 border: none;
                 border-bottom: 2px solid #2c3e50;
                 outline: none;
                 transition: all 0.4s ease;
                 background: transparent;
                 padding: 5px;
                 font-weight: 400;
             }

             .cerca-container.active .cerca-input {
                 width: 200px;
                 opacity: 1;
                 margin-right: 10px;
             }

             .cerca-container.active .cerca-icon {
                 transform: scale(1.1);
                 color: #c0a16b;
             }
         }

         /* RESPONSIVE MOBILE TWEAKS */
         @@media (max-width: 991px) {
             .navbar {
                 padding: 12px 0; /* Navbar più alta in modalità mobile */
             }

             .glass-menu-container {
                 position: relative;
                 background: transparent;
                 backdrop-filter: none;
                 box-shadow: none;
                 padding: 10px 0;
             }
             /* Posizionamento Assoluto per il logo su mobile così resta al centro E NON SI SPOSTA */
             .custom-mobile-logo {
                 position: absolute;
                 left: 50%;
                 top: 0px; /* Fisso in alto rispetto al container */
                 transform: translateX(-50%);
                 z-index: 10;
             }

             .logo-img {
                 height: 60px !important; /* Immagine più grande per riempire la navbar più alta */
                 margin-top: -10px;
             }
             /* Dà spazio al menu che si apre, così non va sotto al logo o ai bottoni */
             #navbarNav {
                 margin-top: 20px;
             }
             /* CSS RICERCA MOBILE (Dropdown Drop-down) */
             .cerca-container {
                 position: static;
             }

             .cerca-input {
                 position: absolute;
                 top: 100%;
                 left: 0;
                 width: 100%;
                 height: 0;
                 padding: 0 20px;
                 background: rgba(255, 255, 255, 0.98);
                 backdrop-filter: blur(15px);
                 border: none;
                 box-shadow: 0 10px 20px rgba(0,0,0,0.05);
                 opacity: 0;
                 visibility: hidden;
                 font-size: 1.1rem;
                 outline: none;
                 transition: all 0.3s ease;
             }

             .cerca-container.active .cerca-input {
                 height: 60px;
                 opacity: 1;
                 visibility: visible;
                 border-bottom: 2px solid #8B0000;
             }

             .cerca-icon.fa-times {
                 color: #8B0000;
                 transform: rotate(90deg);
             }
         }

         /* =========================================
        FOOTER
        ========================================= */
         .site-footer {
             border-top: 1px solid #eaeaea; /* Un bordo leggero e pulito */
             background-color: #fff;
         }

         /* Stile Titoli (CONTATTI, SERVIZIO CLIENTI, SEGUICI) */
         .footer-title {
             font-weight: 300; /* Font sottile come in grafica */
             font-size: 1.4rem;
             color: #000;
             text-transform: uppercase;
             letter-spacing: 1px;
             margin-bottom: 0;
         }

         /* Stile Link di navigazione */
         .footer-links li {
             margin-bottom: 12px;
         }

         .footer-links a {
             color: #000;
             text-decoration: none;
             font-size: 1.1rem;
             font-weight: 300; /* Font sottile */
             text-transform: uppercase;
             display: inline-block;
             width: 100%;
             max-width: 250px; /* Limita la lunghezza della linea azzurra */
             padding-bottom: 8px;
             border-bottom: 3px solid transparent; /* Bordo invisibile di base */
             transition: color 0.3s;
         }

         /* La riga colorata sotto il link attivo (HOMEPAGE nell'esempio) */
         .footer-links li.active a {
             border-bottom-color: #b0caca; /* Il color carta da zucchero della grafica */
         }

         .footer-links a:hover {
             color: #b0caca;
         }

         /* Bottone nero "Dove siamo" */
         .btn-dove-siamo {
             background-color: #000;
             color: #fff;
             border-radius: 30px;
             padding: 8px 30px;
             font-size: 1rem;
             font-weight: 400;
             transition: all 0.3s;
             border: 1px solid #000;
         }

             .btn-dove-siamo:hover {
                 background-color: #fff;
                 color: #000;
             }

         /* Cerchietti Beige per i Social */
         .social-circle {
             background-color: #d4c2b3; /* Stesso beige usato nella sezione bestseller */
             color: #fff;
             width: 45px;
             height: 45px;
             border-radius: 50%;
             display: inline-flex;
             align-items: center;
             justify-content: center;
             text-decoration: none;
             font-size: 1.2rem;
             transition: transform 0.3s, background-color 0.3s;
         }

             .social-circle:hover {
                 background-color: #bfa895; /* Beige un po' più scuro all'hover */
                 color: #fff;
                 transform: scale(1.1);
             }
    </style>
</head>
<body>

    <div class="top-toolbar">
        <div class="scrolling-text-container">
            <div class="scrolling-text">
                @if (testiToolbar != null && testiToolbar.Any())
                {
                    foreach (var item in testiToolbar)
                    {
                        <span>@Html.Raw(item.testo_toolbar)</span>
                    }
                }
                else
                {
                    <span><i class="fas fa-shipping-fast"></i> Spedizione gratuita in tutta Italia</span>
                    <span><i class="fas fa-gift"></i> Confezione regalo inclusa in ogni ordine</span>
                }
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container position-relative">

            <button class="navbar-toggler border-0 px-1" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <a class="navbar-logo custom-mobile-logo" href="/">
                <img src="~/images/AnyeLabel/logo.png" class="img-fluid logo-img" alt="Anye Label" />
            </a>

            <div class="d-flex align-items-center gap-3 ms-auto order-lg-last" style=" margin-right: 1%;">

                @*<div class="cerca-container" id="searchContainer">
                        <input type="text" class="cerca-input" placeholder="Cerca il tuo stile...">
                        <i class="fas fa-search cerca-icon" onclick="toggleSearch()"></i>
                    </div>*@

                <div class="user-dropdown-container">
                    <a href="#" class="text-dark hover-specialissimo" style="font-size: 1.2rem;" onclick="toggleUserMenu(event)">
                        <i class="far fa-user"></i>
                    </a>

                    <div class="user-dropdown-menu" id="userMenu">
                        @if (HttpContext.Current.Request.Cookies["ForrestUser"] == null)
                        {
                            <div class="user-greeting">
                                Benvenuto!
                                <span>Accedi o Registrati</span>
                            </div>
                            <a href="@Url.Action("Login", "login")" class="user-dropdown-item">
                                <i class="fas fa-sign-in-alt"></i> @Resources.labels.Accedi
                            </a>
                            <a href="@Url.Action("Registrazione", "login")" class="user-dropdown-item">
                                <i class="fas fa-user-plus"></i> @Resources.labels.Registrati
                            </a>
                        }
                        else
                        {
                            var userNome = HttpContext.Current.Request.Cookies["ForrestUser"]["Nome"];
                            var userCognome = HttpContext.Current.Request.Cookies["ForrestUser"]["Cognome"];
                            var userId = HttpContext.Current.Request.Cookies["ForrestUser"]["IdUtente"];

                            <div class="user-greeting">
                                Ciao,
                                <span>@userNome.ToUpper() @userCognome.ToUpper()</span>
                            </div>

                            <a href="@Url.Action("Profilo", "Login", new {
                                id = userId,
                                titolo = (userNome + "-" + userCognome).ToLower()
                            })" class="user-dropdown-item">
                                <i class="fas fa-user-circle"></i> @Resources.labels.Profilo
                            </a>
                            <div class="user-dropdown-divider"></div>

                            <a href="@Url.Action("Logout", "login")" class="user-dropdown-item text-danger">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        }
                    </div>
                </div>

                <a href="javascript:void(0)" onclick="openSideCart()" class="text-dark cart-container" style="font-size: 1.2rem;">
                    <i class="fas fa-shopping-bag"></i>
