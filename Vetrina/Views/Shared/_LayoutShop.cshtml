<body>
    <!-- Navbar Unificata -->
    <nav class="main-navbar" id="mainNavbar">
        <!-- Prima Riga: Logo | Menu Centrale | User/Search/Carrello -->
        <div class="navbar-top-row" id="navbarTopRow">
            <div class="navbar-logo" onclick="Home()">
                <img id="logoNav" src="~/Images/Plex/logo-navbar-footer.png" class="img-fluid" alt="Logo" />
            </div>

            <div class="top-nav-center d-none d-xl-flex">
                <a class="nav-link" href="/" data-target="heroSection">HOME</a>
                @*<a class="nav-link" href="/" data-target="progetti">PROGETTI</a>*@
                <a class="nav-link" href="@Url.Action("AllProducts","ecommerce")" data-target="shop">SHOP</a>
                @*<a class="nav-link" href="/" data-target="blog">BLOG</a>*@
                <a class="nav-link" href="@Url.Action("Contatti","ecommerce")" data-target="contattaci">CONTATTI</a>
            </div>

            <div class="top-nav-right" style="">

                @if (HttpContext.Current.Request.Cookies["ForrestUser"] == null)
                {
                    <div class="dropdown" id="userIcon">
                        <button class="dropbtn">
                            <span class="nav-link">
                                <span class="material-symbols-outlined">account_circle</span>
                            </span>
                        </button>
                        <div class="dropdown-content">
                            <a href="@Url.Action("Registrazione", "login")" class="nav-link log">@Resources.labels.Registrati.ToUpper()</a>
                            <a href="@Url.Action("Login", "login")" class="nav-link log">@Resources.labels.Accedi.ToUpper()</a>
                        </div>
                    </div>
                }
                else
                {
                    var userNome = HttpContext.Current.Request.Cookies["ForrestUser"]["Nome"];
                    var userCognome = HttpContext.Current.Request.Cookies["ForrestUser"]["Cognome"];

                    <!-- Nome Utente (solo desktop) -->
                    <a href="@Url.Action("Profilo", "Login")/@HttpContext.Current.Request.Cookies["ForrestUser"]["IdUtente"]/@HttpContext.Current.Request.Cookies["ForrestUser"]["Nome"]-@HttpContext.Current.Request.Cookies["ForrestUser"]["Cognome"]" class="nav-link forrest-user d-none d-xl-block">
                        @userNome.ToUpper() @userCognome.ToUpper()
                    </a>

                    <!-- Logout Icon (tutti gli schermi) -->
                    <div class="dropdown" id="userIcon">
                        <button class="dropbtn">
                            <span class="nav-link">
                                <span class="material-symbols-outlined">logout</span>
                            </span>
                        </button>
                        <div class="dropdown-content">
                            <a href="@Url.Action("Profilo", "Login")/@HttpContext.Current.Request.Cookies["ForrestUser"]["IdUtente"]/@HttpContext.Current.Request.Cookies["ForrestUser"]["Nome"]-@HttpContext.Current.Request.Cookies["ForrestUser"]["Cognome"]" class="nav-link forrest-user">
                                @Resources.labels.Profilo.ToUpper()
                            </a>
                            <a href="@Url.Action("Logout", "login")" class="nav-link">LOGOUT</a>
                        </div>
                    </div>
                }

                <!-- Carrello -->
                <a href="@Url.Action("carrello", "ecommerce")" class="nav-link cart-icon">
                    <img src="~/images/Plex/carrello.png" style="height: 40px; " />
                    <span class="qta" id="cartItemCount"></span>
                </a>

