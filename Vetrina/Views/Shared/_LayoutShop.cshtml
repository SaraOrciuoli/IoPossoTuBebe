    <script>
        $(function () {
            $(".categoriaDropdown").change(function () {
                var categoriaId = $(this).val();
                var dropdown = $(this).closest('.row').find('.sottocategorieDropdown');

                if (categoriaId) {
                    $.ajax({
                        url: '@Url.Action("VerificaSottocategorie", "Ecommerce")',
                        type: 'GET',
                        data: { categoriaId: categoriaId },
                        success: function (response) {
                            dropdown.empty();
                            dropdown.append($('<option>').text("Seleziona una sottocategoria").attr('value', ''));
                            $.each(response.sottocategorieSelectList, function (i, item) {
                                dropdown.append($('<option>').text(item.Text).attr('value', item.Value));
                            });
                        }
                    });
                } else {
                    dropdown.empty();
                    dropdown.append($('<option>').text("Seleziona una sottocategoria").attr('value', ''));
                }
            });
        });
    </script>
