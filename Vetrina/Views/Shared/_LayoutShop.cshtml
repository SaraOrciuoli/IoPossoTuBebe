    <script>
        document.getElementById('search-icon').addEventListener('click', function () {
            var searchInput = document.getElementById('search-input');
            if (searchInput.style.display === 'none') {
                searchInput.style.display = 'inline-block';
                searchInput.focus();
            } else {
                searchInput.style.display = 'none';
            }
        });

      function searchCategories() {
            var searchInput = document.getElementById('search-input').value.toLowerCase();
            var searchResults = document.getElementById('search-results');
            searchResults.innerHTML = '';

            var categoriesData = JSON.parse(searchResults.getAttribute('data-categories'));
            if (categoriesData && searchInput.trim() !== '') {
               categoriesData.listaCategorie.forEach(function(cat) {
                    var categoryName = cat.Descrizione ? cat.Descrizione.toLowerCase() : (cat.Descrizione_eng ? cat.Descrizione_eng.toLowerCase() : "");
                    if (categoryName.includes(searchInput)) {
                        var categoryLink = '@Url.Action("Categoria", "Ecommerce", new { id = "CAT_ID", titolo = "CAT_TITOLO" })'
                            .replace("CAT_ID", cat.id_categorie)
                            .replace("CAT_TITOLO", cat.Descrizione ? cat.Descrizione.toLowerCase().replace("%20", "-") : "");
                        var categoryHtml = '<a href="' + categoryLink + '" class="dropdown-item">' + categoryName + '</a>';
                        searchResults.innerHTML += categoryHtml;

                        // Salva l'ID della categoria corrente per usarlo nelle sottocategorie
                        var currentCategoryId = cat.id_categorie;

                        categoriesData.ListaSottocategorie.forEach(function (subcat) {
                            var subcategoryName = subcat.Nome ? subcat.Nome.toLowerCase() : "";
                            if (subcategoryName.includes(searchInput)) {
                                var subcategoryLink = '@Url.Action("Sottocategoria", "Ecommerce", new { id = "SUBCAT_ID", titolo = "SUBCAT_TITOLO", categoriaId = "CATEGORIA_ID" })'
                                    .replace("SUBCAT_ID", subcat.id_sottocategoria)
                                    .replace("SUBCAT_TITOLO", subcat.Nome ? subcat.Nome.toLowerCase().replace(/\s/g, "-") : "")
                                    .replace("CATEGORIA_ID", currentCategoryId);
                                var subcategoryHtml = '<a href="' + subcategoryLink + '" class="dropdown-item">' + subcategoryName + '</a>';
                                searchResults.innerHTML += subcategoryHtml;
                            }
                        });
                    }
               });

                categoriesData.listaProdotti.forEach(function (prod) {
                    var productName = prod.Descrizione ? prod.Descrizione.toLowerCase() : (prod.Descrizioneprod.Descrizione ? prod.Descrizione.toLowerCase() : "");
                    if (productName.includes(searchInput)) {
                        var encodedTitle = encodeURIComponent(prod.Descrizione ? prod.Descrizione.toLowerCase().replace(/\s/g, "-") : "");
                        encodedTitle = encodedTitle.replace(/%25/g, "-");
                        var productLink = '/ecommerce/Prodotto/' + prod.id_prodotto + '/' + encodedTitle;
                        var productHtml = '<a href="' + productLink + '" class="dropdown-item">' + productName + '</a>';
                        searchResults.innerHTML += productHtml;
                    }
                });

            }

            if (searchResults.innerHTML.trim() !== '') {
                searchResults.style.display = 'block';
            } else {
                searchResults.style.display = 'none';
            }
        }


        document.addEventListener('click', function (event) {
            var searchResultsContainer = document.getElementById('search-results-container');
            if (event.target !== searchResultsContainer && !searchResultsContainer.contains(event.target)) {
                var searchResults = document.getElementById('search-results');
                searchResults.style.display = 'none';
            }
        });


    </script>
