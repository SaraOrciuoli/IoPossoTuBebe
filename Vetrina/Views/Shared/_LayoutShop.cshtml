        // Funzione per mostrare/nascondere le sottocategorie nella sidebar mobile
        function toggleSubcategories(subcategoryId) {
            var subcategories = document.getElementById(subcategoryId);
            var toggleIcon = event.currentTarget.querySelector('.mobile-category-toggle');

            if (subcategories.style.display === 'block') {
                subcategories.style.display = 'none';
                toggleIcon.classList.remove('rotated');
            } else {
                subcategories.style.display = 'block';
                toggleIcon.classList.add('rotated');
            }
        }
