@model Vetrina.Models.CustomModel.LoginModel
@{
    ViewBag.Title = "Errore";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --uptest-dark: #1b365d;
        --uptest-blue: #577399;
        --uptest-mid-blue: #86a6c4;
        --uptest-light: #eef4f9;
        --error-red: #e74c3c;
        --error-light: #fdedec;
    }

    body {
        background: linear-gradient(135deg, #e4eff8 0%, #ffffff 100%);
        min-height: 100vh;
        font-family: 'Poppins', sans-serif;
        display: flex;
        flex-direction: column;
        margin: 0;
    }

    .error-container {
        text-align: center;
        padding: 60px 20px;
        width: 100%;
        margin-top: 50px;
    }

    .error-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-radius: 30px;
        padding: 60px 40px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        border: 1px solid rgba(255,255,255,0.6);
        max-width: 600px;
        margin: 0 auto;
    }

    .logo-error {
        max-width: 160px;
        margin-bottom: 30px;
    }

    .error-icon {
        width: 90px;
        height: 90px;
        background: var(--error-light);
        color: var(--error-red);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 25px auto;
        box-shadow: 0 10px 30px rgba(231, 76, 60, 0.2);
    }

    .error-title {
        font-weight: 800;
        color: var(--uptest-dark);
        font-size: 2rem;
        margin-bottom: 15px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .error-text {
        color: #666;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    .btn-return-home {
        background-color: var(--uptest-dark);
        color: #ffffff;
        border: none;
        border-radius: 30px;
        padding: 15px 40px;
        font-size: 1.1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-return-home:hover {
            background-color: var(--uptest-blue);
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(87, 115, 153, 0.3);
        }
</style>

<div class="container error-container">
    <div class="error-card">

        <div class="error-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>

        <h1 class="error-title">Si è verificato un errore</h1>
        <p class="error-text">
            Qualcosa è andato storto durante l'elaborazione della tua richiesta.<br />
            Ti preghiamo di riprovare tra qualche istante.
        </p>

        <a href="@Url.Action("Index", "Home")" class="btn-return-home">
            <i class="fas fa-home ms-1 me-2"></i> Torna alla Home
        </a>
    </div>
</div>