@{
    ViewBag.Title = "Ordine in Attesa di Bonifico";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #fdfbfb 0%, #fcefe9 50%, #e8f4f8 100%);
        min-height: 100vh;
        margin-top: 150px;
        font-family: 'Lato', sans-serif;
    }

    .success-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        text-align: center;
    }

    .success-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-radius: 30px;
        padding: 50px 40px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        border: 1px solid rgba(255,255,255,0.6);
        max-width: 800px;
        width: 100%;
    }

    .success-icon {
        width: 100px;
        height: 100px;
        background: #fff8e1;
        color: #f39c12; /* Giallo/Arancio per "in attesa" */
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin: 0 auto 30px auto;
        box-shadow: 0 10px 30px rgba(243, 156, 18, 0.2);
    }

    .success-title {
        font-weight: 800;
        color: #2c3e50;
        font-size: 2.2rem;
        margin-bottom: 15px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .success-text {
        color: #666;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    /* Tabella Dati Bonifico */
    .bank-details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        background: #f8f9fa;
        padding: 30px;
        border-radius: 20px;
        border: 1px solid #eaeaea;
        margin-bottom: 40px;
        text-align: left;
    }

    .bank-detail-item {
        background: white;
        padding: 15px 20px;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.02);
    }

    .bank-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #95a5a6;
        text-transform: uppercase;
        margin-bottom: 5px;
        display: block;
    }

    .bank-value {
        font-size: 1.1rem;
        font-weight: 800;
        color: #2c3e50;
        margin: 0;
        word-break: break-all;
    }

    .btn-return-home {
        background-color: #2c3e50;
        color: #ffffff;
        border: none;
        border-radius: 30px;
        padding: 15px 40px;
        font-size: 1.1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-return-home:hover {
            background-color: #1a252f;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(44, 62, 80, 0.2);
        }

    @@media (max-width: 768px) {
        .bank-details-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container success-container" data-aos="zoom-in">
    <div class="success-card">
        <div class="success-icon">
            <i class="fas fa-university"></i>
        </div>

        <h1 class="success-title">@Resources.labels.OrdineInviato</h1>
        <p class="success-text">
            @Resources.labels.GrazieBonificoPar <br />
            L'ordine verrà evaso non appena riceveremo l'accredito sul nostro conto corrente.
        </p>

        <div class="bank-details-grid">
            <div class="bank-detail-item">
                <span class="bank-label">Intestatario</span>
                <p class="bank-value">@System.Configuration.ConfigurationManager.AppSettings["Intestatario"]</p>
            </div>

            <div class="bank-detail-item">
                <span class="bank-label">Nome Banca</span>
                <p class="bank-value">@System.Configuration.ConfigurationManager.AppSettings["NomeBanca"]</p>
            </div>

            <div class="bank-detail-item" style="grid-column: 1 / -1;">
                <span class="bank-label">IBAN</span>
                <p class="bank-value" style="color: #8B0000; font-size: 1.3rem;">@System.Configuration.ConfigurationManager.AppSettings["IBAN"]</p>
            </div>

            <div class="bank-detail-item" style="grid-column: 1 / -1;">
                <span class="bank-label">Causale</span>
                <p class="bank-value">Il tuo Numero Ordine</p>
            </div>
        </div>

        <a href="@Url.Action("Index", "ecommerce")" class="btn-return-home">
            @Resources.labels.TornaHome.ToUpper()
        </a>
    </div>
</div>