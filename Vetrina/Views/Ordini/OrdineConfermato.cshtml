@{
    ViewBag.Title = "Ordine Confermato";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #fdfbfb 0%, #fcefe9 50%, #e8f4f8 100%);
        min-height: 100vh;
        margin-top: 150px;
        font-family: 'Lato', sans-serif;
    }

    .success-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        text-align: center;
    }

    .success-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-radius: 30px;
        padding: 60px 40px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        border: 1px solid rgba(255,255,255,0.6);
        max-width: 600px;
        width: 100%;
    }

    .success-icon {
        width: 100px;
        height: 100px;
        background: #e8f8f5;
        color: #20c997;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin: 0 auto 30px auto;
        box-shadow: 0 10px 30px rgba(32, 201, 151, 0.2);
    }

    .success-title {
        font-weight: 800;
        color: #2c3e50;
        font-size: 2.2rem;
        margin-bottom: 15px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .success-text {
        color: #666;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    .btn-return-home {
        background-color: #2c3e50;
        color: #ffffff;
        border: none;
        border-radius: 30px;
        padding: 15px 40px;
        font-size: 1.1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-return-home:hover {
            background-color: #1a252f;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(44, 62, 80, 0.2);
        }

    .spam-notice {
        font-size: 0.9rem;
        color: #95a5a6;
        margin-top: 30px;
        font-weight: 600;
    }
</style>

<div class="container success-container" data-aos="zoom-in">
    <div class="success-card">
        <div class="success-icon">
            <i class="fas fa-check"></i>
        </div>

        <h1 class="success-title">@Resources.labels.OrdineConfermato</h1>
        <p class="success-text">@Resources.labels.GrazieOrdine</p>

        <a href="@Url.Action("Index", "ecommerce")" class="btn-return-home">
            @Resources.labels.TornaHome.ToUpper()
        </a>

        <p class="spam-notice">
            <i class="fas fa-info-circle"></i> Ti abbiamo inviato un'email di conferma. Se non la vedi, controlla la cartella SPAM.
        </p>
    </div>
</div>