@{
    ViewBag.Title = "Pagamento Annullato";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 text-center">
            <div style="background: rgba(255, 255, 255, 0.95); border-radius: 24px; padding: 50px 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.05); border: 1px solid rgba(255,255,255,0.6);">
                <i class="fas fa-times-circle" style="font-size: 5rem; color: #ffc107; margin-bottom: 20px;"></i>
                <h2 style="font-weight: 800; color: #2c3e50; text-transform: uppercase;">Pagamento Interrotto</h2>
                <p class="text-muted fs-5 mt-3 mb-4">Hai annullato la procedura di pagamento con Klarna. Il tuo ordine è in sospeso, puoi riprovare o scegliere un altro metodo di pagamento.</p>
                @*<a href="@Url.Action("Pagamento", "Ordini")" class="btn btn-outline-custom btn-custom" style="background-color: #2c3e50; color: white; border-radius: 30px; padding: 12px 40px; font-weight: 700; text-transform: uppercase;">Riprova Pagamento</a>*@
            </div>
        </div>
    </div>
</div>