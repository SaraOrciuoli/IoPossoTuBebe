<script>
    document.addEventListener("DOMContentLoaded", () => {
        const container = document.getElementById('flower-container');
        if (!container) return;

        // Palette di colori mantenuta (celeste, azzurro, blu chiaro)
        const colors = ['text-sky-400', 'text-blue-400', 'text-cyan-300', 'text-sky-300', 'text-blue-300'];
        const numFlowers = 25; // Quantità di margherite generate

        for (let i = 0; i < numFlowers; i++) {
            const flower = document.createElement('div');

            // Dimensione casuale (tra 1.5 e 4 rem)
            const size = Math.random() * 2.5 + 1.5;
            const colorClass = colors[Math.floor(Math.random() * colors.length)];

            // Impostiamo il fiore al centro. pointer-events-auto permette l'hover sul singolo fiore
            flower.className = `absolute top-1/2 left-1/2 transition-all ease-out pointer-events-auto select-none ${colorClass}`;
            flower.style.fontSize = `${size}rem`;
            flower.style.textShadow = '0 0 12px currentColor';
            flower.innerHTML = '✿';

            // Stato iniziale: invisibile, piccolo, al centro
            flower.style.opacity = '0';
            flower.style.transform = 'translate(-50%, -50%) scale(0) rotate(0deg)';

            // Durata dell'animazione del colpo di vento casuale per ogni fiore
            const duration = 1500 + Math.random() * 1500;
            flower.style.transitionDuration = `${duration}ms`;

            container.appendChild(flower);

            // Calcola la posizione finale casuale dopo il caricamento
            let targetLeft = 5 + Math.random() * 90; // Tra il 5% e il 95% della larghezza
            let targetTop = 5 + Math.random() * 90;  // Tra il 5% e il 95% dell'altezza
            let targetRot = (Math.random() - 0.5) * 360; // Rotazione iniziale
            const finalOpacity = Math.random() * 0.4 + 0.3; // Trasparenza casuale (tra 0.3 e 0.7) per non disturbare la lettura

            // Distribuzione automatica (colpo di vento inziale)
            setTimeout(() => {
                flower.style.left = `${targetLeft}%`;
                flower.style.top = `${targetTop}%`;
                flower.style.opacity = finalOpacity;
                flower.style.transform = `translate(-50%, -50%) scale(1) rotate(${targetRot}deg)`;
            }, 600 + (Math.random() * 800)); // I fiori partono in momenti leggermente sfalsati

            // Interazione allo spostamento del mouse (Hover)
            flower.addEventListener('mouseenter', () => {
                // Animazione più rapida per lo scatto
                flower.style.transitionDuration = '600ms';

                // Spostamento casuale (+/- 15%)
                const moveX = (Math.random() - 0.5) * 30;
                const moveY = (Math.random() - 0.5) * 30;

                targetLeft += moveX;
                targetTop += moveY;

                // Effetto "muro": se il fiore prova ad uscire dallo schermo, rimbalza verso il centro
                if (targetLeft < 5) targetLeft = 15;
                if (targetLeft > 95) targetLeft = 85;
                if (targetTop < 5) targetTop = 15;
                if (targetTop > 95) targetTop = 85;

                // Gira mentre si sposta
                targetRot += (Math.random() - 0.5) * 180;

                // Si illumina, si ingrandisce leggermente e si sposta
                flower.style.left = `${targetLeft}%`;
                flower.style.top = `${targetTop}%`;
                flower.style.transform = `translate(-50%, -50%) scale(1.3) rotate(${targetRot}deg)`;
                flower.style.opacity = '0.9';
                flower.style.zIndex = '20';

                // Ritorna tranquillo dopo essersi spostato
                setTimeout(() => {
                    flower.style.transitionDuration = '1200ms';
                    flower.style.transform = `translate(-50%, -50%) scale(1) rotate(${targetRot}deg)`;
                    flower.style.opacity = finalOpacity;
                    flower.style.zIndex = '0';
                }, 600);
            });
        }
    });
    document.addEventListener("DOMContentLoaded", () => {

        // FUNZIONE PER GENERARE I FIORI
        function createInteractiveFlowers(containerId, colorPalette, numFlowers) {
            const container = document.getElementById(containerId);
            if (!container) return;

            for (let i = 0; i < numFlowers; i++) {
                const flower = document.createElement('div');

                // Dimensione casuale (tra 1.5 e 4 rem)
                const size = Math.random() * 2.5 + 1.5;
                const colorClass = colorPalette[Math.floor(Math.random() * colorPalette.length)];

                // Impostiamo il fiore al centro. pointer-events-auto permette l'hover
                flower.className = `absolute top-1/2 left-1/2 transition-all ease-out pointer-events-auto select-none ${colorClass}`;
                flower.style.fontSize = `${size}rem`;
                flower.style.textShadow = '0 0 12px currentColor';
                flower.innerHTML = '✿';

                // Stato iniziale: invisibile, piccolo, al centro
                flower.style.opacity = '0';
                flower.style.transform = 'translate(-50%, -50%) scale(0) rotate(0deg)';

                // Durata dell'animazione iniziale casuale
                const duration = 1500 + Math.random() * 1500;
                flower.style.transitionDuration = `${duration}ms`;

                container.appendChild(flower);

                // Calcola la posizione finale casuale
                let targetLeft = 5 + Math.random() * 90;
                let targetTop = 5 + Math.random() * 90;
                let targetRot = (Math.random() - 0.5) * 360;
                const finalOpacity = Math.random() * 0.5 + 0.4;

                // Distribuzione iniziale
                setTimeout(() => {
                    flower.style.left = `${targetLeft}%`;
                    flower.style.top = `${targetTop}%`;
                    flower.style.opacity = finalOpacity;
                    flower.style.transform = `translate(-50%, -50%) scale(1) rotate(${targetRot}deg)`;
                }, 600 + (Math.random() * 800));

                // Interazione Hover (fugge via)
                flower.addEventListener('mouseenter', () => {
                    flower.style.transitionDuration = '600ms';

                    const moveX = (Math.random() - 0.5) * 30;
                    const moveY = (Math.random() - 0.5) * 30;

                    targetLeft += moveX;
                    targetTop += moveY;

                    // Effetto rimbalzo ai bordi
                    if (targetLeft < 5) targetLeft = 15;
                    if (targetLeft > 95) targetLeft = 85;
                    if (targetTop < 5) targetTop = 15;
                    if (targetTop > 95) targetTop = 85;

                    targetRot += (Math.random() - 0.5) * 180;

                    flower.style.left = `${targetLeft}%`;
                    flower.style.top = `${targetTop}%`;
                    flower.style.transform = `translate(-50%, -50%) scale(1.3) rotate(${targetRot}deg)`;
                    flower.style.opacity = '0.9';
                    flower.style.zIndex = '20';

                    setTimeout(() => {
                        flower.style.transitionDuration = '1200ms';
                        flower.style.transform = `translate(-50%, -50%) scale(1) rotate(${targetRot}deg)`;
                        flower.style.opacity = finalOpacity;
                        flower.style.zIndex = '0';
                    }, 600);
                });
            }
        }

        // INIZIALIZZA I FIORI SOLO PER LA SEZIONE FILOSOFIA
        const filosofiaColors = ['text-pink-400', 'text-rose-400', 'text-orange-400', 'text-amber-400', 'text-yellow-400'];
        createInteractiveFlowers('flower-container-filosofia', filosofiaColors, 30);

    });
    document.addEventListener("DOMContentLoaded", () => {
        const wrapper = document.getElementById('merch-scroll-wrapper');
        const container = document.getElementById('merch-carousel-container'); // Ora tracciamo l'hover qui
        const set1 = document.getElementById('merch-set-1');

        if (!wrapper || !set1 || !container) return;

        let isDown = false;
        let startX;
        let scrollLeft;
        let autoScrollInterval;
        const scrollSpeed = 0.8; // Velocità dell'auto-scroll
        let isHovered = false;
        let isManualScrolling = false; // Flag per evitare conflitti coi click manuali

        // Funzione per l'auto-scroll infinito
        function startAutoScroll() {
            autoScrollInterval = requestAnimationFrame(autoScroll);
        }

        function stopAutoScroll() {
            cancelAnimationFrame(autoScrollInterval);
        }

        function autoScroll() {
            // Scorre solo se non siamo col mouse sopra, non stiamo trascinando, e non abbiamo cliccato le frecce
            if (!isHovered && !isDown && !isManualScrolling) {
                wrapper.scrollLeft += scrollSpeed;

                // Gestione loop infinito
                if (wrapper.scrollLeft >= set1.offsetWidth) {
                    wrapper.scrollLeft -= set1.offsetWidth;
                }
            }
            autoScrollInterval = requestAnimationFrame(autoScroll);
        }

        startAutoScroll();

        // Metti in pausa quando il mouse o il tocco è sopra a TUTTA la striscia (frecce comprese)
        container.addEventListener('mouseenter', () => isHovered = true);
        container.addEventListener('mouseleave', () => isHovered = false);
        container.addEventListener('touchstart', () => isHovered = true, { passive: true });
        container.addEventListener('touchend', () => {
            setTimeout(() => isHovered = false, 1500); // Riprende dopo 1.5s su mobile
        }, { passive: true });

        // --- Logica per il DRAG & DROP (Trascinamento col mouse o dito) ---
        wrapper.addEventListener('mousedown', (e) => {
            isDown = true;
            wrapper.classList.add('cursor-grabbing');
            wrapper.classList.remove('cursor-grab');
            startX = e.pageX - wrapper.offsetLeft;
            scrollLeft = wrapper.scrollLeft;
            stopAutoScroll();
        });

        wrapper.addEventListener('mouseleave', () => {
            if (!isDown) return;
            isDown = false;
            wrapper.classList.remove('cursor-grabbing');
            wrapper.classList.add('cursor-grab');
            startAutoScroll();
        });

        wrapper.addEventListener('mouseup', () => {
            isDown = false;
            wrapper.classList.remove('cursor-grabbing');
            wrapper.classList.add('cursor-grab');
            startAutoScroll();
        });

        wrapper.addEventListener('mousemove', (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - wrapper.offsetLeft;
            const walk = (x - startX) * 2; // Moltiplicatore velocità trascinamento
            wrapper.scrollLeft = scrollLeft - walk;

            // Gestione loop durante il trascinamento manuale
            if (wrapper.scrollLeft >= set1.offsetWidth) {
                wrapper.scrollLeft -= set1.offsetWidth;
                scrollLeft -= set1.offsetWidth;
            } else if (wrapper.scrollLeft <= 0) {
                wrapper.scrollLeft += set1.offsetWidth;
                scrollLeft += set1.offsetWidth;
            }
        });

        // --- Funzione Globale per i Pulsanti Laterali ---
        window.scrollMerchManual = function (direction) {
            if (isManualScrolling) return; // Evita di cliccare a raffica creando glitch

            isManualScrolling = true; // Pausa l'autoscroll

            // Larghezza di spostamento (una card + margine)
            const scrollAmount = 350;

            // Avvia lo scroll fluido nativo
            wrapper.scrollBy({
                left: direction * scrollAmount,
                behavior: 'smooth'
            });

            // Aspetta che l'animazione smooth finisca prima di riattivare o resettare il loop
            setTimeout(() => {
                if (wrapper.scrollLeft >= set1.offsetWidth) {
                    wrapper.style.scrollBehavior = 'auto'; // Togli animazione momentaneamente
                    wrapper.scrollLeft -= set1.offsetWidth; // Teletrasporto
                    void wrapper.offsetWidth; // Forza applicazione
                    wrapper.style.scrollBehavior = ''; // Rimetti standard
                } else if (wrapper.scrollLeft <= 0 && direction === -1) {
                    wrapper.style.scrollBehavior = 'auto';
                    wrapper.scrollLeft += set1.offsetWidth;
                    void wrapper.offsetWidth;
                    wrapper.style.scrollBehavior = '';
                }

                isManualScrolling = false; // Riattiva l'autoscroll
            }, 500); // 500ms è il tempo che ci mette il browser per completare 'behavior: smooth'
        };
    });
</script>
