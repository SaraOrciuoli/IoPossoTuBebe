@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_LayoutEcommerce.cshtml"; // Decommenta se necessario nel tuo setup
}

@section Styles {
    <style>
        /* Animazione morbida per l'hero image */
        .hero-image-anim {
            animation: float-elegant 8s ease-in-out infinite;
        }
         @@keyframes scroll-infinite {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); } /* Scorre esattamente della metà (ovvero un set intero di card) */
        }
        .animate-infinite-scroll {
            display: flex;
            width: max-content;
            animation: scroll-infinite 35s linear infinite; /* 35s è la velocità. Aumenta per rallentare */
        }
        /* Mette in pausa l'animazione quando l'utente passa sopra col mouse o tocca */
        .wrapper-scroll:hover .animate-infinite-scroll,
        .wrapper-scroll:active .animate-infinite-scroll {
            animation-play-state: paused;
        }
        /* Nascondiamo la scrollbar nativa per pulizia */
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        @@keyframes float-elegant {
            0%, 100% {
                transform: translateY(0) scale(1);
            }

            50% {
                transform: translateY(-15px) scale(1.02);
            }
        }

        /* Effetto sfocatura per i cerchi di sfondo */
        .glow-circle {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            z-index: 0;
            opacity: 0.5;
        }

        /* Stile per i bottoni premium - Nuova tonalità Azzurra */
        .btn-premium {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%); /* Tailwind Sky-500 to Sky-600 */
            box-shadow: 0 10px 20px -5px rgba(14, 165, 233, 0.4);
            transition: all 0.3s ease;
        }

            .btn-premium:hover {
                box-shadow: 0 15px 25px -5px rgba(14, 165, 233, 0.5);
                transform: translateY(-2px);
            }
    </style>
}

<!-- Hero Section Prorompente & Sofisticata (Sfondo azzurro più carico) -->
