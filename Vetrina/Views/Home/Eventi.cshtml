    <div class="row text">
        <div class="col-md-3">

        </div>
        <div class="col-md-6">


            <h2 class="title text-center">RICHIEDI INFORMAZIONI</h2>
            @using (Html.BeginForm("InviaMail", "Home", FormMethod.Post))
            {
                <div class="form-group">
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)

                    @Html.TextBoxFor(m => m.Nome, new { @class = "form-control", type = "text", placeholder = "Nome", required = true })
                    @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", type = "number", placeholder = "Telefono", required = true })
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", placeholder = "E-mail", required = true })
                    @Html.TextAreaFor(m => m.Messaggio, new { @class = "form-control", type = "text", rows = "10", placeholder = "Messaggio", required = true })

                </div>
                <div class="text-center">
                    <button type="submit" class="btn">INVIA</button>
                </div>
            }

        </div>

        <div class="col-md-3">

        </div>
    </div>
