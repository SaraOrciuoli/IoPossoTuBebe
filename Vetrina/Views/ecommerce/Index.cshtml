        </div>
    </div>
</section>

<script>
    window.addEventListener('scroll', function () {
        const scrollY = window.scrollY;
        const bannerOverlay = document.getElementById('bannerOverlay');
        let opacity = Math.min(scrollY / 600, 1);

        if (bannerOverlay) {
            bannerOverlay.style.opacity = opacity;
        }
    });
</script>