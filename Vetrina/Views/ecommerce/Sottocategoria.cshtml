@model Vetrina.Models.CustomModel.CombinedViewModel
@using System.Configuration

@{
    string title = string.Empty;
    if (Model.MenuModel != null && !string.IsNullOrEmpty(Model.MenuModel.nomeCategoria))
    {
        if (System.Threading.Thread.CurrentThread.CurrentUICulture.Name.ToLower().StartsWith("en"))
        {
            title = Model.MenuModel.nomeCategoriaEng?.ToUpper().Replace("-", " ") ?? "SUBCATEGORY";
        }
        else
        {
            title = Model.MenuModel.nomeCategoria.ToUpper().Replace("-", " ");
        }
    }
    ViewBag.Title = title;
    var pathFotoLocale = ConfigurationManager.AppSettings["pathFotoLocale"];
    // Layout = "~/Views/Shared/_LayoutShop.cshtml";
}

<style>
    /* =========================================
       ANIMAZIONI
       ========================================= */
    @@keyframes fadeUp {
        0% {
            opacity: 0;
            transform: translateY(50px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInRight {
        0% {
            opacity: 0;
            transform: translateX(50px);
        }

        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    body {
        background: linear-gradient(180deg, #ffffff 20%, #efe7fc 90%, #ffffff 100%);
        min-height: 100vh;
    }

    /* =========================================
       BREADCRUMB
       ========================================= */
    .custom-breadcrumb {
        display: flex;
        align-items: center;
        justify-content: center;
        list-style: none;
        padding: 20px 0;
        margin: 0;
        background: transparent;
        font-size: 1.1rem;
        font-weight: 600;
        color: #95a5a6;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .custom-breadcrumb li {
            display: flex;
            align-items: center;
        }

        .custom-breadcrumb a {
            color: #2c3e50;
            text-decoration: none;
            transition: color 0.3s;
        }

            .custom-breadcrumb a:hover {
                color: #c0a16b;
            }

        .custom-breadcrumb .separator {
            margin: 0 15px;
            color: #ccc;
        }

        .custom-breadcrumb .active {
            color: #c0a16b;
        }

    /* =========================================
       HERO SECTION (SPLIT 60/40)
       ========================================= */
    .category-hero {
        position: relative;
        width: 100%;
        height: 60vh;
        min-height: 450px;
        display: flex;
        align-items: center;
        background-color: #e0e7ef;
        overflow: hidden;
    }

    .hero-image-wrapper {
        width: 60%;
        height: 100%;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        position: relative;
    }

        .hero-image-wrapper::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            background: linear-gradient(to right, transparent 70%, rgba(248, 249, 250, 0.8) 100%);
        }

    .hero-text-wrapper {
        width: 45%;
        margin-left: -5%;
        z-index: 2;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0 40px;
    }

    .category-hero-box {
        backdrop-filter: blur(3px);
        -webkit-backdrop-filter: blur(15px);
        padding: 50px 40px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        text-align: left;
        animation: fadeUp 1s ease-out forwards;
        background: #e0e7ef2b;
    }

        .category-hero-box h1 {
            color: #8B0000;
            font-weight: 600;
            font-size: 2.5rem;
            margin-bottom: 20px;
            line-height: 1.1;
        }

        .category-hero-box p {
            color: #4a4a4a;
            font-size: 1.05rem;
            line-height: 1.7;
            margin-bottom: 30px;
        }

    .hero-btn-group {
        display: flex;
        gap: 15px;
    }

    .btn-hero-dark {
        background: #2c3e50;
        color: white;
        border-radius: 30px;
        padding: 12px 35px;
        text-transform: uppercase;
        font-weight: 600;
        font-size: 0.85rem;
        border: 2px solid #2c3e50;
        transition: all 0.3s;
        text-decoration: none;
    }

        .btn-hero-dark:hover {
            background: transparent;
            color: #2c3e50;
            transform: translateY(-3px);
        }

    .btn-hero-outline {
        background: transparent;
        color: #2c3e50;
        border-radius: 30px;
        padding: 12px 35px;
        text-transform: uppercase;
        font-weight: 600;
        font-size: 0.85rem;
        border: 2px solid #2c3e50;
        transition: all 0.3s;
        text-decoration: none;
    }

        .btn-hero-outline:hover {
            background: #2c3e50;
            color: white;
            transform: translateY(-3px);
        }

    /* =========================================
       PILLOLE SOTTOCATEGORIE (Più larghe e meno alte)
       ========================================= */
    .cat-pills-wrapper {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 25px;
        margin-top: 30px;
        margin-bottom: 50px;
        padding: 0 20px;
        position: relative;
        z-index: 3;
    }

    .cat-pill {
        background: #ffffff;
        display: flex;
        align-items: center;
        color: #2c3e50 !important;
        border-radius: 60px;
        /* MODIFICA: Meno padding sopra/sotto (5px), più padding a destra (40px) */
        padding: 5px 40px 5px 6px;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.05rem;
        text-transform: uppercase;
        /* MODIFICA: Larghezza minima aumentata */
        min-width: 260px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.05);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 2px solid transparent;
    }

        .cat-pill:hover {
            transform: translateY(-5px) scale(1.02);
        }

        .cat-pill img {
            /* MODIFICA: Immagine più piccola per ridurre l'altezza della pillola */
            width: 45px;
            height: 45px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            border: 2px solid white;
        }

    /* STATO HOVER NORMALE */
    .pill-dark {
        border: 2px solid #2c3e50
    }

        .pill-dark:hover {
            border-color: #2c3e50;
            box-shadow: 0 15px 35px rgba(44, 62, 80, 0.15);
            color: #2c3e50 !important;
        }

    .pill-brown {
        border: 2px solid #c49a6c
    }

        .pill-brown:hover {
            border-color: #c49a6c;
            box-shadow: 0 15px 35px rgba(196, 154, 108, 0.2);
            color: #c49a6c !important;
        }

    .pill-blue {
        border: 2px solid #5b8bd0
    }

        .pill-blue:hover {
            border-color: #5b8bd0;
            box-shadow: 0 15px 35px rgba(91, 139, 208, 0.2);
            color: #5b8bd0 !important;
        }

    /* =========================================
       STATO ATTIVO (Categoria Selezionata)
       ========================================= */
    .cat-pill.active-pill {
        transform: translateY(-5px) scale(1.05);
        color: #ffffff !important;
        box-shadow: 0 15px 30px rgba(0,0,0,0.15);
    }

        .cat-pill.active-pill img {
            /* MODIFICA: Ingrandita per staccare, ma meno di prima per mantenere la forma affusolata */
            width: 55px;
            height: 55px;
            margin-left: -4px; /* Fa sporgere leggermente la foto a sinistra */
            margin-right: 18px;
            border: 3px solid white;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

    /* Colori Sfondo per i bottoni ATTIVI */
    .pill-dark.active-pill {
        background-color: #2c3e50;
        border-color: white;
    }

    .pill-brown.active-pill {
        background-color: #c49a6c;
        border-color: white;
    }

    .pill-blue.active-pill {
        background-color: #5b8bd0;
        border-color: white;
    }
    /* =========================================
       TOOLBAR FILTRI
       ========================================= */
    .filter-toolbar {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        gap: 40px;
        margin-bottom: 40px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #2c3e50;
        text-transform: uppercase;
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .filter-select {
        border: 1px solid #e0e0e0;
        border-radius: 20px;
        padding: 8px 25px;
        outline: none;
        font-weight: 600;
        color: #2c3e50;
        background: white;
        cursor: pointer;
        transition: all 0.3s;
    }

        .filter-select:hover {
            border-color: #c0a16b;
        }

    .grid-icon {
        font-size: 1.2rem;
        color: #95a5a6;
        cursor: pointer;
        transition: color 0.3s;
    }

        .grid-icon:hover, .grid-icon.active {
            color: #2c3e50;
        }

    /* =========================================
       PRODUCT GRID & CARDS
       ========================================= */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        GAP: 50PX;
        padding: 0 5%;
        list-style: none;
        margin: 0;
    }

    .mockup-card {
        text-align: center;
        position: relative;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        width: 100%;
        transition: all 0.4s;
        padding-bottom: 10px;
        background: transparent;
        border-radius: 20px;
    }

        .mockup-card:hover {
            background: #ffffff;
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

    .card-badge {
        position: absolute;
        top: 20px;
        left: 30px;
        background: #5b8bd0;
        color: white;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        z-index: 2;
    }

    .card-heart {
        position: absolute;
        top: 20px;
        right: 30px;
        color: #95a5a6;
        font-size: 1.2rem;
        background: transparent;
        border: none;
        transition: color 0.3s;
        z-index: 2;
    }

        .card-heart:hover {
            color: #e74c3c;
        }

    .card-arrow {
        position: absolute;
        top: 45%;
        transform: translateY(-50%);
        width: 35px;
        height: 35px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        color: #333;
        opacity: 0;
        transition: opacity 0.3s, transform 0.3s;
        z-index: 2;
    }

    .card-arrow-left {
        left: 10px;
    }

    .card-arrow-right {
        right: 10px;
    }

    .mockup-card:hover .card-arrow {
        opacity: 1;
    }

    .card-arrow:hover {
        transform: translateY(-50%) scale(1.1);
        background: #2c3e50;
        color: white;
    }

    .card-img-wrapper {
        height: 80%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 25px;
    }

        .card-img-wrapper img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            mix-blend-mode: multiply;
            transition: transform 0.4s;
        }

    .mockup-card:hover .card-img-wrapper img {
        transform: scale(1.06);
    }

    .card-title {
        color: #2c3e50;
        font-weight: 600;
        font-size: 1.05rem;
        margin-bottom: 15px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .card-price-pill {
        background: #2c3e50;
        color: white;
        border-radius: 30px;
        display: inline-block;
        padding: 8px 30px;
        font-weight: 600;
        font-size: 1rem;
        margin: 0 auto;
        transition: background 0.3s;
    }

    .mockup-card:hover .card-price-pill {
        background: #8B0000;
    }

    /* PAGINAZIONE */
    .pagination-container {
        text-align: center;
        margin: 80px 0;
    }

    .page-info {
        display: inline-block;
        border-bottom: 2px solid #8B0000;
        padding-bottom: 5px;
        font-weight: 600;
        color: #333;
        margin-bottom: 20px;
    }

    .btn-load-more {
        display: block;
        width: max-content;
        margin: 0 auto;
        background: transparent;
        border: 2px solid #e0e0e0;
        border-radius: 30px;
        padding: 12px 40px;
        color: #2c3e50;
        font-weight: 600;
        transition: all 0.3s;
    }

        .btn-load-more:hover {
            border-color: #2c3e50;
            background: #2c3e50;
            color: white;
        }

    /* RESPONSIVE */
    @@media (max-width: 1200px) {
        .product-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 992px) {
        .category-hero {
            flex-direction: column;
            height: auto;
            padding-bottom: 40px;
            margin-top: 20px;
        }

        .hero-image-wrapper {
            width: 100%;
            height: 350px;
        }

        .hero-text-wrapper {
            width: 100%;
            margin-left: 0;
            margin-top: -50px;
            padding: 0 20px;
        }

        .category-hero-box {
            text-align: center;
        }

        .hero-btn-group {
            justify-content: center;
        }

        .product-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .custom-breadcrumb {
            padding: 0
        }
    }

    @@media (max-width: 576px) {
        .product-grid {
            grid-template-columns: 1fr;
        }

        .filter-toolbar {
            flex-direction: column;
            gap: 15px;
        }

        .cat-pills-wrapper {
            flex-direction: column;
            align-items: center;
            gap: 20px;
            margin-top: 20px;
        }

        .cat-pill {
            margin-left: 10px;
        }

        .hero-btn-group {
            flex-direction: column;
        }
    }
</style>

@if (System.Threading.Thread.CurrentThread.CurrentCulture.Name == "en-US" || System.Threading.Thread.CurrentThread.CurrentCulture.Name == "en")
{
    <ul class="custom-breadcrumb">
        <li><a href="@Url.Action("Categoria", "Ecommerce", new { id = Model.CategoriaPadre.id_categorie, titolo = Model.CategoriaPadre.Descrizione.Replace(" ", "-") })">@Model.CategoriaPadre.Descrizione_eng</a></li>
        <li class="separator"><i class="fas fa-chevron-right fa-xs"></i></li>
        <li class="active">@Model.MenuModel.nomeCategoriaEng</li>
    </ul>
}
else if (System.Threading.Thread.CurrentThread.CurrentCulture.Name == "it-IT" || System.Threading.Thread.CurrentThread.CurrentCulture.Name == "it")
{
    <ul class="custom-breadcrumb">
        <li><a href="@Url.Action("Categoria", "Ecommerce", new { id = Model.CategoriaPadre.id_categorie, titolo = Model.CategoriaPadre.Descrizione.Replace(" ", "-") })">@Model.CategoriaPadre.Descrizione</a></li>
        <li class="separator"><i class="fas fa-chevron-right fa-xs"></i></li>
        <li class="active">@title</li>
    </ul>
}

<section class="category-hero">
    <div class="hero-image-wrapper" style="background-image: url('@pathFotoLocale/@ViewBag.PathSfondoHero');"></div>

    <div class="hero-text-wrapper">
        <div class="category-hero-box">
            <h1>@title</h1>
            <p>I dettagli fanno la differenza. Scopri i modelli specifici di questa collezione, pensati per esaltare il tuo viso con linee studiate, lenti performanti e un'estetica senza tempo.</p>
            <div class="hero-btn-group">
                <a href="#prodotti" class="btn-hero-dark">Prova i Modelli</a>
            </div>
        </div>
    </div>
</section>

<div class="cat-pills-wrapper">
    @if (ViewBag.ListaSottocategorie != null)
    {
        var count = 0;
        string[] classiColori = { "pill-blue", "pill-dark", "pill-brown" };
        string[] iconeDefault = { "/images/Bettanini/uomo.png", "/images/banner-sole.png", "/images/bambini2.png" };

        var sottocategorie = (List<DAL.Model.Sottocategorie>)ViewBag.ListaSottocategorie;

        foreach (var sub in sottocategorie.Take(3))
        {
            var colore = classiColori[count % 3];
            var icona = iconeDefault[count % 3];

            // Verifichiamo se questa è la sottocategoria aperta al momento
            var isCurrent = (Model.MenuModel.idSottocategoria == sub.id_sottocategoria);

            // Aggiungiamo la classe active-pill solo se selezionata
            var activeClass = isCurrent ? "active-pill" : "";

            <a href="@Url.Action("Sottocategoria", "Ecommerce", new { id = sub.id_sottocategoria, titolo = sub.Nome.ToLower().Replace(" ", "-").Replace("/", "-"), categoriaId = Model.CategoriaPadre.id_categorie })"
               class="cat-pill @colore @activeClass">
                <img src="@icona" alt="@sub.Nome" />
                <span>@sub.Nome</span>
            </a>
            count++;
        }
    }
</div>
<div class="filter-toolbar" id="prodotti">
    <div class="filter-group">
        <span>ORDINA PER</span>
        <select class="filter-select" id="orderSelect">
            <option value="0">Posizione</option>
            <option value="1">Prezzo: Decrescente</option>
            <option value="2">Prezzo: Crescente</option>
        </select>
    </div>

    @*<div class="filter-group d-none d-md-flex">
            <span>VEDI COME</span>
            <i class="fas fa-th grid-icon active"></i>
            <i class="fas fa-list grid-icon"></i>
        </div>*@

    <div class="filter-group">
        <span>VISUALIZZA</span>
        <select class="filter-select" id="pageSizeSelect">
            <option value="8">8</option>
            <option value="16">16</option>
            <option value="24">24</option>
        </select>
    </div>
</div>

<div class="container-fluid p-0 mb-5">
    @if (Model.MenuModel.listaProdotti != null && Model.MenuModel.listaProdotti.Any())
    {
        <ul class="product-grid content">
            @foreach (var prodotto in Model.MenuModel.listaProdotti)
            {
                var nomeProd = prodotto.Descrizione;
                var titoloUrl = System.Web.HttpUtility.UrlEncode(nomeProd.Replace(" ", "-").Replace("%25", "-").Replace("%26", "e"));

                // Logica Sconto (Assicurati che sia presente in ENTRAMBE le view)
                var hasDiscount = prodotto.in_offerta == true;
                var finalPrice = hasDiscount ? prodotto.PrezzoVendita - (prodotto.PrezzoVendita * prodotto.sconto / 100) : prodotto.PrezzoVendita;

                <li class="product-item">
                    <a href="@Url.Action("Prodotto", "ecommerce", new { id = prodotto.id_prodotto, titolo = titoloUrl })" class="mockup-card">

                        @if (hasDiscount)
                        {
                            <span class="card-badge bg-danger">-@prodotto.sconto%</span>
                        }
                        else
                        {
                            <span class="card-badge">Nuovo</span>
                        }

                        <button class="card-heart"><i class="far fa-heart"></i></button>

                        <div class="card-img-wrapper">
                            @if (!string.IsNullOrEmpty(prodotto.pathFoto))
                            {
                                <img src="@System.Configuration.ConfigurationManager.AppSettings["pathFotoLocale"]@prodotto.pathFoto" alt="@prodotto.Descrizione" loading="lazy" />
                            }
                            else
                            {
                                <img src="~/images/ecommerce/imgnondisp.png" alt="Immagine non disponibile" loading="lazy" />
                            }
                        </div>

                        <div class="card-bottom-info">
                            <h3 class="card-title">@prodotto.Descrizione</h3>

                            @if (prodotto.prezzo_visibile == false)
                            {
                                <span class="text-muted small fw-bold">Contatta per il prezzo</span>
                            }
                            else
                            {
                                <div style="display:flex; justify-content:center; align-items:center; gap: 10px; margin-top: 10px;">
                                    <div class="card-price-pill" style="margin: 0;">
                                        € @String.Format("{0:n2}", finalPrice)
                                    </div>

                                    @if (hasDiscount)
                                    {
                                        <span style="text-decoration: line-through; color: #95a5a6; font-size:0.95rem; font-weight:600;">
                                            € @String.Format("{0:n2}", prodotto.PrezzoVendita)
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    </a>
                </li>
            }
        </ul>

        <div class="pagination-container">
            <span class="page-info"></span>
            <button class="btn-load-more">Carica altri prodotti</button>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h2 style="color: #bdc3c7; font-weight: 300;">Nessun prodotto trovato per questa collezione.</h2>
        </div>
    }
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // ==========================================
            // 1. GESTIONE ORDINAMENTO (Ricarica la pagina in modo sicuro)
            // ==========================================
            var orderSelect = $("#orderSelect");

            // Legge l'URL attuale per impostare la select corretta al caricamento
            const urlParams = new URLSearchParams(window.location.search);
            const currentOrder = urlParams.get('orderBy') || "0";
            orderSelect.val(currentOrder);

            orderSelect.change(function () {
                var selectedValue = $(this).val();
                // Sfruttiamo l'API URL per aggiornare solo il parametro orderBy
                // mantenendo intatti id, titolo e categoriaId!
                var currentUrl = new URL(window.location.href);
                currentUrl.searchParams.set('orderBy', selectedValue);
                window.location.href = currentUrl.toString();
            });

            // ==========================================
            // 2. GESTIONE VISUALIZZA E PAGINAZIONE JS (Fulminea)
            // ==========================================
            var pageSize = parseInt($("#pageSizeSelect").val()) || 8;
            var currentPage = 1;
            var $products = $('.product-grid li.product-item');
            var totalProducts = $products.length;

            function updatePagination() {
                var visibleCount = currentPage * pageSize;
                var totalPages = Math.ceil(totalProducts / pageSize) || 1;

                // Nasconde tutto e mostra solo i prodotti della pagina corrente
                $products.hide();
                $products.slice(0, visibleCount).fadeIn(400);

                // Aggiorna il testino
                $('.page-info').text('Pagina ' + currentPage + ' di ' + totalPages + ' (' + totalProducts + ' prodotti)');

                // Nascondi o mostra il bottone
                if (visibleCount >= totalProducts) {
                    $('.btn-load-more').hide();
                } else {
                    $('.btn-load-more').show();
                }
            }

            // Cambio numero prodotti da visualizzare (8, 16, 24)
            $('#pageSizeSelect').change(function () {
                pageSize = parseInt($(this).val());
                currentPage = 1;
                updatePagination();
            });

            // Click su "Carica altri prodotti"
            $('.btn-load-more').click(function (e) {
                e.preventDefault();
                currentPage++;
                updatePagination();
            });

            // Inizializza subito
            updatePagination();

            // ==========================================
            // 3. EFFETTI CARDS
            // ==========================================
            $('.card-heart').click(function (e) {
                e.preventDefault();
                $(this).find('i').toggleClass('far fas text-danger');
            });

            $('.card-arrow').click(function (e) {
                e.preventDefault();
            });
        });
    </script>
}