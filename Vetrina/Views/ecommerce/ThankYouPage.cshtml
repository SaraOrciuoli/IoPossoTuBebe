@model Vetrina.Models.CustomModel.CombinedViewModel


@{
    ViewBag.Title = "Grazie per averci contattato";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #fdfbfb 0%, #fcefe9 50%, #e8f4f8 100%);
        min-height: 100vh;
        margin-top: 150px;
        font-family: 'Poppins', sans-serif;
    }

    .thankyou-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        text-align: center;
    }

    .thankyou-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-radius: 30px;
        padding: 60px 40px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        border: 1px solid rgba(255,255,255,0.6);
        max-width: 600px;
        width: 100%;
    }

    .thankyou-icon {
        width: 100px;
        height: 100px;
        background: #e8f4f8;
        color: #5b8bd0; /* Azzurro Bettanini */
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin: 0 auto 30px auto;
        box-shadow: 0 10px 30px rgba(91, 139, 208, 0.2);
    }

    .thankyou-title {
        font-weight: 800;
        color: #2c3e50;
        font-size: 2.2rem;
        margin-bottom: 15px;
        letter-spacing: 0.5px;
    }

    .thankyou-text {
        color: #666;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 40px;
    }

    .btn-return-home {
        background-color: #2c3e50;
        color: #ffffff;
        border: none;
        border-radius: 30px;
        padding: 15px 40px;
        font-size: 1.1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-return-home:hover {
            background-color: #1a252f;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(44, 62, 80, 0.2);
        }
</style>

<div class="container thankyou-container" data-aos="zoom-in">
    <div class="thankyou-card">

        <div class="thankyou-icon">
            <i class="far fa-envelope-open"></i>
        </div>

        <h1 class="thankyou-title">Messaggio Inviato!</h1>
        <p class="thankyou-text">
            Grazie per averci contattato. Il nostro team leggerà la tua richiesta e ti risponderà il prima possibile.
        </p>

        <a href="@Url.Action("Index", "Ecommerce")" class="btn-return-home">
            Torna alla Home
        </a>

    </div>
</div>