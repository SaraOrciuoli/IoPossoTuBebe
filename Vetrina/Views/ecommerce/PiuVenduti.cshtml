@model Vetrina.Models.CustomModel.CombinedViewModel

@{
    ViewBag.Title = @Resources.labels.PiuVenduti;
    Layout = "~/Views/Shared/_LayoutEcommerce.cshtml";
}

<h2 class="text-center text-uppercase">@Resources.labels.PiuVenduti</h2>
<div class="container">
    <div class="content" style="padding-top:35px">
        <ul class="row" id="menu">
            @foreach (var prodotto in Model.MenuModel.listaProdottiPiuVenduti.Where(p => p.MostraWeb == true && p.numero_vendite != null &&  p.numero_vendite > 0 ).Take(12).OrderByDescending(x => x.numero_vendite))
            {
                var titolo = prodotto.Descrizione;
                var titoloSenzaPercentuale = titolo.Replace(" ", "-");
                var titoloEncoded = System.Web.HttpUtility.UrlEncode(titoloSenzaPercentuale);

                <li class="col-lg-4 col-md-4 col-12" style="padding-bottom:25px">
                    <div class="col-lg-12 d-flex border-item" style="align-items:center; flex-direction:column">
                        <a href="@Url.Action("Prodotto", "ecommerce", new { id = prodotto.id_prodotto, titolo = titoloEncoded.Replace("%25", "-").Replace("%26","e")})" style="text-decoration:none; color:#333333;">
                            <div class="card" style="height: 400px">
                                <span class="sconto" data-sconto="@prodotto.sconto"></span>

                                <div class="card-info" style=" max-width: 270px;">
                                    @if (System.Threading.Thread.CurrentThread.CurrentCulture.Name == "en-US" || System.Threading.Thread.CurrentThread.CurrentCulture.Name == "en")
                                    {
                                        if (string.IsNullOrEmpty(prodotto.Descrizione_eng))
                                        {
                                            <h4 class="text-title" style="text-align:center;color:darkgoldenrod">@prodotto.Descrizione</h4>
                                        }
                                        else
                                        {
                                            <h4 class="text-title" style="text-align:center;color:darkgoldenrod">@prodotto.Descrizione_eng</h4>
                                        }
                                    }
                                    else if (System.Threading.Thread.CurrentThread.CurrentCulture.Name == "it-IT" || System.Threading.Thread.CurrentThread.CurrentCulture.Name == "it")
                                    {
                                        <h4 class="text-title" style="text-align:center;color:darkgoldenrod">@prodotto.Descrizione</h4>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(prodotto.pathFoto))
                                {
                                    <div class="image-container img-cat">
                                        <img class="img-responsive" src="@System.Configuration.ConfigurationManager.AppSettings["RottaAdmin"]@prodotto.pathFoto" />
                                    </div>
                                }
                                else
                                {
                                    <div class="image-container img-cat">
                                        <img class="img-responsive" src="~/images/ecommerce/home/Senza-titolo-1.png" />
                                    </div>
                                }

                                <div class="card-footer">
                                    @if (prodotto.prezzo_visibile == false)
                                    {
                                        <span class="text-title">Contatta per il prezzo</span>

                                    }
                                    else
                                    {
                                        <span class="text-title prezzo-vecchio">&euro; &nbsp;@String.Format("{0:n2}", prodotto.PrezzoVendita)</span>
                                        <span class="text-title">&euro; &nbsp;@String.Format("{0:n2}", prodotto.PrezzoVendita - (prodotto.PrezzoVendita * prodotto.sconto / 100))</span>
                                    }

                                    <div class="card-button">
                                        <span class="material-symbols-outlined" style="color: black; ">
                                            search
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                </li>
            }
        </ul>
        <div class="products-displayed text-center" style="padding-bottom:25px"></div>
    </div>
</div>


<script>
    $(document).ready(function () {
        $('.card .sconto').each(function () {
            var percentualeSconto = $(this).data('sconto'); // Ottieni la percentuale di sconto dal data attributo
            $(this).attr('data-sconto', percentualeSconto + '%'); // Aggiorna il valore dell'attributo dati con la percentuale di sconto
        });
    });

</script>