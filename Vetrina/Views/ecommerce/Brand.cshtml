@model Vetrina.Models.CustomModel.CombinedViewModel
@using System.Configuration;

@{
    ViewBag.Title = "I Nostri Brand";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var pathFotoLocale = ConfigurationManager.AppSettings["pathFotoLocale"];
}

<style>
    /* =========================================
       ANIMAZIONI
       ========================================= */
    @@keyframes fadeUp {
        0% {
            opacity: 0;
            transform: translateY(50px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* =========================================
       HERO SECTION (SPLIT 60/40 MODERNO)
       ========================================= */
    .category-hero {
        position: relative;
        width: 100%;
        height: 60vh;
        min-height: 450px;
        display: flex;
        align-items: center;
        background-color: #e0e7ef;
        margin-top: 70px;
        overflow: hidden;
        margin-bottom: 60px;
    }

    .hero-image-wrapper {
        width: 60%;
        height: 100%;
        background-image: url('/images/Bettanini/brand.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        position: relative;
    }

        .hero-image-wrapper::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            background: linear-gradient(to right, transparent 70%, rgba(248, 249, 250, 0.8) 100%);
        }

    .hero-text-wrapper {
        width: 45%;
        margin-left: -5%;
        z-index: 2;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0 40px;
    }

    .category-hero-box {
        backdrop-filter: blur(3px);
        -webkit-backdrop-filter: blur(15px);
        padding: 50px 40px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        text-align: left;
        animation: fadeUp 1s ease-out forwards;
        background: #e0e7ef2b;
    }
        .category-hero-box h1 {
            color: #8B0000;
            font-weight: 800;
            font-size: 2.8rem;
            margin-bottom: 20px;
            line-height: 1.1;
        }

        .category-hero-box p {
            color: #4a4a4a;
            font-size: 1.05rem;
            line-height: 1.7;
            margin-bottom: 30px;
        }

    /* =========================================
       GRIGLIA BRAND CARDS
       ========================================= */
    .brand-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 40px 20px;
        text-align: center;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.04);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        height: 100%;
        position: relative;
        overflow: hidden;
    }

        .brand-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            border-color: #c0a16b;
        }

    .brand-logo-container {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        padding: 20px;
        transition: transform 0.4s;
        border: 2px solid transparent;
    }

    .brand-card:hover .brand-logo-container {
        transform: scale(1.1);
        background: #fff;
        border-color: #f1f2f6;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .brand-logo-container img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        filter: grayscale(100%);
        transition: filter 0.4s;
    }

    .brand-card:hover .brand-logo-container img {
        filter: grayscale(0%);
    }

    .brand-name {
        color: #2c3e50;
        font-weight: 800;
        font-size: 1.2rem;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .explore-text {
        font-size: 0.85rem;
        color: #c0a16b;
        margin-top: 15px;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.3s;
        font-weight: 700;
        text-transform: uppercase;
    }

    .brand-card:hover .explore-text {
        opacity: 1;
        transform: translateY(0);
    }

    /* RESPONSIVE */
    @@media (max-width: 992px) {
        .category-hero {
            flex-direction: column;
            height: auto;
            padding-bottom: 40px;
            margin-top: 80px;
        }

        .hero-image-wrapper {
            width: 100%;
            height: 350px;
        }

        .hero-text-wrapper {
            width: 100%;
            margin-left: 0;
            margin-top: -50px;
            padding: 0 20px;
        }

        .category-hero-box {
            text-align: center;
        }
    }
</style>

<section class="category-hero">
    <div class="hero-image-wrapper"></div>
    <div class="hero-text-wrapper">
        <div class="category-hero-box">
            <h1>I Nostri Brand</h1>
            <p>Selezioniamo solo le migliori marche di ottica per garantirti stile, comfort e materiali di altissima qualità. Scegli il tuo designer preferito.</p>
        </div>
    </div>
</section>

<div class="container mb-5 pb-5">
    <div class="row g-4 justify-content-center">

        @if (Model.ListaMarchi != null && Model.ListaMarchi.Any())
        {
            int delay = 0;
            foreach (var marchio in Model.ListaMarchi)
            {
                // Action per visualizzare i prodotti del singolo Brand
                string urlProdottiBrand = Url.Action("ProdottiByBrand", "Ecommerce", new { id = marchio.id_marchio, nome = marchio.nome_marchio.Replace(" ", "-").ToLower() });

                string imgPath = !string.IsNullOrEmpty(marchio.path_logo_marchio)
                                 ? marchio.path_logo_marchio
                                 : "/images/placeholder-brand.png";

                <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="@delay">
                    <a href="@urlProdottiBrand" class="brand-card">
                        <div class="brand-logo-container">
                            <img src="@pathFotoLocale/@imgPath" alt="Logo @marchio.nome_marchio">
                        </div>
                        <h3 class="brand-name">@marchio.nome_marchio</h3>
                        <span class="explore-text">Scopri <i class="fas fa-arrow-right ms-1"></i></span>
                    </a>
                </div>

                delay += 50;
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <h4 class="text-muted">Nessun brand trovato al momento.</h4>
            </div>
        }

    </div>
</div>