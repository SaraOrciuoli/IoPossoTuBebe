@model Vetrina.Models.CustomModel.CombinedViewModel
@using System.Configuration

@{
    string title = string.Empty;
    if (System.Threading.Thread.CurrentThread.CurrentUICulture.Name.ToLower().StartsWith("en"))
    {
        title = Model.Prodotto.Descrizione_eng;
    }
    else
    {
        title = Model.Categorie.Descrizione.ToString();
    }
    ViewBag.Title = title;
    var pathFotoLocale = ConfigurationManager.AppSettings["pathFotoLocale2"];

    var hasDiscount = Model.Prodotto.in_offerta == true;
    var finalPrice = hasDiscount ? Model.Prodotto.PrezzoVendita - (Model.Prodotto.PrezzoVendita * Model.Prodotto.sconto / 100) : Model.Prodotto.PrezzoVendita;

    // FIX: Rimosso il vincolo "&& x.id_tipo_immagine == 5". Ora prenderà tutte le foto aggiuntive collegate al prodotto!
    var immaginiProdotto = Model.ListSliderProdotto != null
        ? Model.ListSliderProdotto.Where(x => x.id_prod == Model.Prodotto.id_prodotto).ToList()
        : new List<DAL.Model.Immagini_catProd>();

    var prodottiConsigliati = Model.MenuModel.listaProdotti != null
        ? Model.MenuModel.listaProdotti.Where(p => p.id_sottocategoria == Model.Prodotto.id_sottocategoria && p.id_prodotto != Model.Prodotto.id_prodotto).Take(4).ToList()
        : new List<DAL.Model.Prodotti>();
}

<style>
    body {
        background-color: white;
        background-size: cover;
        min-height: 100vh;
        margin-top: 25px;
        font-family: 'Raleway', sans-serif;
    }

    /* =========================================
       1. HEADER PRODOTTI
       ========================================= */
    .prodotti-title-container {
        position: relative;
        text-align: start;
        margin-top: 50px;
        margin-bottom: 40px;
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .contatti-bg-text {
        font-size: 8rem;
        font-weight: 300;
        color: #110904;
        position: absolute;
        white-space: nowrap;
        z-index: 0;
        letter-spacing: 5px;
        width: 100%;
        margin-left: 20%;
    }

    .container-contatti-cursive {
        padding: 0 5%;
        width: 100%;
        border-top: 2px solid black;
        border-bottom: 2px solid black;
        background-color: white;
        position: relative;
        z-index: 2;
        min-height: 50px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-height: 50px;
    }

    .contatti-cursive-text {
        font-family: 'Aleya', cursive;
        font-size: 3.5rem;
        color: #000;
        line-height: 0.8;
        margin-left: 20%;
        margin-top: 1%;
    }

    .btn-black-outline {
        background-color: #000;
        color: #fff;
        border: 2px solid #000;
        font-weight: 600;
        letter-spacing: 1px;
        padding: 5px 20px;
        text-decoration: none;
        transition: all 0.3s;
    }

        .btn-black-outline:hover {
            background-color: #fff;
            color: #000;
        }

    /* =========================================
       2. LAYOUT PRODOTTO (IL TRUCCO DELLA SOVRAPPOSIZIONE)
       ========================================= */
    .product-single-row {
        align-items: stretch;
    }

    .gallery-col {
        position: relative;
        z-index: 10; /* La foto deve stare SOPRA */
    }

    .info-col {
        position: relative;
        z-index: 5; /* Il testo deve stare SOTTO */
    }

    .product-info-wrapper {
        background-image: url(/images/AnyeLabel/Homepage-background-grigio.png);
        background-size: cover;
        background-position: center;
        border-top-right-radius: 80px;
        margin-left: -125px;
        padding: 50px 50px 50px 110px;
        min-height: 100%;
        display: flex;
        width: 110%;
        flex-direction: column;
        justify-content: center;
        padding-right: 20%;
        height: 75vh;
    }
    /* La scritta sfumata gigante sul fondo */
    .watermark-bg {
        position: absolute;
        top: 30%;
        left: 5%;
        font-family: 'Aleya', cursive;
        font-size: 14rem;
        color: transparent;
        -webkit-text-stroke: 2px rgba(0, 0, 0, 0.05);
        z-index: 0;
        transform: rotate(-10deg);
        pointer-events: none;
        user-select: none;
    }

    /* =========================================
       3. GALLERIA IMMAGINI
       ========================================= */
    .product-gallery-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        grid-gap: 15px;
        height: 100%;
        padding:5%;
    }

    .img-box {
        background-color: #f1f2f6;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: zoom-in;
        padding: 0;
        border: none;
        overflow: hidden;
        border-radius: 30px;
        box-shadow: 10px 10px 30px rgba(0,0,0,0.1); /* L'ombra aiuta a staccare la foto dal fumo */
    }

        .img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

        .img-box:hover img {
            transform: scale(1.05);
        }

    .main-img-box {
        aspect-ratio: 4 / 5;
        width: 100%;
        height: 100%;
    }

    .side-img-container {
        display: flex;
        flex-direction: column;
        gap: 15px;
        height: 100%;
    }

    .side-img-box {
        flex: 1 1 0;
        width: 100%;
        height: 100%;
    }

    /* =========================================
       4. TESTI, PREZZO E BOTTONI (Come da foto)
       ========================================= */
    .info-content-inner {
        position: relative;
        z-index: 5;
    }

    .top-info-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
        border-bottom: 1px solid #000;
        padding-bottom: 15px;
    }

    .brand-title {
        font-size: 2.2rem;
        font-weight: 300;
        color: #000;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .wishlist-btn {
        background: transparent;
        border: none;
        font-size: 2rem;
        color: #000;
        cursor: pointer;
        padding: 0;
        transition: color 0.3s;
    }

        .wishlist-btn:hover {
            color: #8B0000;
        }

    .product-description {
        color: #333;
        font-size: 0.95rem;
        line-height: 1.6;
        text-align: justify;
        margin-bottom: 20px;
    }

    /* Riquadro del prezzo allineato a destra */
    .price-box-new {
        border: 1px solid #000;
        background-color: transparent;
        padding: 8px 30px;
        font-size: 1.6rem;
        font-weight: 400;
        color: #000;
        display: inline-block;
    }

    /* Controlli Quantità */
    .qty-row {
        margin-top: 40px;
        margin-bottom: 15px;
    }

    .qty-label {
        font-size: 1.2rem;
        font-weight: 300;
        color: #000;
    }

    .qty-controls {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .qty-circle {
        background: #000;
        color: #fff;
        width: 25px;
        height: 25px;
        border-radius: 50%;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        cursor: pointer;
    }

    .qty-input {
        width: 25px;
        text-align: center;
        border: none;
        background: transparent;
        font-weight: 400;
        font-size: 1.1rem;
        color: #000;
        pointer-events: none;
    }

    /* Gruppo Bottoni */
    .action-btn {
        width: 100%;
        border-radius: 50px;
        padding: 10px;
        font-weight: 300;
        font-size: 1.1rem;
        text-align: center;
        margin-bottom: 15px;
        border: 1px solid transparent;
        transition: all 0.3s;
    }

    .btn-cart {
        background-color: transparent;
        border-color: #000;
        color: #000;
 
    }

        .btn-cart:hover {
            background-color: rgba(0,0,0,0.05);
        }

    .btn-buy {
        background-color: #69605b; /* Grigio marroncino */
        color: #fff;
  
    }

        .btn-buy:hover {
            background-color: #524b47;
        }

    .btn-paypal {
        background-color: #1a1e29; /* Blu scuro */
        color: #fff;
 
    }

        .btn-paypal:hover {
            background-color: #0f121a;
        }

    /* Torna allo shop */
    .btn-torna-shop {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background-color: transparent;
        border: 1px solid #000;
        border-radius: 50px;
        padding: 5px 25px;
        color: #000;
        font-size: 1.1rem;
        font-weight: 300;
        text-decoration: none;
        transition: background 0.3s;
        margin-top: 20px;
    }

        .btn-torna-shop i {
            background-color: #dbe3e3;
            border: 1px solid #000;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: 15px;
            font-size: 0.8rem;
        }

    /* =========================================
       5. RESPONSIVE
       ========================================= */
    @@media (max-width: 992px) {
        .product-layout-row {
            flex-direction: column;
        }

        .gallery-col {
            margin-right: 0;
            margin-bottom: 20px;
        }

        .product-info-wrapper {
            margin-left: 0; /* Togliamo la sovrapposizione su mobile */
            padding: 40px 30px;
            border-radius: 40px;
        }

        .watermark-bg {
            display: none;
        }
        /* Nascondiamo la scritta grande per pulizia */

        .product-gallery-grid {
            grid-template-columns: 1fr;
        }

        .side-img-container {
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto;
            flex-direction: row;
            display: grid;
        }

        .side-img-box {
            aspect-ratio: 1 / 1;
        }
    }

    @@media (max-width: 576px) {
        .container-contatti-cursive {
            flex-direction: column;
            padding: 15px 0;
            gap: 10px;
        }

        .contatti-cursive-text {
            transform: none;
            margin-left: 0;
        }

        .top-info-row {
            flex-direction: column;
            text-align: center;
            align-items: center;
            gap: 15px;
        }
    }

    /* Stili per la sezione "Potrebbero interessarti" (Invariati) */
    .recommended-section {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(35px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 12px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.03);
        padding: 30px 20px;
        margin: 40px auto 80px auto;
        max-width: 1400px;
        width: 90%;
    }

    .section-title-line {
        text-align: center;
        font-size: 1.3rem;
        font-weight: 600;
        color: #2c3e50;
        position: relative;
        display: inline-block;
        left: 50%;
        transform: translateX(-50%);
        border-bottom: 2px solid #8B0000;
        padding-bottom: 5px;
    }

    .custom-product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .cpc-card {
        background-color: rgba(255, 255, 255, 0.45);
        border: 1px solid #000;
        border-radius: 30px;
        position: relative;
        height: 480px;
        display: block;
        text-decoration: none;
        color: #000;
        transition: transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
    }

    .product-item:nth-child(4n+2) .cpc-card {
        background-color: #e3d3c8;
    }

    .product-item:nth-child(4n+3) .cpc-card {
        background-image: url('../../images/AnyeLabel/sfondo-fumo.jpg');
        background-size: cover;
        box-shadow: inset 0 0 40px rgba(0,0,0,0.6);
    }

    .cpc-img {
        position: absolute;
        top: 8%;
        left: 0;
        width: 100%;
        height: 75%;
        object-fit: contain;
        z-index: 1;
    }

    .cpc-price {
        position: absolute;
        top: 15px;
        right: 15px;
        background: #fff;
        border: 1px solid #000;
        padding: 4px 15px;
        font-size: 0.95rem;
        font-weight: 700;
        z-index: 5;
    }

    .cpc-btn-acquista {
        position: absolute;
        right: 15px;
        top: 70px;
        bottom: 80px;
        width: 45px;
        background-color: #bce3e3;
        border: 1px solid #000;
        border-radius: 50px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding-top: 15px;
        z-index: 5;
        height:40%;
    }

        .cpc-btn-acquista i {
            font-size: 1.2rem;
            margin-bottom: 10px;
            color: #000;
        }

    .cpc-vertical-text {
        writing-mode: vertical-rl;
        text-orientation: mixed;
        transform: rotate(180deg);
        font-weight: 300;
        letter-spacing: 2px;
        font-size: 1.1rem;
        text-transform: lowercase;
        color: #000;
    }

    .cpc-icons {
        position: absolute;
        bottom: 25px;
        right: 20px;
        display: flex;
        gap: 15px;
        font-size: 1.3rem;
        z-index: 5;
        color: #000;
    }

        .cpc-icons i:hover {
            color: #8B0000;
        }

    .cpc-title {
        position: absolute;
        bottom: 25px;
        left: 20px;
        margin: 0;
        font-size: 1.1rem;
        font-weight: 300;
        text-transform: uppercase;
        max-width: 60%;
        z-index: 5;
        text-align: left;
        color: #000;
    }

    .product-item:nth-child(4n+2) .cpc-title {
        background-color: #1e2025;
        color: #fff;
        width: 100%;
        max-width: 100%;
        left: 0;
        bottom: 0;
        padding: 15px 20px;
        text-align: center;
    }

    .product-item:nth-child(4n+2) .cpc-icons {
        bottom: 70px;
    }

    /* Modale */
    .lightbox-modal .modal-content {
        background-color: transparent;
        border: none;
        box-shadow: none;
    }

    .lightbox-modal .modal-body {
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 80vh;
    }

    .lightbox-modal .carousel-item img {
        max-height: 80vh;
        width: auto;
        max-width: 100%;
        margin: 0 auto;
        object-fit: contain;
        border-radius: 12px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        background: white;
        padding: 20px;
    }

    .lightbox-close {
        position: absolute;
        top: 10px;
        right: 20px;
        font-size: 2.5rem;
        color: white;
        opacity: 0.8;
        background: transparent;
        border: none;
        z-index: 1055;
        transition: opacity 0.3s;
    }

        .lightbox-close:hover {
            opacity: 1;
        }
</style>

<div class="prodotti-title-container">
    <div class="contatti-bg-text">PRODOTTI</div>
    <div class="container-contatti-cursive">
        <span class="contatti-cursive-text">prodotti</span>
        <a href="@Url.Action("Categoria", "Ecommerce",new {id = 1})" class="btn-black-outline">TUTTI I PRODOTTI</a>
    </div>
</div>

<div class="container ">

    <div class="row product-single-row">

        <div class="col-lg-5 col-md-12 gallery-col">
            <div class="product-gallery-grid">

                <div class="img-box main-img-box thumbnail-trigger" id="mainImageContainer" data-slide-index="0">
                    @{
                        string mainImgPath = !string.IsNullOrEmpty(Model.Prodotto.pathFoto) ? pathFotoLocale + Model.Prodotto.pathFoto : "/images/ecommerce/imgnondisp.png";
                    }
                    <img id="mainImage" src="@mainImgPath" alt="@Model.Prodotto.Descrizione" />
                </div>

                <div class="side-img-container">
                    @if (immaginiProdotto.Any())
                    {
                        int slideIndex = 1;
                        foreach (var img in immaginiProdotto)
                        {
                            <div class="img-box side-img-box thumbnail-trigger" data-img="@pathFotoLocale@img.path" data-slide-index="@slideIndex">
                                <img src="@pathFotoLocale@img.path" alt="Dettaglio" />
                            </div>
                            slideIndex++;
                        }

                        if (immaginiProdotto.Count == 1)
                        {
                            <div class="img-box side-img-box thumbnail-trigger" data-img="@mainImgPath" data-slide-index="0">
                                <img src="@mainImgPath" alt="Dettaglio Base" style="opacity: 0.5;" />
                            </div>
                        }
                    }
                    else
                    {
                        <div class="img-box side-img-box thumbnail-trigger" data-img="@mainImgPath" data-slide-index="0"><img src="@mainImgPath" /></div>
                        <div class="img-box side-img-box thumbnail-trigger" data-img="@mainImgPath" data-slide-index="0"><img src="@mainImgPath" /></div>
                    }
                </div>

            </div>
        </div>

        <div class="col-lg-7 col-md-12 info-col">

            <div class="product-info-wrapper">

                <div class="watermark-bg">Anye</div>

                <div class="info-content-inner">
                    <div class="top-info-row">
                        <h1 class="brand-title">@(Model.Prodotto.Descrizione != null ? Model.Prodotto.Descrizione : "BETTANINI")</h1>
                        <button type="button" class="wishlist-btn"><i class="far fa-heart"></i></button>
                    </div>

                    <p class="product-description">
                        @if (!string.IsNullOrEmpty(Model.Prodotto.Ingredienti))
                        {
                            @Html.Raw(Model.Prodotto.Ingredienti)
                        }

                    </p>

                    <div class="d-flex justify-content-end align-items-center mb-4">
                        @if (hasDiscount)
                        {
                            <span class="price-old">€ @String.Format("{0:n2}", Model.Prodotto.PrezzoVendita)</span>
                        }
                        <div class="price-box-new">
                            € @String.Format("{0:n2}", finalPrice)
                        </div>
                    </div>
                    @if (Model.listaTaglie != null && Model.listaTaglie.Any())
                    {
                        <div class="mb-4">
                            <label for="selettoreTaglia" style="font-weight: 600; margin-bottom: 5px; display: block;">Seleziona Taglia:</label>
                            <select id="selettoreTaglia" class="form-control" style="border: 1px solid #000; border-radius: 25px; padding: 10px 20px; outline: none; background: transparent; width: 50%;">
                                <option value="" disabled selected>-- Seleziona una taglia --</option>
                                @foreach (var taglia in Model.listaTaglie)
                                {
                                    <option value="@taglia.id_taglia">@taglia.Descrizione_taglia</option>
                                }
                            </select>
                            <small id="erroreTaglia" class="text-danger" style="display:none; font-weight:600;">Seleziona una taglia prima di procedere!</small>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" id="selettoreTaglia" value="0" />
                    }

                    <div class="qty-row d-flex justify-content-between align-items-center">
                        <span class="qty-label">Q.tà</span>
                        <div class="qty-controls">
                            <button type="button" class="qty-circle" id="btn-plus"><i class="fas fa-plus"></i></button>
                            <input type="text" id="quantita" class="qty-input" value="1" readonly />
                            <button type="button" class="qty-circle" id="btn-minus"><i class="fas fa-minus"></i></button>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="button" class="action-btn btn-cart" onclick="addToCart()">Aggiungi al carrello</button>
                        <button type="button" class="action-btn btn-buy" onclick="GoToCheckOut()">Acquista ora</button>
                        <button type="button" class="action-btn btn-paypal" onclick="GoToCheckOut()">Paga con paypal</button>
                    </div>

                    <div class="text-center">
                        <a href=@Url.Action("Categoria","Ecommerce", new {id = 1}) class="btn-torna-shop">
                            Torna allo shop 
                        </a>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

@if (prodottiConsigliati.Any())
{
    <div class="recommended-section">
        <div class="container-fluid">
            <div class="section-title-line mb-5">POTREBBERO INTERESSARTI</div>

            <ul class="custom-product-grid">
                @foreach (var p in prodottiConsigliati)
                {
                    var pTitleUrl = System.Web.HttpUtility.UrlEncode(p.Descrizione.Replace(" ", "-").Replace("%25", "-").Replace("%26", "e"));
                    var pHasDiscount = p.in_offerta == true;
                    var pFinalPrice = pHasDiscount ? p.PrezzoVendita - (p.PrezzoVendita * p.sconto / 100) : p.PrezzoVendita;

                    <li class="product-item">
                        <a href="@Url.Action("Prodotto", "ecommerce", new { id = p.id_prodotto, titolo = pTitleUrl })" class="cpc-card">

                            <div class="cpc-price">
                                € @String.Format("{0:n0}", pFinalPrice)
                            </div>

                            <div class="cpc-btn-acquista">
                                <i class="fas fa-arrow-up"></i>
                                <span class="cpc-vertical-text">acquista</span>
                            </div>

                            @if (!string.IsNullOrEmpty(p.pathFoto))
                            {
                                <img src="@pathFotoLocale@p.pathFoto" class="cpc-img" alt="@p.Descrizione" loading="lazy" />
                            }
                            else
                            {
                                <img src="~/images/ecommerce/imgnondisp.png" class="cpc-img" alt="N/D" loading="lazy" />
                            }

                            <h3 class="cpc-title">@p.Descrizione</h3>

                            <div class="cpc-icons">
                                <i class="fas fa-shopping-cart"></i>
                                <i class="far fa-heart card-heart"></i>
                            </div>

                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
}

<div class="modal fade lightbox-modal" id="lightboxGallery" tabindex="-1" aria-hidden="true">
    <button type="button" class="lightbox-close" data-dismiss="modal" data-bs-dismiss="modal" aria-label="Close">&times;</button>
    <div class="modal-dialog modal-fullscreen modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body">

                <div id="carouselLightbox" class="carousel slide" data-bs-ride="false" style="width: 100%;">
                    <div class="carousel-inner text-center">

                        <div class="carousel-item active">
                            <img src="@mainImgPath" alt="@Model.Prodotto.Descrizione">
                        </div>

                        @foreach (var img in immaginiProdotto)
                        {
                            <div class="carousel-item">
                                <img src="@pathFotoLocale@img.path" alt="Dettaglio Prodotto">
                            </div>
                        }

                    </div>

                    @if (immaginiProdotto.Any())
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselLightbox" data-bs-slide="prev" data-slide="prev" style="width: 10%; border:none; background:transparent;">
                            <span class="carousel-control-prev-icon" aria-hidden="true" style="background-color: #2c3e50; border-radius: 50%; padding: 20px;"></span>
                            <span class="visually-hidden">Precedente</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselLightbox" data-bs-slide="next" data-slide="next" style="width: 10%; border:none; background:transparent;">
                            <span class="carousel-control-next-icon" aria-hidden="true" style="background-color: #2c3e50; border-radius: 50%; padding: 20px;"></span>
                            <span class="visually-hidden">Successivo</span>
                        </button>
                    }
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="cartErrorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border:none; box-shadow: 0 20px 50px rgba(0,0,0,0.1);">
            <div class="modal-header" style="background: #f8f9fa; border-radius: 20px 20px 0 0; border-bottom: 1px solid #eee;">
                <h5 class="modal-title fw-bold text-dark"><i class="fas fa-exclamation-circle text-danger me-2"></i> Attenzione</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <p id="cartErrorMessage" style="color: #2c3e50; font-size: 1.1rem; margin: 0;"></p>
            </div>
            <div class="modal-footer" style="border: none; justify-content: center;">
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal" style="border-radius: 30px; padding: 8px 30px;">Ho capito</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {

            const maxQta = @(Model.Prodotto.Quantita > 0 ? Model.Prodotto.Quantita : 10);

            $('#btn-plus').click(function (e) {
                e.preventDefault();
                let currentVal = parseInt($('#quantita').val());
                if (currentVal < maxQta) {
                    $('#quantita').val(currentVal + 1);
                }
            });

            $('#btn-minus').click(function (e) {
                e.preventDefault();
                let currentVal = parseInt($('#quantita').val());
                if (currentVal > 1) {
                    $('#quantita').val(currentVal - 1);
                }
            });

            $('.thumbnail-trigger').on('mouseenter', function () {
                let newSrc = $(this).data('img');
                let newIndex = $(this).data('slide-index');

                $('#mainImage').attr('src', newSrc);
                $('#mainImageContainer').data('slide-index', newIndex);
            });

            $('.img-box').on('click', function () {
                let slideIndex = $(this).data('slide-index');

                if (typeof bootstrap !== 'undefined' && bootstrap.Carousel) {
                    let myCarousel = document.getElementById('carouselLightbox');
                    let carousel = bootstrap.Carousel.getInstance(myCarousel);
                    if (!carousel) {
                        carousel = new bootstrap.Carousel(myCarousel);
                    }
                    carousel.to(slideIndex);
                } else {
                    $('#carouselLightbox').carousel(parseInt(slideIndex));
                }

                $('#lightboxGallery').modal('show');
            });

            $('.wishlist-btn, .card-heart').click(function(e) {
                e.preventDefault();
                $(this).find('i').toggleClass('far fas text-danger');
            });
        });

        function addToCart() {
            var quantity = $('#quantita').val();
            var productId = "@Model.Prodotto.id_prodotto";
            var finalPrice = "@finalPrice".replace(',', '.');

            var tagliaSelezionata = $('#selettoreTaglia').val();
            if ($('#selettoreTaglia').is('select') && !tagliaSelezionata) {
                $('#erroreTaglia').fadeIn();
                return; 
            } else {
                $('#erroreTaglia').fadeOut();
            }

            $.ajax({
                url: '@Url.Action("AddProdotto", "Shop")',
                type: 'POST',
                data: {
                    idProd: productId,
                    quantity: quantity,
                    prezzoAggiornato: finalPrice,
                    idTaglia: tagliaSelezionata
                },
                success: function (response) {
                    if (response.success) {
                        updateCartItemCount();

                        if (typeof openSideCart === "function") {
                            openSideCart();
                        } else {
                            $('#cartErrorMessage').text(response.message || "Si è verificato un problema.");
                            $('#cartErrorModal').modal('show');                        }
                    } else {
                        $('#cartErrorMessage').text(response.message || "Si è verificato un problema.");
                        $('#cartErrorModal').modal('show');                    }
                },
                error: function () {
                    $('#cartErrorMessage').text(response.message || "Si è verificato un problema.");
                    $('#cartErrorModal').modal('show');                }
            });
        }

        function GoToCheckOut() {
            var quantity = $('#quantita').val();
            var productId = "@Model.Prodotto.id_prodotto";
            var finalPrice = "@finalPrice".replace(',', '.');

            var tagliaSelezionata = $('#selettoreTaglia').val();
            if ($('#selettoreTaglia').is('select') && !tagliaSelezionata) {
                $('#erroreTaglia').fadeIn();
                return;
            } else {
                $('#erroreTaglia').fadeOut();
            }

            $.ajax({
                url: '@Url.Action("AddProdotto", "Shop")',
                type: 'POST',
                data: {
                    idProd: productId,
                    quantity: quantity,
                    prezzoAggiornato: finalPrice,
                    idTaglia: tagliaSelezionata
                },
                success: function (response) {
                    if (response.success) {
                        updateCartItemCount();
                        window.location.href = '@Url.Action("Pagamento", "Ordini")';
                    } else {
                        $('#cartErrorMessage').text(response.message || "Si è verificato un problema.");
                        $('#cartErrorModal').modal('show');                    }
                },
                error: function () {
                    $('#cartErrorMessage').text(response.message || "Si è verificato un problema.");
                    $('#cartErrorModal').modal('show');                }
            });
        }
    </script>
}