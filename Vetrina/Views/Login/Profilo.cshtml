@model Vetrina.Models.CustomModel.CombinedViewModel
@{
    ViewBag.Title = "Profilo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dashboard-header {
        text-align: center;
        margin-bottom: 50px;
    }

        .dashboard-header h1 {
            font-weight: 800;
            color: #2c3e50;
            font-size: 2.5rem;
        }

        .dashboard-header p {
            color: #666;
            font-size: 1.1rem;
        }

    .dashboard-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        border: 1px solid rgba(255,255,255,0.5);
        height: 100%;
    }

    .card-title {
        font-weight: 800;
        color: #2c3e50;
        text-transform: uppercase;
        font-size: 1.2rem;
        margin-bottom: 30px;
        letter-spacing: 1px;
        border-bottom: 2px solid #8B0000;
        display: inline-block;
        padding-bottom: 5px;
    }

    /* Stili Input Moderni */
    .modern-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #95a5a6;
        text-transform: uppercase;
        margin-bottom: 5px;
        display: block;
    }

    .modern-input {
        width: 100%;
        padding: 12px 15px;
        border: none;
        border-bottom: 2px solid #e0e0e0;
        background-color: transparent;
        transition: all 0.3s ease;
        font-weight: 600;
        color: #2c3e50;
    }

        .modern-input:focus {
            outline: none;
            border-bottom-color: #2c3e50;
            background: #f8f9fa;
            border-radius: 8px 8px 0 0;
        }

        .modern-input[readonly] {
            color: #95a5a6;
        }

    .password-wrapper {
        position: relative;
    }

    .toggle-password-btn {
        position: absolute;
        top: 50%;
        right: 10px;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        color: #95a5a6;
        cursor: pointer;
    }

    .modern-btn-submit {
        background-color: #2c3e50;
        color: #ffffff;
        border: none;
        border-radius: 30px;
        padding: 12px 40px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
        margin-top: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .modern-btn-submit:hover {
            background-color: #1a252f;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(44,62,80,0.2);
        }

    /* Info Banca */
    .bank-info-box {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        border: 1px solid #eee;
    }

        .bank-info-box p {
            margin: 0;
            font-weight: 700;
            color: #2c3e50;
            font-size: 1.1rem;
        }

    /* TABELLA ORDINI MODERNA */
    .orders-section {
        margin-top: 60px;
        margin-bottom: 100px;
    }

    .modern-table-wrapper {
        background: white;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.03);
        overflow-x: auto;
    }

    .modern-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .modern-table th {
            background: #f8f9fa;
            color: #95a5a6;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 20px;
            border-bottom: 2px solid #eee;
            text-align: left;
        }

        .modern-table td {
            padding: 20px;
            color: #2c3e50;
            font-weight: 600;
            border-bottom: 1px solid #f1f2f6;
            vertical-align: middle;
        }

        .modern-table tbody tr {
            transition: background 0.3s;
        }

            .modern-table tbody tr:hover {
                background: #fafbfc;
            }

    .btn-table {
        background: #e0e7ef;
        color: #2c3e50;
        border-radius: 20px;
        padding: 6px 20px;
        font-size: 0.85rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s;
        display: inline-block;
    }

        .btn-table:hover {
            background: #2c3e50;
            color: white;
        }

    /* Paginazione Custom */
    .pagination {
        justify-content: center;
        margin-top: 30px;
        gap: 10px;
    }

        .pagination button {
            border: none;
            background: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            font-weight: 700;
            color: #2c3e50;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            transition: all 0.3s;
        }

            .pagination button:hover, .pagination button.active {
                background: #2c3e50;
                color: white;
                transform: translateY(-2px);
            }

    /* TOAST FALLBACK MODERNO */
    .custom-toast {
        position: fixed;
        bottom: 20px;
        right: 20px;
        padding: 15px 25px;
        border-radius: 8px;
        color: white;
        font-weight: 700;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        z-index: 9999;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

        .custom-toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .custom-toast.error {
            background-color: #e74c3c;
        }

        .custom-toast.success {
            background-color: #2ecc71;
        }

        .custom-toast.warning {
            background-color: #f39c12;
        }

    .hidden {
        display: none;
    }

    @@media (max-width: 768px) {
        .dashboard-card {
            padding: 30px 20px;
        }

        .th-desktop {
            display: none;
        }

        .modern-table td {
            font-size: 0.9rem;
            padding: 15px 10px;
        }
    }
</style>

<div class="container pt-5 pb-5">

    <div class="dashboard-header" data-aos="fade-down">
        <h1>@Resources.labels.Ciao, @Model.ModelUser.Utente.Nome!</h1>
        <p>Benvenuto nel tuo profilo personale. Qui puoi gestire i tuoi dati e controllare i tuoi ordini.</p>
    </div>

    <div class="row g-4">

        <div class="col-lg-7" data-aos="fade-right">
            <div class="dashboard-card">
                <h3 class="card-title">@Resources.labels.DatiPersonali</h3>

                @using (Html.BeginForm("AggiornaUtente", "Login", FormMethod.Post, new { @enctype = "multipart/form-data", id = "formProfilo" }))
                {
                    @Html.ValidationSummary(true)
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.ModelUser.Utente.id_utente)

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="modern-label">@Resources.labels.Nome</label>
                            @Html.TextBoxFor(model => model.ModelUser.Utente.Nome, new { @class = "modern-input", required = "required" })
                        </div>
                        <div class="col-md-6">
                            <label class="modern-label">@Resources.labels.Cognome</label>
                            @Html.TextBoxFor(model => model.ModelUser.Utente.Cognome, new { @class = "modern-input", required = "required" })
                        </div>
                        <div class="col-md-6">
                            <label class="modern-label">Email</label>
                            @Html.TextBoxFor(model => model.ModelUser.Utente.Mail, new { @class = "modern-input", @type = "email", required = "required", autocomplete = "nope" })
                        </div>
                        <div class="col-md-6">
                            <label class="modern-label">@Resources.labels.Consegna_Cellullare</label>
                            @Html.TextBoxFor(model => model.ModelUser.Utente.Cellulare, new { @class = "modern-input", required = "required" })
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-12">
                            <label class="modern-label">@Resources.labels.Consegna_Indirizzo</label>
                            @Html.TextBoxFor(m => m.ModelUser.Utente.indirizzo, new { @class = "modern-input", id = "indirizzo", required = "required", autocomplete = "new-password" })
                        </div>
                        <div class="col-md-4">
                            <label class="modern-label">@Resources.labels.Consegna_Citta</label>
                            @Html.TextBoxFor(m => m.ModelUser.Utente.Citta, new { @class = "modern-input", id = "citta", @readonly = "readonly", tabindex = "-1" })
                        </div>
                        <div class="col-md-4">
                            <label class="modern-label">@Resources.labels.Consegna_Cap</label>
                            @Html.TextBoxFor(m => m.ModelUser.Utente.Cap, new { @class = "modern-input", id = "cap", @readonly = "readonly", tabindex = "-1" })
                        </div>
                        <div class="col-md-4">
                            <label class="modern-label">Nazione</label>
                            @Html.TextBoxFor(m => m.ModelUser.Utente.Nazione, new { @class = "modern-input", id = "nazione", @readonly = "readonly", tabindex = "-1" })
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="modern-label">Password</label>
                            <div class="password-wrapper">
                                @Html.TextBoxFor(model => model.ModelUser.Utente.Password, new { @class = "modern-input", @id = "password", @type = "password", autocomplete = "new-password" })
                                <button id="showPasswordBtn" class="toggle-password-btn" type="button" onclick="togglePasswordVisibility()">
                                    <span id="passwordIcon" class="material-symbols-outlined">visibility</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="text-end">
                        <button class="modern-btn-submit" type="submit" id="btnSalvaProfilo">
                            <span id="btnText">@Resources.labels.Aggiorna_dati</span>
                        </button>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-5" data-aos="fade-left">
            <div class="dashboard-card">
                <h3 class="card-title">@Resources.labels.Per_Pagare</h3>

                <div class="bank-info-box">
                    <label class="modern-label">@Resources.labels.Intestatario</label>
                    <p>@System.Configuration.ConfigurationManager.AppSettings["Intestatario"]</p>
                </div>

                <div class="bank-info-box">
                    <label class="modern-label">@Resources.labels.Nome_Banca</label>
                    <p>@System.Configuration.ConfigurationManager.AppSettings["NomeBanca"]</p>
                </div>

                <div class="bank-info-box">
                    <label class="modern-label">IBAN</label>
                    <p>@System.Configuration.ConfigurationManager.AppSettings["IBAN"]</p>
                </div>

                <div class="bank-info-box">
                    <label class="modern-label">@Resources.labels.Causale</label>
                    <p>"Numero ordine"</p>
                </div>
            </div>
        </div>

    </div>

    <div class="orders-section" data-aos="fade-up">
        <h3 class="card-title text-center d-block mx-auto mb-4">@Resources.labels.ItuoiOrdini</h3>

        @if (Model.ModelUser.Ordini.Count > 0)
        {
            <div class="modern-table-wrapper">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>@Resources.labels.Numero_ordine</th>
                            <th>@Resources.labels.Data_ordine</th>
                            <th class="th-desktop">@Resources.labels.Qta</th>
                            <th class="th-desktop">Metodo</th>
                            <th>Azione</th>
                        </tr>
                    </thead>
                    <tbody class="content">
                        @foreach (var dettaglio in Model.ModelUser.Ordini)
                        {
                            <tr class="product-item">
                                <td>#@dettaglio.id_ordine</td>
                                <td>@dettaglio.DataOra.ToString("dd MMMM yyyy")</td>
                                <td class="th-desktop">@dettaglio.NumeroPezzi pezzi</td>
                                <td class="th-desktop">
                                    <span style="background: #eef2f5; padding: 4px 12px; border-radius: 10px; font-size: 0.8rem;">
                                        @dettaglio.Tipo_Pagamento
                                    </span>
                                </td>
                                <td>
                                    <a class="btn-table" href="@Url.Action("DettaglioOrdine", "Ordini", new { id = dettaglio.id_ordine })">
                                        Dettaglio <i class="fas fa-arrow-right ms-1"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pagination d-flex"></div>
        }
        else
        {
            <div class="dashboard-card text-center py-5">
                <i class="fas fa-box-open mb-3" style="font-size: 3rem; color: #95a5a6;"></i>
                <h2>@Resources.labels.No_ord_yet</h2>
                <p class="text-muted">Sembra che tu non abbia ancora effettuato acquisti.</p>
                <br />
                <a href='/Ecommerce/Index' class="modern-btn-submit text-decoration-none">@Resources.labels.Inizia</a>
            </div>
        }
    </div>
</div>

<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script async src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCv7f1ZWKOVszw7hykWKNDb0phtsK3MkN0&callback=initAutocomplete&libraries=places&v=weekly"></script>

<script>
    // ==========================================
    // NOTIFICHE (Nessun alert nativo)
    // ==========================================
    function showNotification(message, type) {
        if (typeof DevExpress !== 'undefined' && DevExpress.ui && DevExpress.ui.notify) {
            DevExpress.ui.notify({ message: message, type: type, displayTime: 3500 });
        } else {
            // Toast Custom se DevExtreme manca
            let toast = document.createElement("div");
            toast.className = "custom-toast " + (type === 'error' ? 'error' : (type === 'warning' ? 'warning' : 'success'));
            toast.innerText = message;
            document.body.appendChild(toast);

            setTimeout(() => toast.classList.add("show"), 100);
            setTimeout(() => {
                toast.classList.remove("show");
                setTimeout(() => toast.remove(), 300);
            }, 3500);
        }
    }

    @if (ViewBag.Message != null)
    {
        <text>
        document.addEventListener('DOMContentLoaded', function() {
            showNotification('@ViewBag.Message', 'success');
        });
        </text>
    }

    // ==========================================
    // AUTOCOMPLETE INDIRIZZO GOOGLE MAPS
    // ==========================================
    let autocomplete;
    let address1Field;
    let cityField;
    let postalField;
    let nationField;

    function initAutocomplete() {
        address1Field = document.querySelector("#indirizzo");
        cityField = document.querySelector("#citta");
        postalField = document.querySelector("#cap");
        nationField = document.querySelector("#nazione");

        autocomplete = new google.maps.places.Autocomplete(address1Field, {
            fields: ["address_components", "geometry"],
            types: ["address"],
        });

        autocomplete.addListener("place_changed", fillInAddress);
    }

    function fillInAddress() {
        const place = autocomplete.getPlace();
        if (!place || !place.address_components) return;

        postalField.value = ''; cityField.value = ''; nationField.value = '';
        let capFound = false; let hasStreetNumber = false;

        for (const component of place.address_components) {
            const componentType = component.types[0];
            switch (componentType) {
                case "postal_code": postalField.value = component.long_name; capFound = true; break;
                case "street_number": hasStreetNumber = true; break;
                case "locality":
                case "administrative_area_level_3": cityField.value = component.long_name; break;
                case "country": nationField.value = component.long_name; break;
            }
        }

        if (!hasStreetNumber) {
            showNotification("@Resources.labels.valida_indirizzo", "warning");
            address1Field.value = ''; cityField.value = ''; postalField.value = ''; nationField.value = '';
            return;
        }

        if (!capFound) postalField.value = "00000";
    }

    // ==========================================
    // PREVENZIONE SUBMIT TASTO INVIO + DOPPIO CLICK
    // ==========================================
    document.addEventListener("DOMContentLoaded", function () {
        var form = document.getElementById("formProfilo");
        var btnSalva = document.getElementById("btnSalvaProfilo");
        var btnText = document.getElementById("btnText");
        var addressInput = document.getElementById("indirizzo");

        // 1. Uccidiamo il tasto Invio dentro il campo indirizzo
        if (addressInput) {
            addressInput.addEventListener("keydown", function(e) {
                if (e.key === "Enter" || e.keyCode === 13) {
                    e.preventDefault();
                    return false;
                }
            });
        }

        // 2. Controllo sul Submit
        if (form) {
            form.addEventListener("submit", function (e) {
                var citta = document.getElementById("citta").value;
                var cap = document.getElementById("cap").value;

                if (!citta || !cap) {
                    e.preventDefault();
                    showNotification("Seleziona un indirizzo dal suggerimento di Google prima di salvare.", "error");
                    return false;
                }

                btnSalva.disabled = true;
                btnSalva.style.opacity = '0.7';
                btnSalva.style.pointerEvents = 'none';
                btnText.innerHTML = '<i class="fas fa-spinner fa-spin me-2" style="margin-right:8px;"></i> Salvataggio...';
            });
        }
    });

    // ==========================================
    // TOGGLE PASSWORD
    // ==========================================
    function togglePasswordVisibility() {
        var passwordInput = document.getElementById('password');
        var passwordIcon = document.getElementById('passwordIcon');
        if (passwordInput.type === "password") {
            passwordInput.type = "text";
            passwordIcon.innerText = "visibility_off";
        } else {
            passwordInput.type = "password";
            passwordIcon.innerText = "visibility";
        }
    }

    // ==========================================
    // PAGINAZIONE JS TABELLA
    // ==========================================
    document.addEventListener('DOMContentLoaded', function () {
        const content = document.querySelector('tbody.content');
        if(!content) return;
        const itemsPerPage = 10;
        let currentPage = 0;
        const items = Array.from(content.querySelectorAll('tr.product-item'));

        function showPage(page) {
            const startIndex = page * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;
            items.forEach((item, index) => {
                item.style.display = (index >= startIndex && index < endIndex) ? 'table-row' : 'none';
            });
            updateActiveButtonStates();
        }

        function createPageButtons() {
            const totalPages = Math.ceil(items.length / itemsPerPage);
            const paginationContainer = document.querySelector('.pagination');
            if(totalPages <= 1) return;

            for (let i = 0; i < totalPages; i++) {
                const btn = document.createElement('button');
                btn.textContent = i + 1;
                btn.addEventListener('click', () => {
                    currentPage = i; showPage(currentPage);
                });
                paginationContainer.appendChild(btn);
            }
        }

        function updateActiveButtonStates() {
            const btns = document.querySelectorAll('.pagination button');
            btns.forEach((btn, idx) => {
                if(idx === currentPage) btn.classList.add('active');
                else btn.classList.remove('active');
            });
        }

        if(items.length > 0) {
            createPageButtons();
            showPage(0);
        }
    });
</script>